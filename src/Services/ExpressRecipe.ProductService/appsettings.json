{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.HttpLogging": "Warning",
      "Microsoft.Extensions.Http": "Warning",
      "System.Net.Http.HttpClient": "Warning",
      "System.Net.Http.HttpClient.IIngredientServiceClient.ClientHandler": "Warning",
      "System.Net.Http.HttpClient.IIngredientServiceClient.LogicalHandler": "Warning",
      "Polly": "Warning",
      "ExpressRecipe": "Information",
      "ExpressRecipe.Client.Shared": "Information",
      "ExpressRecipe.Shared.Services.AuthenticationDelegatingHandler": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ProductImport": {
    "AutoImport": true,
    "AutoProcessing": true,
    "DataSource": "Both",
    "EnableCsvImport": true,
    "EnableJsonImport": true,
    "JsonImportDelayRecords": 100000,
    "EnableDataAugmentation": true,
    "DiagnoseJsonImages": true,
    "MaxParallelism": 4,
    "BatchSize": 1000,
    "BufferSize": 50000,
    "BatchDelayMs": 0,
    "UsdaPortion": {
      "AutoImport": true,
      "BatchDelayMs": 0
    }
  }
}
