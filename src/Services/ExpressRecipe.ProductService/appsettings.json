{
  "ConnectionStrings": {
    "productdb": "Server=localhost,1436;Database=ExpressRecipe.Products;Trusted_Connection=true;Min Pool Size=10;Max Pool Size=100;Connection Lifetime=600;"
  },
  "Features": {
    "EnableMetrics": true,
    "EnableOpenTelemetry": true
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext"]
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "SecretKey": "your-secret-key-min-32-characters-long-change-in-production",
    "Issuer": "ExpressRecipe",
    "Audience": "ExpressRecipe.Products",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "ProductImport": {
    "AutoImport": true,
    "AutoProcessing": true,
    "DataSource": "Both",
    "EnableCsvImport": true,
    "EnableJsonImport": true,
    "JsonImportDelayRecords": 100000,
    "EnableDataAugmentation": true,
    "DiagnoseJsonImages": true,
    "MaxParallelism": 16,
    "BatchSize": 2000,
    "BufferSize": 50000
  }
}
