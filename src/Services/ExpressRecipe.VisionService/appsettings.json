{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Vision": {
    "Onnx": {
      "Enabled": true,
      "ModelPath": "/models/yolov8n-products.onnx",
      "ConfidenceThreshold": 0.55
    },
    "PaddleOcr": {
      "Enabled": true,
      "ModelDirectory": "/models/paddle",
      "Language": "en"
    },
    "OllamaVision": {
      "Enabled": true,
      "Model": "llava",
      "Endpoint": "http://localhost:11434",
      "TimeoutMs": 10000
    },
    "AzureVision": {
      "Enabled": false,
      "Endpoint": "",
      "ApiKey": ""
    },
    "ImageMaxDimensionPx": 1280,
    "ProductServiceBaseUrl": "https+http://productservice"
  }
}
