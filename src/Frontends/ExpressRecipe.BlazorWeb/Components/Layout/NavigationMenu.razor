@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using ExpressRecipe.Client.Shared.Services
@inject NavigationManager Navigation
@inject IAuthService AuthService

<AuthorizeView>
    <Authorized>
        <a href="/dashboard" class="nav-link @GetActiveClass("/dashboard")">
            <span class="nav-icon">🏠</span>
            <span class="nav-text">Dashboard</span>
        </a>

        <a href="/search" class="nav-link @GetActiveClass("/search")">
            <span class="nav-icon">🔍</span>
            <span class="nav-text">Search</span>
        </a>

        <a href="/scanner" class="nav-link @GetActiveClass("/scanner")">
            <span class="nav-icon">📷</span>
            <span class="nav-text">Barcode Scanner</span>
        </a>

        <a href="/products" class="nav-link @GetActiveClass("/products")">
            <span class="nav-icon">📦</span>
            <span class="nav-text">Products</span>
        </a>

        <a href="/prices" class="nav-link @GetActiveClass("/prices")">
            <span class="nav-icon">🏷️</span>
            <span class="nav-text">Prices</span>
        </a>

        <a href="/grocery-stores" class="nav-link @GetActiveClass("/grocery-stores")">
            <span class="nav-icon">🏪</span>
            <span class="nav-text">Grocery Stores</span>
        </a>

        <a href="/recipes" class="nav-link @GetActiveClass("/recipes")">
            <span class="nav-icon">🍳</span>
            <span class="nav-text">Recipes</span>
        </a>

        <a href="/inventory" class="nav-link @GetActiveClass("/inventory")">
            <span class="nav-icon">🥫</span>
            <span class="nav-text">My Inventory</span>
        </a>

        <a href="/shopping" class="nav-link @GetActiveClass("/shopping")">
            <span class="nav-icon">🛒</span>
            <span class="nav-text">Shopping List</span>
        </a>

        <a href="/meal-planning" class="nav-link @GetActiveClass("/meal-planning")">
            <span class="nav-icon">📅</span>
            <span class="nav-text">Meal Planning</span>
        </a>

        <a href="/queue" class="nav-link @GetActiveClass("/queue")">
            <span class="nav-icon">📋</span>
            <span class="nav-text">Work Queue</span>
            @if (WorkQueueCount > 0)
            {
                <span class="notification-badge @(WorkQueueHasCritical ? "badge-critical" : "")">
                    @(WorkQueueCount > 99 ? "99+" : WorkQueueCount.ToString())
                </span>
            }
        </a>

        <a href="/discover" class="nav-link @GetActiveClass("/discover")">
            <span class="nav-icon">🔎</span>
            <span class="nav-text">What Can I Make?</span>
        </a>

        <div class="nav-divider"></div>

        <a href="/discover" class="nav-link @GetActiveClass("/discover")">
            <span class="nav-icon">🔥</span>
            <span class="nav-text">Discover</span>
        </a>

        <a href="/analytics" class="nav-link @GetActiveClass("/analytics")">
            <span class="nav-icon">📊</span>
            <span class="nav-text">Analytics</span>
        </a>

        <a href="/notifications" class="nav-link @GetActiveClass("/notifications")">
            <span class="nav-icon">🔔</span>
            <span class="nav-text">Notifications</span>
            @if (UnreadCount > 0)
            {
                <span class="notification-badge">@UnreadCount</span>
            }
        </a>

        <a href="/recalls" class="nav-link @GetActiveClass("/recalls")">
            <span class="nav-icon">⚠️</span>
            <span class="nav-text">Recall Alerts</span>
        </a>

        <a href="/allergy" class="nav-link @GetActiveClass("/allergy")">
            <span class="nav-icon">🩺</span>
            <span class="nav-text">Allergy Tracker</span>
        </a>

        <a href="/meal-planning" class="nav-link @GetActiveClass("/meal-planning")">
            <span class="nav-icon">⏱️</span>
            <span class="nav-text">Cooking Timers</span>
        </a>

        <a href="/discover" class="nav-link @GetActiveClass("/discover")">
            <span class="nav-icon">⭐</span>
            <span class="nav-text">Rewards &amp; Referrals</span>
        </a>

        <div class="nav-divider"></div>

        <a href="/sync" class="nav-link @GetActiveClass("/sync")">
            <span class="nav-icon">☁️</span>
            <span class="nav-text">Cloud Sync</span>
        </a>

        <a href="/profile" class="nav-link @GetActiveClass("/profile")">
            <span class="nav-icon">👤</span>
            <span class="nav-text">My Profile</span>
        </a>

        <a href="/settings" class="nav-link @GetActiveClass("/settings")">
            <span class="nav-icon">⚙️</span>
            <span class="nav-text">Settings</span>
        </a>

        <a href="/help" class="nav-link @GetActiveClass("/help")">
            <span class="nav-icon">❓</span>
            <span class="nav-text">Help</span>
        </a>

        <AuthorizeView Roles="Admin" Context="adminCtx">
            <Authorized>
                <div class="nav-divider"></div>
                <a href="/admin/import" class="nav-link @GetActiveClass("/admin/import")">
                    <span class="nav-icon">📥</span>
                    <span class="nav-text">Data Import</span>
                </a>
                <a href="/admin/import-dashboard" class="nav-link @GetActiveClass("/admin/import-dashboard")">
                    <span class="nav-icon">📊</span>
                    <span class="nav-text">Import Dashboard</span>
                </a>
                <a href="/admin/users" class="nav-link @GetActiveClass("/admin/users")">
                    <span class="nav-icon">👥</span>
                    <span class="nav-text">User Management</span>
                </a>
            </Authorized>
        </AuthorizeView>

        <button @onclick="HandleLogout" class="nav-link logout-btn">
            <span class="nav-icon">🚪</span>
            <span class="nav-text">Logout</span>
        </button>
    </Authorized>
    <NotAuthorized>
        <a href="/login" class="nav-link">
            <span class="nav-icon">🔐</span>
            <span class="nav-text">Login</span>
        </a>
        <a href="/register" class="nav-link">
            <span class="nav-icon">✨</span>
            <span class="nav-text">Register</span>
        </a>
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter]
    public int UnreadCount { get; set; }

    [Parameter]
    public int WorkQueueCount { get; set; }

    [Parameter]
    public bool WorkQueueHasCritical { get; set; }

    private string GetActiveClass(string path)
    {
        return Navigation.Uri.Contains(path, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    }

    private async Task HandleLogout()
    {
        try
        {
            Console.WriteLine("[NavigationMenu] HandleLogout called - button click detected!");

            Console.WriteLine("[NavigationMenu] Calling AuthService.LogoutAsync");
            await AuthService.LogoutAsync();
            Console.WriteLine("[NavigationMenu] AuthService.LogoutAsync completed");

            Console.WriteLine("[NavigationMenu] Navigating to /login with forceLoad");
            Navigation.NavigateTo("/login", forceLoad: true);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[NavigationMenu] Logout failed: {ex.Message}");
            Navigation.NavigateTo("/login", forceLoad: true);
        }
    }
}
