@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using ExpressRecipe.Client.Shared.Services
@implements IDisposable
@inject IWorkQueueState WorkQueueState

<div class="app-container">
    <div class="sidebar">
        <div class="sidebar-header">
            <h1 class="logo">🍽️ ExpressRecipe</h1>
        </div>

        <nav class="sidebar-nav">
            <NavigationMenu UnreadCount="@_unreadCount"
                            WorkQueueCount="@WorkQueueState.PendingCount"
                            WorkQueueHasCritical="@WorkQueueState.HasCritical" />
        </nav>
    </div>

    <div class="main-content">
        <header class="top-bar">
            <UserInfoBar />
        </header>

        <main class="page-content">
            <CascadingValue Name="EatingDisorderRecovery" Value="@_eatingDisorderRecovery">
                @Body
            </CascadingValue>
        </main>

        <CookingTimerWidget />
    </div>
</div>

<ToastContainer />

@code {
    private int  _unreadCount          = 0;
    private bool _eatingDisorderRecovery = false;
    // TODO: Load from PreferencesService for the authenticated user's primary profile

    protected override async Task OnInitializedAsync()
    {
        WorkQueueState.OnChange += HandleQueueChange;
        // Refresh the work queue count on layout load (best-effort; failures are swallowed).
        await WorkQueueState.RefreshAsync();
    }

    private void HandleQueueChange() => InvokeAsync(StateHasChanged);

    public void Dispose() => WorkQueueState.OnChange -= HandleQueueChange;
}
