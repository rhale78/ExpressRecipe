@page "/settings/household"
@page "/setup/household"
@rendermode InteractiveServer
@using ExpressRecipe.Client.Shared.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Household Members - ExpressRecipe</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="settings-container">
            <div class="settings-header">
                <button class="btn btn-outline" @onclick="@(() => Navigation.NavigateTo("/settings"))">
                    ← Back to Settings
                </button>
                <h1>👨‍👩‍👧‍👦 Household Members</h1>
            </div>
            <p class="settings-subtitle">
                Manage everyone in your household. Each member has their own allergen profile and preferences.
            </p>
            <div class="settings-section">
                <div class="section-header">
                    <h2>Members</h2>
                    <button class="btn btn-primary btn-sm" @onclick="ShowAddMember">+ Add Member</button>
                </div>
                @if (_isLoading)
                {
                    <div class="loading-container"><div class="spinner"></div><p>Loading members...</p></div>
                }
                else if (_members.Count == 0)
                {
                    <p class="empty-message">No members added yet. Add yourself and family members to get started.</p>
                }
                else
                {
                    <div class="member-list">
                        @foreach (HouseholdMemberItem member in _members)
                        {
                            <div class="action-card">
                                <div class="action-card-icon">👤</div>
                                <div class="action-card-content">
                                    <h3>@member.DisplayName</h3>
                                    <p>@member.MemberType @(member.BirthYear.HasValue ? $"(born {member.BirthYear})" : string.Empty)</p>
                                </div>
                                <div class="action-card-actions">
                                    <button class="btn btn-outline btn-sm"
                                            @onclick="@(() => Navigation.NavigateTo($"/settings/allergens/{member.Id}"))">
                                        Allergens
                                    </button>
                                    <button class="btn btn-outline btn-sm"
                                            @onclick="@(() => Navigation.NavigateTo($"/settings/cookprofile/{member.Id}"))">
                                        Cook Profile
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="settings-container">
            <p>Please <a href="/login">sign in</a> to manage household members.</p>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool _isLoading = true;
    private List<HouseholdMemberItem> _members = new();

    protected override async Task OnInitializedAsync()
    {
        // TODO: Load members via ProfileService HTTP client
        await Task.Delay(10);
        _isLoading = false;
    }

    private void ShowAddMember()
    {
        // TODO: Show add member form
    }

    private class HouseholdMemberItem
    {
        public Guid Id { get; set; }
        public string DisplayName { get; set; } = string.Empty;
        public string MemberType { get; set; } = string.Empty;
        public short? BirthYear { get; set; }
    }
}
