@page "/settings/tips/{MemberId:guid}"
@page "/setup/tips/{MemberId:guid}"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using ExpressRecipe.Client.Shared.Services
@inject NavigationManager Navigation
@inject IPreferencesApiClient PreferencesClient

<PageTitle>Cooking Tips - ExpressRecipe</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="settings-container">
            <div class="settings-header">
                <button class="btn btn-outline" @onclick="@(() => Navigation.NavigateTo($"/settings/cookprofile/{MemberId}"))">
                    ← Back to Cook Profile
                </button>
                <h1>💡 Cooking Tips</h1>
            </div>
            <p class="settings-subtitle">
                Manage dismissed cooking tips. Restore tips you'd like to see again.
            </p>
            <div class="settings-section">
                <div class="section-header">
                    <h2>Dismissed Tips</h2>
                </div>
                @if (_isLoading)
                {
                    <div class="loading-container"><div class="spinner"></div><p>Loading dismissed tips...</p></div>
                }
                else if (_dismissedTips.Count == 0)
                {
                    <p class="empty-message">No dismissed tips. Tips you dismiss will appear here so you can restore them.</p>
                }
                else
                {
                    @foreach (DismissedTipItem tip in _dismissedTips)
                    {
                        <div class="action-card">
                            <div class="action-card-content">
                                <h3>@(string.IsNullOrWhiteSpace(tip.TipTitle) ? $"Tip ({tip.TipId})" : tip.TipTitle)</h3>
                                <p>Dismissed: @tip.DismissedAt.ToShortDateString()</p>
                            </div>
                            <div class="action-card-actions">
                                <button class="btn btn-outline btn-sm" @onclick="@(() => RestoreTipAsync(tip.TipId))">
                                    Restore
                                </button>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="settings-container">
            <p>Please <a href="/login">sign in</a> to manage tip settings.</p>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter]
    public Guid MemberId { get; set; }

    private bool _isLoading = true;
    private List<DismissedTipItem> _dismissedTips = new();
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var tips = await PreferencesClient.GetDismissedTipsAsync(MemberId);
            if (tips != null)
            {
                _dismissedTips = tips.Select(t => new DismissedTipItem
                {
                    TipId = t.TipId,
                    DismissedAt = t.DismissedAt
                }).ToList();
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load dismissed tips: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task RestoreTipAsync(Guid tipId)
    {
        try
        {
            await PreferencesClient.RestoreTipAsync(MemberId, tipId);
            _dismissedTips.RemoveAll(t => t.TipId == tipId);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Restore failed: {ex.Message}";
        }
    }

    private class DismissedTipItem
    {
        public Guid TipId { get; set; }
        public string TipTitle { get; set; } = string.Empty;
        public DateTime DismissedAt { get; set; }
    }
}
