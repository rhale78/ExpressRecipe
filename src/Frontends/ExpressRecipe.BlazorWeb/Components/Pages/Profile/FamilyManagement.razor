@page "/profile/family"
@using ExpressRecipe.Client.Shared.Services
@using ClientModels = ExpressRecipe.Client.Shared.Models.User
@inject IUserProfileApiClient UserProfileClient
@inject IToastService ToastService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Family Management - ExpressRecipe</PageTitle>

<div class="container py-4">
    <div class="row">
        <div class="col-lg-10 mx-auto">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="display-5 fw-bold">
                    <i class="bi bi-people-fill me-2"></i>Family Management
                </h1>
                <button class="btn btn-primary" @onclick="ShowAddMemberModal">
                    <i class="bi bi-person-plus me-2"></i>Add Family Member
                </button>
            </div>

            @if (isLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-3 text-muted">Loading family members...</p>
                </div>
            }
            else if (familyMembers != null && familyMembers.Any())
            {
                <div class="row g-3">
                    @foreach (var member in familyMembers)
                    {
                        <div class="col-md-6">
                            <div class="card h-100">
                                <div class="card-header d-flex justify-content-between align-items-center">
                                    <h5 class="mb-0">
                                        @member.Name
                                        @if (member.HasUserAccount)
                                        {
                                            <i class="bi bi-person-check text-success ms-2" title="Has account"></i>
                                        }
                                        @if (member.IsGuest)
                                        {
                                            <span class="badge bg-info ms-2">Guest</span>
                                        }
                                    </h5>
                                    <div>
                                        <span class="badge @GetRoleBadgeClass(member.UserRole)">@member.UserRole</span>
                                    </div>
                                </div>
                                <div class="card-body">
                                    @if (!string.IsNullOrEmpty(member.Relationship))
                                    {
                                        <p class="mb-2"><strong>Relationship:</strong> @member.Relationship</p>
                                    }
                                    @if (member.DateOfBirth.HasValue)
                                    {
                                        <p class="mb-2"><strong>Date of Birth:</strong> @member.DateOfBirth.Value.ToShortDateString()</p>
                                    }
                                    @if (member.HasUserAccount && !string.IsNullOrEmpty(member.Email))
                                    {
                                        <p class="mb-2"><strong>Email:</strong> @member.Email</p>
                                    }

                                    @if (member.Allergens.Any())
                                    {
                                        <div class="mb-2">
                                            <strong>Allergens:</strong>
                                            <div class="mt-1">
                                                @foreach (var allergen in member.Allergens)
                                                {
                                                    <span class="badge bg-danger me-1">@allergen</span>
                                                }
                                            </div>
                                        </div>
                                    }

                                    @if (member.DietaryRestrictions.Any())
                                    {
                                        <div class="mb-2">
                                            <strong>Dietary Restrictions:</strong>
                                            <div class="mt-1">
                                                @foreach (var restriction in member.DietaryRestrictions)
                                                {
                                                    <span class="badge bg-warning text-dark me-1">@restriction</span>
                                                }
                                            </div>
                                        </div>
                                    }

                                    @if (!string.IsNullOrEmpty(member.Notes))
                                    {
                                        <p class="mb-2"><small class="text-muted">@member.Notes</small></p>
                                    }
                                </div>
                                <div class="card-footer">
                                    <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => EditMember(member)">
                                        <i class="bi bi-pencil me-1"></i>Edit
                                    </button>
                                    @if (member.IsGuest)
                                    {
                                        <button class="btn btn-sm btn-outline-warning" @onclick="() => DismissGuest(member)">
                                            <i class="bi bi-x-circle me-1"></i>Dismiss Guest
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteMember(member)">
                                            <i class="bi bi-trash me-1"></i>Delete
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>
                    No family members added yet. Click "Add Family Member" to get started.
                </div>
            }
        </div>
    </div>
</div>

@* Add/Edit Family Member Modal *@
@if (showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(isEditMode ? "Edit" : "Add") Family Member</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Name *</label>
                        <input type="text" class="form-control" @bind="currentMember.Name" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Relationship</label>
                        <input type="text" class="form-control" @bind="currentMember.Relationship" placeholder="e.g., Spouse, Child, Parent" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Date of Birth</label>
                        <input type="date" class="form-control" @bind="currentMember.DateOfBirth" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Role</label>
                        <select class="form-select" @bind="currentMember.UserRole">
                            <option value="Admin">Admin (Can manage all family members)</option>
                            <option value="Member">Member (Can manage themselves only)</option>
                            <option value="Guest">Guest (View only, temporary access)</option>
                        </select>
                    </div>

                    @if (!isEditMode)
                    {
                        <div class="mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="createAccount" @bind="createWithAccount" />
                                <label class="form-check-label" for="createAccount">
                                    Create user account for this family member
                                </label>
                            </div>
                        </div>

                        @if (createWithAccount)
                        {
                            <div class="mb-3">
                                <label class="form-label">Email *</label>
                                <input type="email" class="form-control" @bind="memberEmail" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Password *</label>
                                <input type="password" class="form-control" @bind="memberPassword" />
                                <small class="text-muted">Minimum 8 characters</small>
                            </div>

                            <div class="mb-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="sendEmail" @bind="sendWelcomeEmail" />
                                    <label class="form-check-label" for="sendEmail">
                                        Send welcome email
                                    </label>
                                </div>
                            </div>
                        }
                    }

                    <div class="mb-3">
                        <label class="form-label">Notes</label>
                        <textarea class="form-control" rows="3" @bind="currentMember.Notes"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveMember" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        @(isEditMode ? "Update" : "Add") Member
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ClientModels.FamilyMemberDto>? familyMembers;
    private bool isLoading = true;
    private bool showModal = false;
    private bool isEditMode = false;
    private bool isSaving = false;
    private ClientModels.CreateFamilyMemberRequest currentMember = new();
    private Guid? editingMemberId = null;
    
    // Account creation fields
    private bool createWithAccount = false;
    private string memberEmail = string.Empty;
    private string memberPassword = string.Empty;
    private bool sendWelcomeEmail = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadFamilyMembers();
    }

    private async Task LoadFamilyMembers()
    {
        isLoading = true;
        try
        {
            familyMembers = await UserProfileClient.GetFamilyMembersAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Failed to load family members: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowAddMemberModal()
    {
        isEditMode = false;
        editingMemberId = null;
        currentMember = new ClientModels.CreateFamilyMemberRequest();
        createWithAccount = false;
        memberEmail = string.Empty;
        memberPassword = string.Empty;
        sendWelcomeEmail = true;
        showModal = true;
    }

    private void EditMember(ClientModels.FamilyMemberDto member)
    {
        isEditMode = true;
        editingMemberId = member.Id;
        currentMember = new ClientModels.UpdateFamilyMemberRequest
        {
            Name = member.Name,
            Relationship = member.Relationship,
            DateOfBirth = member.DateOfBirth,
            Allergens = new List<string>(member.Allergens),
            IngredientsToAvoid = new List<string>(member.IngredientsToAvoid),
            DietaryRestrictions = new List<string>(member.DietaryRestrictions),
            DislikedFoods = new List<string>(member.DislikedFoods),
            Notes = member.Notes,
            UserRole = member.UserRole,
            IsGuest = member.IsGuest
        };
        showModal = true;
    }

    private async Task SaveMember()
    {
        if (string.IsNullOrWhiteSpace(currentMember.Name))
        {
            ToastService.ShowWarning("Please enter a name");
            return;
        }

        if (!isEditMode && createWithAccount)
        {
            if (string.IsNullOrWhiteSpace(memberEmail) || string.IsNullOrWhiteSpace(memberPassword))
            {
                ToastService.ShowWarning("Email and password are required when creating an account");
                return;
            }
        }

        isSaving = true;
        try
        {
            if (isEditMode && editingMemberId.HasValue)
            {
                await UserProfileClient.UpdateFamilyMemberAsync(editingMemberId.Value, (ClientModels.UpdateFamilyMemberRequest)currentMember);
                ToastService.ShowSuccess("Family member updated successfully");
            }
            else if (createWithAccount)
            {
                var request = new ClientModels.CreateFamilyMemberWithAccountRequest
                {
                    Name = currentMember.Name,
                    Relationship = currentMember.Relationship,
                    DateOfBirth = currentMember.DateOfBirth,
                    Allergens = currentMember.Allergens,
                    IngredientsToAvoid = currentMember.IngredientsToAvoid,
                    DietaryRestrictions = currentMember.DietaryRestrictions,
                    DislikedFoods = currentMember.DislikedFoods,
                    Notes = currentMember.Notes,
                    UserRole = currentMember.UserRole,
                    IsGuest = currentMember.IsGuest,
                    Email = memberEmail,
                    Password = memberPassword,
                    SendWelcomeEmail = sendWelcomeEmail
                };
                await UserProfileClient.CreateFamilyMemberWithAccountAsync(request);
                ToastService.ShowSuccess("Family member created with account successfully");
            }
            else
            {
                await UserProfileClient.CreateFamilyMemberAsync(currentMember);
                ToastService.ShowSuccess("Family member added successfully");
            }

            CloseModal();
            await LoadFamilyMembers();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Failed to save family member: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteMember(ClientModels.FamilyMemberDto member)
    {
        try
        {
            await UserProfileClient.DeleteFamilyMemberAsync(member.Id);
            ToastService.ShowSuccess("Family member deleted successfully");
            await LoadFamilyMembers();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Failed to delete family member: {ex.Message}");
        }
    }

    private async Task DismissGuest(ClientModels.FamilyMemberDto member)
    {
        try
        {
            await UserProfileClient.DismissGuestAsync(member.Id);
            ToastService.ShowSuccess("Guest dismissed successfully");
            await LoadFamilyMembers();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Failed to dismiss guest: {ex.Message}");
        }
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private string GetRoleBadgeClass(string role) => role switch
    {
        "Admin" => "bg-primary",
        "Member" => "bg-success",
        "Guest" => "bg-info",
        _ => "bg-secondary"
    };
}
