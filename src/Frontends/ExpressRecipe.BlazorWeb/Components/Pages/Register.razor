@page "/register"
@rendermode InteractiveServer
@using ExpressRecipe.Client.Shared.Models.Auth
@using ExpressRecipe.Client.Shared.Services
@using System.ComponentModel.DataAnnotations
@inject IAuthService AuthService
@inject CustomAuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<PageTitle>Register - ExpressRecipe</PageTitle>

<div class="login-container">
    <div class="login-card">
        <h2>Create Account</h2>
        <p class="subtitle">Join ExpressRecipe and start managing your dietary needs</p>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-error">
                @_errorMessage
            </div>
        }

        <EditForm Model="@_registerRequest" OnValidSubmit="@HandleRegister" FormName="registerForm">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-row">
                <div class="form-group">
                    <label for="firstName">First Name</label>
                    <InputText id="firstName" @bind-Value="_registerRequest.FirstName" class="form-control" placeholder="John" />
                    <ValidationMessage For="@(() => _registerRequest.FirstName)" />
                </div>

                <div class="form-group">
                    <label for="lastName">Last Name</label>
                    <InputText id="lastName" @bind-Value="_registerRequest.LastName" class="form-control" placeholder="Doe" />
                    <ValidationMessage For="@(() => _registerRequest.LastName)" />
                </div>
            </div>

            <div class="form-group">
                <label for="email">Email</label>
                <InputText id="email" @bind-Value="_registerRequest.Email" class="form-control" placeholder="you@example.com" />
                <ValidationMessage For="@(() => _registerRequest.Email)" />
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <InputText id="password" type="password" @bind-Value="_registerRequest.Password" class="form-control" placeholder="At least 8 characters" />
                <ValidationMessage For="@(() => _registerRequest.Password)" />
                <small class="form-text">Must be at least 8 characters long</small>
            </div>

            <div class="form-group">
                <label for="confirmPassword">Confirm Password</label>
                <InputText id="confirmPassword" type="password" @bind-Value="_confirmPassword" class="form-control" placeholder="Re-enter your password" />
                @if (!string.IsNullOrEmpty(_confirmPassword) && _registerRequest.Password != _confirmPassword)
                {
                    <small class="text-danger">Passwords do not match</small>
                }
            </div>

            <button type="submit" class="btn btn-primary" disabled="@(_isLoading || _registerRequest.Password != _confirmPassword)">
                @if (_isLoading)
                {
                    <span class="spinner"></span>
                    <span>Creating account...</span>
                }
                else
                {
                    <span>Create Account</span>
                }
            </button>
        </EditForm>

        <div class="login-footer">
            <p>Already have an account? <a href="/login">Sign in</a></p>
        </div>
    </div>
</div>

@code {
private ExpressRecipe.Client.Shared.Models.Auth.RegisterRequest _registerRequest = new();
private string _confirmPassword = string.Empty;
private string? _errorMessage;
private bool _isLoading;

    private async Task HandleRegister()
    {
        if (_registerRequest.Password != _confirmPassword)
        {
            _errorMessage = "Passwords do not match";
            return;
        }

        _isLoading = true;
        _errorMessage = null;

        try
        {
            // Debug: Log what we're sending
            Console.WriteLine($"Sending registration: Email={_registerRequest.Email}, FirstName={_registerRequest.FirstName}, LastName={_registerRequest.LastName}, PasswordLength={_registerRequest.Password?.Length ?? 0}");

            var result = await AuthService.RegisterAsync(_registerRequest);

            if (result != null)
            {
                // Update authentication state
                await AuthStateProvider.MarkUserAsAuthenticated(
                    result.Email,
                    result.FirstName,
                    result.LastName,
                    result.UserId
                );

                // Force reload to ensure authentication state is fully initialized
                Navigation.NavigateTo("/dashboard", forceLoad: true);
            }
            else
            {
                _errorMessage = "Registration failed. Please try again.";
            }
        }
        catch (InvalidOperationException ex)
        {
            // Display specific error from API
            Console.WriteLine($"Registration InvalidOperationException: {ex.Message}");
            _errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Registration Exception: {ex.GetType().Name} - {ex.Message}");
            _errorMessage = $"Registration error: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }
}

