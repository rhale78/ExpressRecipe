    /// <summary>Safely parses a date string in yyyy-MM-dd format (as returned by type="date" inputs).</summary>
    private static DateTime ParseDateInput(object? value, DateTime fallback)
    {
        string? str = value?.ToString();
        if (string.IsNullOrEmpty(str))
            return fallback;

        if (DateTime.TryParseExact(str, "yyyy-MM-dd",
                System.Globalization.CultureInfo.InvariantCulture,
                System.Globalization.DateTimeStyles.None,
                out DateTime result))
        {
            return result;
        }

        return fallback;
    }
