    private void ShowSaveTemplateModal()
    {
        if (_currentActivePlan == null)
            return;

        _templateName = _currentActivePlan.Name;
        _templateDescription = null;
        _templateCategory = null;
        _templateFromDate = _currentActivePlan.StartDate;
        _templateToDate = _currentActivePlan.EndDate;
        _templateIsPublic = false;
        _saveTemplateError = string.Empty;
        _saveTemplateSuccess = string.Empty;
        _showSaveTemplateModal = true;
    }

    private async Task ExecuteSaveTemplate()
    {
        if (_currentActivePlan == null)
            return;

        if (string.IsNullOrWhiteSpace(_templateName))
        {
            _saveTemplateError = "Template name is required.";
            return;
        }

        _saveTemplateError = string.Empty;
        SaveTemplateRequest request = new()
        {
            PlanId = _currentActivePlan.Id,
            Name = _templateName,
            Description = _templateDescription,
            Category = _templateCategory,
            FromDate = DateOnly.FromDateTime(_templateFromDate),
            ToDate = DateOnly.FromDateTime(_templateToDate),
            IsPublic = _templateIsPublic
        };

        Guid? templateId = await MealPlanApi.SaveAsTemplateAsync(request);
        if (templateId.HasValue)
        {
            _saveTemplateSuccess = "Template saved successfully!";
        }
        else
        {
            _saveTemplateError = "Failed to save template. Please try again.";
        }
    }

