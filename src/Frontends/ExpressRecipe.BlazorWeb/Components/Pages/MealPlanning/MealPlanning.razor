    private void ShowCloneMealModal(MealPlanEntryDto meal, DateTime sourceDate)
    {
        _cloneMealSource = meal;
        _cloneTargetDate = sourceDate.AddDays(1);
        _cloneTargetMealType = meal.MealType;
        _cloneMealError = string.Empty;
        _showCloneMealModal = true;
    }

    private void CloseCloneMealModal()
    {
        _showCloneMealModal = false;
        _cloneMealSource = null;
    }

    private async Task ExecuteCloneMeal()
    {
        if (_cloneMealSource == null)
            return;

        _cloneMealError = string.Empty;
        CloneMealRequest request = new()
        {
            TargetDate = DateOnly.FromDateTime(_cloneTargetDate),
            TargetMealType = _cloneTargetMealType
        };

        Guid? newId = await MealPlanApi.CloneMealAsync(_cloneMealSource.Id, request);
        if (newId.HasValue)
        {
            CloseCloneMealModal();
            await LoadWeekView();
        }
        else
        {
            _cloneMealError = "Failed to clone meal. Please try again.";
        }
    }

