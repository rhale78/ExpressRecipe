@page "/meal-planning"
@rendermode InteractiveServer
@using ExpressRecipe.Client.Shared.Models.MealPlanning
@using ExpressRecipe.Client.Shared.Models.Recipe
@using ExpressRecipe.Client.Shared.Services
@inject IMealPlanApiClient MealPlanApi
@inject IRecipeApiClient RecipeApi
@inject NavigationManager Navigation

<PageTitle>Meal Planning - ExpressRecipe</PageTitle>

<div class="meal-planning-container">
    <div class="planning-header">
        <h1>📅 Meal Planning</h1>
        <div class="header-actions">
            <button class="btn btn-secondary" @onclick="NavigateToCalendarView">
                🗓️ Calendar View
            </button>
            <button class="btn btn-secondary" @onclick="CreateQuickPlan">
                ⚡ Quick Plan
            </button>
            <button class="btn btn-primary" @onclick="CreateMealPlan">
                ➕ New Plan
            </button>
        </div>
    </div>

    <p class="planning-subtitle">
        Plan your meals for the week and generate shopping lists automatically.
    </p>

    @if (_isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Loading meal plans...</p>
        </div>
    }
    else if (_summary != null)
    {
        <!-- Summary Cards -->
        <div class="summary-dashboard">
            <div class="summary-card">
                <div class="summary-icon">📋</div>
                <div class="summary-value">@_summary.TotalActivePlans</div>
                <div class="summary-label">Active Plans</div>
            </div>

            <div class="summary-card info">
                <div class="summary-icon">🍽️</div>
                <div class="summary-value">@_summary.MealsThisWeek</div>
                <div class="summary-label">Meals This Week</div>
            </div>

            <div class="summary-card success">
                <div class="summary-icon">✅</div>
                <div class="summary-value">@_summary.PreparedThisWeek</div>
                <div class="summary-label">Prepared This Week</div>
            </div>

            <div class="summary-card">
                <div class="summary-icon">⏱️</div>
                <div class="summary-value">@_summary.TotalUpcomingMeals</div>
                <div class="summary-label">Upcoming Meals</div>
            </div>
        </div>

        <!-- Week Navigation -->
        <div class="week-navigation">
            <button class="nav-btn" @onclick="PreviousWeek">← Previous Week</button>
            <h2 class="week-title">
                @_currentWeekStart.ToString("MMM dd") - @_currentWeekStart.AddDays(6).ToString("MMM dd, yyyy")
            </h2>
            <button class="nav-btn" @onclick="NextWeek">Next Week →</button>
        </div>

        <!-- Weekly Calendar -->
        @if (_weekView != null && _weekView.Days.Any())
        {
            <div class="week-calendar">
                @foreach (var day in _weekView.Days)
                {
                    string dayDateStr = day.Date.ToString("yyyy-MM-dd");
                    <div class="day-column @(day.Date.Date == DateTime.Today ? "today" : "")">
                        <!-- Day Header -->
                        <div class="day-header">
                            <div class="day-name">@day.Date.ToString("ddd")</div>
                            <div class="day-date">
                                <a class="day-date-link" href="/meal-planning/day/@day.Date.ToString("yyyy-MM-dd")">
                                    @day.Date.ToString("MMM dd")
                                </a>
                            </div>
                            @if (day.IsComplete && day.TotalMeals > 0)
                            {
                                <div class="day-complete-badge">✓</div>
                            }
                        </div>

                        <!-- Drop zone for this day -->
                        <div class="day-meals @(_dragOverDate == dayDateStr ? "drag-target" : "")"
                             @ondragenter="() => OnDragEnter(dayDateStr)"
                             @ondragleave="OnDragLeave"
                             @ondragover:preventDefault
                             @ondrop="() => OnDropToDay(dayDateStr)">
                            @if (day.Meals.Any())
                            {
                                @foreach (var meal in day.Meals.OrderBy(m => GetMealTypeOrder(m.MealType)))
                                {
                                    <div class="meal-card @(meal.IsPrepared ? "prepared" : "") @GetMealTypeClass(meal.MealType)"
                                         draggable="true"
                                         @ondragstart="() => OnDragStart(meal)"
                                         @ondragend="() => { _draggingMeal = null; _dragOverDate = null; }"
                                         @onclick="() => ViewMeal(meal)">
                                        <div class="meal-type-badge">@GetMealTypeIcon(meal.MealType)</div>

                                        <div class="meal-info">
                                            <h4 class="meal-name">
                                                @if (meal.RecipeId.HasValue)
                                                {
                                                    @meal.RecipeName
                                                }
                                                else
                                                {
                                                    @meal.CustomMealName
                                                }
                                            </h4>

                                            @if (meal.Servings > 0)
                                            {
                                                <span class="meal-servings">👥 @meal.Servings servings</span>
                                            }

                                            @if (meal.RecipePrepTime.HasValue || meal.RecipeCookTime.HasValue)
                                            {
                                                <span class="meal-time">
                                                    ⏱️ @((meal.RecipePrepTime ?? 0) + (meal.RecipeCookTime ?? 0)) min
                                                </span>
                                            }

                                            @if (meal.RecipeAllergens.Any())
                                            {
                                                <div class="meal-allergens">
                                                    @foreach (var allergen in meal.RecipeAllergens.Take(2))
                                                    {
                                                        <span class="allergen-tag-xs">⚠️ @allergen</span>
                                                    }
                                                </div>
                                            }
                                        </div>

                                        <div class="meal-card-actions" @onclick:stopPropagation="true">
                                            <button class="btn-icon" title="Clone meal"
                                                    @onclick="() => ShowCloneMealModal(meal, day.Date)">
                                                📋
                                            </button>
                                        </div>

                                        @if (meal.IsPrepared)
                                        {
                                            <div class="prepared-checkmark">✓</div>
                                        }
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="empty-day">
                                    <p>No meals planned</p>
                                </div>
                            }
                        </div>

                        <!-- Add Meal Button -->
                        <button class="add-meal-btn" @onclick="() => ShowAddMealModal(day.Date)">
                            ➕ Add Meal
                        </button>
                    </div>
                }
            </div>

            <!-- Actions for Current Plan -->
            @if (_currentActivePlan != null)
            {
                <div class="plan-actions">
                    <button class="btn btn-primary" @onclick="GenerateShoppingList">
                        🛒 Generate Shopping List
                    </button>
                    <button class="btn btn-secondary" @onclick="ViewNutritionSummary">
                        📊 Nutrition Summary
                    </button>
                    <button class="btn btn-secondary" @onclick="() => ShowCopyDayModal()">
                        📋 Copy Day
                    </button>
                    <button class="btn btn-secondary" @onclick="() => ShowCopyWeekModal()">
                        📅 Copy Week
                    </button>
                    <button class="btn btn-secondary" @onclick="() => ShowSaveTemplateModal()">
                        💾 Save as Template
                    </button>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <div class="empty-icon">📅</div>
                <h3>No Meal Plan for This Week</h3>
                <p>Create a meal plan to start organizing your weekly meals.</p>
                <button class="btn btn-primary" @onclick="CreateMealPlan">
                    ➕ Create Meal Plan
                </button>
            </div>
        }
    }
</div>

<!-- Add/Edit Meal Modal -->
@if (_showAddMealModal)
{
    <div class="modal-overlay" @onclick="CloseAddMealModal">
        <div class="modal-content large" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>Add Meal - @_selectedDate.ToString("MMM dd, yyyy")</h2>
                <button class="modal-close" @onclick="CloseAddMealModal">✕</button>
            </div>

            <div class="modal-body">
                <div class="form-group">
                    <label>Meal Type *</label>
                    <select class="form-control" @bind="_newMealEntry.MealType">
                        <option value="Breakfast">🍳 Breakfast</option>
                        <option value="Lunch">🥗 Lunch</option>
                        <option value="Dinner">🍽️ Dinner</option>
                        <option value="Snack">🍿 Snack</option>
                    </select>
                </div>

                <!-- Recipe Search -->
                <div class="form-group">
                    <label>Search Recipes</label>
                    <div class="recipe-search-bar">
                        <input type="text" class="form-control" placeholder="Search safe recipes..."
                               @bind="_recipeSearchTerm" @bind:event="oninput" />
                        <button class="btn btn-secondary" @onclick="SearchRecipes">Search</button>
                    </div>

                    @if (_recipeSearchResults?.Any() == true)
                    {
                        <div class="recipe-search-results">
                            @foreach (var recipe in _recipeSearchResults.Take(5))
                            {
                                <div class="recipe-result-card" @onclick="() => SelectRecipe(recipe)">
                                    <strong>@recipe.Title</strong>
                                    <span class="text-muted">⏱️ @recipe.TotalTimeMinutes min</span>
                                    <button class="btn btn-sm btn-primary">Select</button>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="divider-small">OR</div>

                <!-- Custom Meal -->
                <div class="form-group">
                    <label>Custom Meal Name</label>
                    <input type="text" class="form-control" @bind="_newMealEntry.CustomMealName"
                           placeholder="e.g., Leftovers, Takeout" />
                </div>

                <div class="form-group">
                    <label>Servings</label>
                    <input type="number" class="form-control" @bind="_newMealEntry.Servings" min="1" />
                </div>

                <div class="form-group">
                    <label>Notes</label>
                    <textarea class="form-control" rows="2" @bind="_newMealEntry.Notes"></textarea>
                </div>

                @if (!string.IsNullOrEmpty(_addMealError))
                {
                    <div class="alert alert-error">@_addMealError</div>
                }
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary-outline" @onclick="CloseAddMealModal">Cancel</button>
                <button class="btn btn-primary" @onclick="SaveMeal">Add Meal</button>
            </div>
        </div>
    </div>
}

<!-- Nutrition Summary Modal -->
@if (_showNutritionModal)
{
    <div class="modal-overlay" @onclick="() => _showNutritionModal = false">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>📊 Nutrition Summary</h2>
                <button class="modal-close" @onclick="() => _showNutritionModal = false">✕</button>
            </div>
            <div class="modal-body">
                @if (_nutritionLoading)
                {
                    <div class="loading-state"><div class="spinner"></div><p>Loading...</p></div>
                }
                else if (_nutritionSummary == null)
                {
                    <p class="text-muted">No nutrition data available for this plan.</p>
                }
                else
                {
                    <div class="nutrition-grid">
                        <div class="nutrition-card">
                            <div class="nutrition-label">Total Calories</div>
                            <div class="nutrition-value">@_nutritionSummary.TotalCalories</div>
                            <div class="nutrition-avg">~@((int)_nutritionSummary.AvgDailyCalories)/day</div>
                        </div>
                        <div class="nutrition-card">
                            <div class="nutrition-label">Protein</div>
                            <div class="nutrition-value">@_nutritionSummary.TotalProtein g</div>
                            <div class="nutrition-avg">~@((int)_nutritionSummary.AvgDailyProtein) g/day</div>
                        </div>
                        <div class="nutrition-card">
                            <div class="nutrition-label">Carbohydrates</div>
                            <div class="nutrition-value">@_nutritionSummary.TotalCarbohydrates g</div>
                            <div class="nutrition-avg">~@((int)_nutritionSummary.AvgDailyCarbs) g/day</div>
                        </div>
                        <div class="nutrition-card">
                            <div class="nutrition-label">Fat</div>
                            <div class="nutrition-value">@_nutritionSummary.TotalFat g</div>
                            <div class="nutrition-avg">~@((int)_nutritionSummary.AvgDailyFat) g/day</div>
                        </div>
                    </div>
                    <p class="nutrition-note text-muted">Over @_nutritionSummary.DaysInPlan days</p>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary-outline" @onclick="() => _showNutritionModal = false">Close</button>
            </div>
        </div>
    </div>
}

<!-- Clone Meal Modal -->
@if (_showCloneMealModal && _cloneMealSource != null)
{
    <div class="modal-overlay" @onclick="CloseCloneMealModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>📋 Clone Meal</h2>
                <button class="modal-close" @onclick="CloseCloneMealModal">✕</button>
            </div>
            <div class="modal-body">
                <p>Clone <strong>@(_cloneMealSource.RecipeName ?? _cloneMealSource.CustomMealName)</strong> to another date.</p>
                <div class="form-group">
                    <label>Target Date</label>
                    <input type="date" class="form-control"
                           value="@_cloneTargetDate.ToString("yyyy-MM-dd")"
                           @onchange="e => _cloneTargetDate = ParseDateInput(e.Value, _cloneTargetDate)" />
                </div>
                <div class="form-group">
                    <label>Meal Type</label>
                    <select class="form-control" @bind="_cloneTargetMealType">
                        <option value="Breakfast">🍳 Breakfast</option>
                        <option value="Lunch">🥗 Lunch</option>
                        <option value="Dinner">🍽️ Dinner</option>
                        <option value="Snack">🍿 Snack</option>
                    </select>
                </div>
                @if (!string.IsNullOrEmpty(_cloneMealError))
                {
                    <div class="alert alert-error">@_cloneMealError</div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary-outline" @onclick="CloseCloneMealModal">Cancel</button>
                <button class="btn btn-primary" @onclick="ExecuteCloneMeal">📋 Clone</button>
            </div>
        </div>
    </div>
}

<!-- Copy Day Modal -->
@if (_showCopyDayModal)
{
    <div class="modal-overlay" @onclick="() => _showCopyDayModal = false">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>📋 Copy Day</h2>
                <button class="modal-close" @onclick="() => _showCopyDayModal = false">✕</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Source Date (copy from)</label>
                    <input type="date" class="form-control"
                           value="@_copyDaySource.ToString("yyyy-MM-dd")"
                           @onchange="e => _copyDaySource = ParseDateInput(e.Value, _copyDaySource)" />
                </div>
                <div class="form-group">
                    <label>Target Date (paste to)</label>
                    <input type="date" class="form-control"
                           value="@_copyDayTarget.ToString("yyyy-MM-dd")"
                           @onchange="e => _copyDayTarget = ParseDateInput(e.Value, _copyDayTarget)" />
                </div>
                @if (!string.IsNullOrEmpty(_copyDayError))
                {
                    <div class="alert alert-error">@_copyDayError</div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary-outline" @onclick="() => _showCopyDayModal = false">Cancel</button>
                <button class="btn btn-primary" @onclick="ExecuteCopyDay">📋 Copy</button>
            </div>
        </div>
    </div>
}

<!-- Copy Week Modal -->
@if (_showCopyWeekModal)
{
    <div class="modal-overlay" @onclick="() => _showCopyWeekModal = false">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>📅 Copy Week</h2>
                <button class="modal-close" @onclick="() => _showCopyWeekModal = false">✕</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Source Week Start (Sunday)</label>
                    <input type="date" class="form-control"
                           value="@_copyWeekSource.ToString("yyyy-MM-dd")"
                           @onchange="e => _copyWeekSource = ParseDateInput(e.Value, _copyWeekSource)" />
                </div>
                <div class="form-group">
                    <label>Target Week Start (Sunday)</label>
                    <input type="date" class="form-control"
                           value="@_copyWeekTarget.ToString("yyyy-MM-dd")"
                           @onchange="e => _copyWeekTarget = ParseDateInput(e.Value, _copyWeekTarget)" />
                </div>
                @if (!string.IsNullOrEmpty(_copyWeekError))
                {
                    <div class="alert alert-error">@_copyWeekError</div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary-outline" @onclick="() => _showCopyWeekModal = false">Cancel</button>
                <button class="btn btn-primary" @onclick="ExecuteCopyWeek">📅 Copy Week</button>
            </div>
        </div>
    </div>
}

<!-- Save as Template Modal -->
@if (_showSaveTemplateModal && _currentActivePlan != null)
{
    <div class="modal-overlay" @onclick="() => _showSaveTemplateModal = false">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>💾 Save as Template</h2>
                <button class="modal-close" @onclick="() => _showSaveTemplateModal = false">✕</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Template Name *</label>
                    <input type="text" class="form-control" @bind="_templateName"
                           placeholder="e.g., Family Weeknight Dinners" />
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea class="form-control" rows="2" @bind="_templateDescription"
                              placeholder="Brief description of this template"></textarea>
                </div>
                <div class="form-group">
                    <label>Category</label>
                    <input type="text" class="form-control" @bind="_templateCategory"
                           placeholder="e.g., Quick Weeknights, Healthy, Budget" />
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>From Date</label>
                        <input type="date" class="form-control"
                               value="@_templateFromDate.ToString("yyyy-MM-dd")"
                               @onchange="e => _templateFromDate = ParseDateInput(e.Value, _templateFromDate)" />
                    </div>
                    <div class="form-group">
                        <label>To Date</label>
                        <input type="date" class="form-control"
                               value="@_templateToDate.ToString("yyyy-MM-dd")"
                               @onchange="e => _templateToDate = ParseDateInput(e.Value, _templateToDate)" />
                    </div>
                </div>
                <div class="form-group form-check-group">
                    <label class="form-check-label">
                        <input type="checkbox" class="form-check-input" @bind="_templateIsPublic" />
                        Share publicly with community
                    </label>
                </div>
                @if (!string.IsNullOrEmpty(_saveTemplateError))
                {
                    <div class="alert alert-error">@_saveTemplateError</div>
                }
                @if (!string.IsNullOrEmpty(_saveTemplateSuccess))
                {
                    <div class="mealplan-alert-success">@_saveTemplateSuccess</div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary-outline" @onclick="() => _showSaveTemplateModal = false">Cancel</button>
                <button class="btn btn-primary" @onclick="ExecuteSaveTemplate">💾 Save Template</button>
            </div>
        </div>
    </div>
}

@code {
    private bool _isLoading = true;
    private MealPlanSummaryDto? _summary;
    private MealPlanWeekView? _weekView;
    private MealPlanDto? _currentActivePlan;
    private DateTime _currentWeekStart;

    // Add meal modal
    private bool _showAddMealModal = false;
    private DateTime _selectedDate;
    private AddMealPlanEntryRequest _newMealEntry = new();
    private string _addMealError = string.Empty;
    private string _recipeSearchTerm = string.Empty;
    private List<RecipeDto>? _recipeSearchResults;

    // Drag-and-drop state
    private MealPlanEntryDto? _draggingMeal;
    private string? _dragOverDate;

    // Nutrition summary modal
    private bool _showNutritionModal = false;
    private bool _nutritionLoading = false;
    private MealPlanNutritionSummaryDto? _nutritionSummary;

    // Clone meal modal
    private bool _showCloneMealModal = false;
    private MealPlanEntryDto? _cloneMealSource;
    private DateTime _cloneTargetDate = DateTime.Today.AddDays(1);
    private string _cloneTargetMealType = "Dinner";
    private string _cloneMealError = string.Empty;

    // Copy day modal
    private bool _showCopyDayModal = false;
    private DateTime _copyDaySource = DateTime.Today;
    private DateTime _copyDayTarget = DateTime.Today.AddDays(1);
    private string _copyDayError = string.Empty;

    // Copy week modal
    private bool _showCopyWeekModal = false;
    private DateTime _copyWeekSource = DateTime.Today;
    private DateTime _copyWeekTarget = DateTime.Today.AddDays(7);
    private string _copyWeekError = string.Empty;

    // Save template modal
    private bool _showSaveTemplateModal = false;
    private string _templateName = string.Empty;
    private string? _templateDescription;
    private string? _templateCategory;
    private DateTime _templateFromDate = DateTime.Today;
    private DateTime _templateToDate = DateTime.Today.AddDays(6);
    private bool _templateIsPublic = false;
    private string _saveTemplateError = string.Empty;
    private string _saveTemplateSuccess = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _currentWeekStart = GetWeekStart(DateTime.Today);
        await LoadMealPlanning();
    }

    private DateTime GetWeekStart(DateTime date)
    {
        // Calculate offset to the previous Sunday; formula returns 0 when date is already a Sunday
        int diff = (7 + (date.DayOfWeek - DayOfWeek.Sunday)) % 7;
        return date.AddDays(-1 * diff).Date;
    }

    private async Task LoadMealPlanning()
    {
        _isLoading = true;
        StateHasChanged();

        _summary = await MealPlanApi.GetMealPlanSummaryAsync();
        _weekView = await MealPlanApi.GetWeekViewAsync(_currentWeekStart);

        // Get current active plan for actions
        MealPlanSearchResult? plansResult = await MealPlanApi.SearchMealPlansAsync(new MealPlanSearchRequest
        {
            Status = "Active",
            Page = 1,
            PageSize = 1
        });
        _currentActivePlan = plansResult?.Plans.FirstOrDefault();

        _isLoading = false;
        StateHasChanged();
    }

    private async Task PreviousWeek()
    {
        _currentWeekStart = _currentWeekStart.AddDays(-7);
        await LoadWeekView();
    }

    private async Task NextWeek()
    {
        _currentWeekStart = _currentWeekStart.AddDays(7);
        await LoadWeekView();
    }

    private async Task LoadWeekView()
    {
        _weekView = await MealPlanApi.GetWeekViewAsync(_currentWeekStart);
        StateHasChanged();
    }

    private void NavigateToCalendarView() => Navigation.NavigateTo("/meal-planning/calendar");

    private Task OnDropToDay(string date) => OnDrop(date, "Dinner");

    // ── Drag-and-drop ──────────────────────────────────────────────────────────

    private void OnDragStart(MealPlanEntryDto meal) { _draggingMeal = meal; }
    private void OnDragEnter(string date) { _dragOverDate = date; }
    private void OnDragLeave() { _dragOverDate = null; }

    private async Task OnDrop(string targetDate, string mealType)
    {
        if (_draggingMeal is null) { return; }
        await MealPlanApi.MoveMealAsync(_draggingMeal.Id, DateOnly.Parse(targetDate), mealType);
        _draggingMeal = null;
        _dragOverDate = null;
        await LoadWeekView();
    }

    // ── Modal ──────────────────────────────────────────────────────────────────

    private void ShowAddMealModal(DateTime date)
    {
        _selectedDate = date;
        _newMealEntry = new AddMealPlanEntryRequest
        {
            MealPlanId = _currentActivePlan?.Id ?? Guid.Empty,
            Date = date,
            MealType = "Dinner",
            Servings = 4
        };
        _recipeSearchResults = null;
        _addMealError = string.Empty;
        _showAddMealModal = true;
    }

    private void CloseAddMealModal()
    {
        _showAddMealModal = false;
    }

    private async Task SearchRecipes()
    {
        if (string.IsNullOrWhiteSpace(_recipeSearchTerm))
            return;

        RecipeSearchRequest request = new()
        {
            SearchTerm = _recipeSearchTerm,
            Page = 1,
            PageSize = 10
        };

        RecipeSearchResult? result = await RecipeApi.SearchRecipesAsync(request);
        _recipeSearchResults = result?.Recipes ?? new();
        StateHasChanged();
    }

    private void SelectRecipe(RecipeDto recipe)
    {
        _newMealEntry.RecipeId = recipe.Id;
        _newMealEntry.CustomMealName = null;
        _recipeSearchResults = null;
        _recipeSearchTerm = string.Empty;
    }

    private async Task SaveMeal()
    {
        _addMealError = string.Empty;

        if (_currentActivePlan == null)
        {
            _addMealError = "Please create a meal plan first.";
            return;
        }

        if (!_newMealEntry.RecipeId.HasValue && string.IsNullOrWhiteSpace(_newMealEntry.CustomMealName))
        {
            _addMealError = "Please select a recipe or enter a custom meal name.";
            return;
        }

        _newMealEntry.MealPlanId = _currentActivePlan.Id;

        Guid? entryId = await MealPlanApi.AddMealEntryAsync(_newMealEntry);

        if (entryId.HasValue)
        {
            CloseAddMealModal();
            await LoadMealPlanning();
        }
        else
        {
            _addMealError = "Failed to add meal. Please try again.";
        }
    }

