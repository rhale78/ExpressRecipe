@page "/dashboard"
@rendermode InteractiveServer
@using ExpressRecipe.Client.Shared.Models.User
@using ExpressRecipe.Client.Shared.Models.Inventory
@using ExpressRecipe.Client.Shared.Models.Shopping
@using ExpressRecipe.Client.Shared.Models.MealPlanning
@using ExpressRecipe.Client.Shared.Models.Recipe
@using ExpressRecipe.Client.Shared.Services
@using Microsoft.AspNetCore.Components.Authorization
@using ExpressRecipe.BlazorWeb.Components.Pages.Allergy
@inject IUserProfileApiClient UserProfileApi
@inject IInventoryApiClient InventoryApi
@inject IShoppingListApiClient ShoppingApi
@inject IMealPlanApiClient MealPlanApi
@inject IRecipeApiClient RecipeApi
@inject IAllergyApiClient AllergyApi
@inject IWorkQueueState QueueState
@inject IWorkQueueClientService WorkQueueApi
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Dashboard - ExpressRecipe</PageTitle>

<div class="dashboard-container">
    @if (_isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Loading your dashboard...</p>
        </div>
    }
    else
    {
        <!-- Welcome Section -->
        <div class="welcome-section">
            <h1>👋 Welcome back, @_userName!</h1>
            <p class="welcome-subtitle">Here's what's happening with your meals and dietary management.</p>
        </div>

        <!-- Quick Stats Cards -->
        <div class="stats-grid">
            <div class="stat-card" @onclick='() => Navigation.NavigateTo("/inventory")'>
                <div class="stat-icon">🥫</div>
                <div class="stat-content">
                    <div class="stat-value">@(_inventorySummary?.TotalItems ?? 0)</div>
                    <div class="stat-label">Inventory Items</div>
                </div>
            </div>

            <div class="stat-card warning" @onclick='() => Navigation.NavigateTo("/inventory")'>
                <div class="stat-icon">⏰</div>
                <div class="stat-content">
                    <div class="stat-value">@(_inventorySummary?.ExpiringSoonItems ?? 0)</div>
                    <div class="stat-label">Expiring Soon</div>
                </div>
            </div>

            <div class="stat-card" @onclick='() => Navigation.NavigateTo("/meal-planning")'>
                <div class="stat-icon">🍽️</div>
                <div class="stat-content">
                    <div class="stat-value">@(_mealPlanSummary?.MealsThisWeek ?? 0)</div>
                    <div class="stat-label">Meals This Week</div>
                </div>
            </div>

            <div class="stat-card" @onclick='() => Navigation.NavigateTo("/shopping")'>
                <div class="stat-icon">🛒</div>
                <div class="stat-content">
                    <div class="stat-value">@(_shoppingSummary?.TotalActiveItems ?? 0)</div>
                    <div class="stat-label">Shopping Items</div>
                </div>
            </div>
        </div>

        <!-- Quick Feature Access -->
        <div class="quick-access-grid">
            <a href="/pantry-discovery" class="quick-access-card">
                <span>🔎</span>
                <span>What Can I Make?</span>
            </a>
            <a href="/allergy" class="quick-access-card">
                <span>🩺</span>
                <span>Log a Reaction</span>
            </a>
            <a href="/meal-planning" class="quick-access-card">
                <span>⏱️</span>
                <span>Cooking Timers</span>
            </a>
            <a href="/queue" class="quick-access-card">
                <span>📋</span>
                <span>My Work Queue</span>
            </a>
        </div>

        <!-- Allergen Discovery Alert -->
        @if (_allergenDiscoveries?.Any() == true)
        {
            <div class="dashboard-discovery-alert">
                <span class="discovery-alert-icon">🔬</span>
                <div class="discovery-alert-body">
                    <strong>@_allergenDiscoveries.Count new allergen @(_allergenDiscoveries.Count == 1 ? "discovery" : "discoveries")</strong>
                    <p>Potential allergens were found when items were disposed from inventory.</p>
                </div>
                <a href="/inventory" class="btn btn-warning btn-sm">Review →</a>
            </div>
        }

        <!-- Family Allergen Summary -->
        @if (_userProfile != null && (_userProfile.Allergens.Any() || _userProfile.FamilyMembers.Any()))
        {
            <div class="allergen-summary-card">
                <h2>🛡️ Family Safety Summary</h2>
                <div class="allergen-summary-content">
                    <!-- User Allergens -->
                    @if (_userProfile.Allergens.Any())
                    {
                        <div class="allergen-section">
                            <h3>Your Allergens</h3>
                            <div class="allergen-tags">
                                @foreach (var allergen in _userProfile.Allergens)
                                {
                                    <span class="allergen-tag">⚠️ @allergen</span>
                                }
                            </div>
                        </div>
                    }

                    <!-- Family Member Allergens -->
                    @if (_userProfile.FamilyMembers.Any(fm => fm.Allergens.Any()))
                    {
                        <div class="allergen-section">
                            <h3>Family Member Allergens</h3>
                            @foreach (var member in _userProfile.FamilyMembers.Where(fm => fm.Allergens.Any()))
                            {
                                <div class="family-member-allergens">
                                    <strong>@member.Name (@member.Relationship):</strong>
                                    @foreach (var allergen in member.Allergens)
                                    {
                                        <span class="allergen-tag-sm">⚠️ @allergen</span>
                                    }
                                </div>
                            }
                        </div>
                    }

                    <div class="allergen-summary-footer">
                        <span>All recipes and meal plans are filtered for family safety</span>
                        <button class="btn-link" @onclick='() => Navigation.NavigateTo("/settings")'>
                            Manage →
                        </button>
                    </div>
                </div>
            </div>
        }

        <!-- Suspected Allergen Alert -->
        @if (_allergenSuspects?.Any() == true)
        {
            <div class="dashboard-suspect-alert">
                <button class="suspect-alert-dismiss" @onclick="DismissAllergenAlert" title="Dismiss">✕</button>
                <AllergyDisclaimer />
                <div class="suspect-alert-header">
                    <span>⚠️</span>
                    <strong>@_allergenSuspects.Count potential allergen@(_allergenSuspects.Count != 1 ? "s" : "") detected</strong>
                </div>
                <p>Based on your logged reactions, these ingredients may be causing issues:</p>
                <div class="suspect-chips">
                    @foreach (SuspectedAllergenSummaryDto suspect in _allergenSuspects)
                    {
                        <div class="suspect-chip">
                            <span>@suspect.IngredientName</span>
                            <span class="suspect-confidence">@((suspect.ConfidenceScore * 100).ToString("F0"))% confidence</span>
                        </div>
                    }
                </div>
                <a href="/allergy" class="btn btn-warning btn-sm">Review →</a>
            </div>
        }

        <!-- Work Queue Widget -->
        @if (QueueState.PendingCount > 0)
        {
            <div class="dashboard-queue-widget @(QueueState.HasCritical ? "queue-critical" : "")">
                <div class="queue-widget-header">
                    <span class="queue-widget-icon">📋</span>
                    <h3>Work Queue</h3>
                    <span class="queue-count-badge">@QueueState.PendingCount item@(QueueState.PendingCount != 1 ? "s" : "") need attention</span>
                </div>

                @if (_queuePreview?.Any() == true)
                {
                    <div class="queue-preview-list">
                        @foreach (WorkQueueItemDto item in _queuePreview.Take(3))
                        {
                            <div class="queue-preview-item priority-@GetQueueItemPriorityClass(item.Priority)">
                                <span class="queue-item-icon">@GetQueueItemIcon(item.ItemType)</span>
                                <span class="queue-item-title">@item.Title</span>
                                <span class="queue-item-age">@GetRelativeTime(item.CreatedAt)</span>
                            </div>
                        }
                    </div>
                }

                <a href="/queue" class="btn btn-primary btn-sm queue-action-link">
                    View All →
                </a>
            </div>
        }

        <!-- Household Tasks Widget -->
        @if (_householdTasks?.Any() == true)
        {
            <div class="dashboard-tasks-widget">
                <div class="tasks-widget-header">
                    <span>🧊</span>
                    <h3>Household Reminders</h3>
                    <span class="task-count">@_householdTasks.Count pending</span>
                </div>
                <div class="task-list">
                    @foreach (HouseholdTaskDto task in _householdTasks.Take(4))
                    {
                        <div class="task-item task-@GetTaskTypeCssClass(task.TaskType)">
                            <div class="task-title">@task.Title</div>
                            <div class="task-due">Due: @task.DueAt.ToString("MMM dd h:mmtt")</div>
                            <div class="task-actions">
                                <button class="btn btn-success btn-xs" @onclick='() => CompleteTask(task, "Moved")'>
                                    ✓ Done
                                </button>
                                <button class="btn btn-outline btn-xs" @onclick='() => CompleteTask(task, "Ignored")'>
                                    Dismiss
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Main Content Grid -->
        <div class="dashboard-grid">
            <!-- Left Column -->
            <div class="dashboard-column">
                <!-- Upcoming Meals Widget -->
                <div class="widget">
                    <div class="widget-header">
                        <h3>📅 Upcoming Meals</h3>
                        <button class="btn-sm btn-secondary" @onclick='() => Navigation.NavigateTo("/meal-planning")'>
                            View All →
                        </button>
                    </div>

                    <div class="widget-content">
                        @if (_upcomingMeals?.Any() == true)
                        {
                            @foreach (var meal in _upcomingMeals.Take(5))
                            {
                                <div class="meal-item">
                                    <div class="meal-date">
                                        <span class="date-day">@meal.Date.ToString("ddd")</span>
                                        <span class="date-num">@meal.Date.Day</span>
                                    </div>
                                    <div class="meal-details">
                                        <div class="meal-type-icon">@GetMealTypeIcon(meal.MealType)</div>
                                        <div class="meal-info">
                                            <strong>@(meal.RecipeName ?? meal.CustomMealName)</strong>
                                            <span class="meal-meta">@meal.MealType • @meal.Servings servings</span>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="widget-empty">
                                <p>No meals planned yet</p>
                                <button class="btn btn-primary-sm" @onclick='() => Navigation.NavigateTo("/meal-planning")'>
                                    Plan Meals
                                </button>
                            </div>
                        }
                    </div>
                </div>

                <!-- Expiring Soon Widget -->
                <div class="widget">
                    <div class="widget-header">
                        <h3>⏰ Expiring Soon</h3>
                        <button class="btn-sm btn-secondary" @onclick='() => Navigation.NavigateTo("/inventory")'>
                            View All →
                        </button>
                    </div>

                    <div class="widget-content">
                        @if (_expiringItems?.Any() == true)
                        {
                            @foreach (var item in _expiringItems.Take(5))
                            {
                                <div class="expiring-item">
                                    <div class="item-icon">
                                        @if (item.IsExpired)
                                        {
                                            <span class="expired-badge">❌</span>
                                        }
                                        else
                                        {
                                            <span class="expiring-badge">⚠️</span>
                                        }
                                    </div>
                                    <div class="item-details">
                                        <strong>@item.Name</strong>
                                        <span class="item-expiry">
                                            @if (item.IsExpired)
                                            {
                                                <span class="expired-text">Expired @item.ExpirationDate?.ToString("MMM dd")</span>
                                            }
                                            else
                                            {
                                                <span class="expiring-text">Expires @item.ExpirationDate?.ToString("MMM dd")</span>
                                            }
                                        </span>
                                    </div>
                                    <div class="item-location">@GetLocationIcon(item.Location)</div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="widget-empty">
                                <p>✓ No items expiring soon</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Right Column -->
            <div class="dashboard-column">
                <!-- Active Shopping Lists Widget -->
                <div class="widget">
                    <div class="widget-header">
                        <h3>🛒 Shopping Lists</h3>
                        <button class="btn-sm btn-secondary" @onclick='() => Navigation.NavigateTo("/shopping")'>
                            View All →
                        </button>
                    </div>

                    <div class="widget-content">
                        @if (_activeShoppingLists?.Any() == true)
                        {
                            @foreach (var list in _activeShoppingLists.Take(3))
                            {
                                <div class="shopping-list-item" @onclick='() => Navigation.NavigateTo($"/shopping/{list.Id}")'>
                                    <div class="list-info">
                                        <strong>@list.Name</strong>
                                        <div class="list-progress-small">
                                            <div class="progress-bar-small">
                                                <div class="progress-fill-small" style="width: @list.CompletionPercentage%"></div>
                                            </div>
                                            <span class="progress-text-small">
                                                @list.CompletedItems/@list.TotalItems items
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="widget-empty">
                                <p>No active shopping lists</p>
                            <button class="btn btn-primary-sm" @onclick='() => Navigation.NavigateTo("/shopping")'>
                                    Create List
                                </button>
                            </div>
                        }
                    </div>
                </div>

                <!-- Quick Actions Widget -->
                <div class="widget quick-actions-widget">
                    <div class="widget-header">
                        <h3>⚡ Quick Actions</h3>
                    </div>

                    <div class="widget-content">
                        <div class="quick-actions-grid">
                            <button class="quick-action-btn" @onclick='() => Navigation.NavigateTo("/products/scan")'>
                                <span class="action-icon">📷</span>
                                <span class="action-label">Scan Product</span>
                            </button>

                            <button class="quick-action-btn" @onclick='() => Navigation.NavigateTo("/recipes")'>
                                <span class="action-icon">🍳</span>
                                <span class="action-label">Find Recipe</span>
                            </button>

                            <button class="quick-action-btn" @onclick='() => Navigation.NavigateTo("/inventory/add")'>
                                <span class="action-icon">➕</span>
                                <span class="action-label">Add to Inventory</span>
                            </button>

                            <button class="quick-action-btn" @onclick='() => Navigation.NavigateTo("/meal-planning")'>
                                <span class="action-icon">📅</span>
                                <span class="action-label">Plan Meals</span>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Recipe Suggestions Widget -->
                <div class="widget">
                    <div class="widget-header">
                        <h3>💡 Recipe Suggestions</h3>
                        <button class="btn-sm btn-secondary" @onclick='() => Navigation.NavigateTo("/recipes")'>
                            Browse All →
                        </button>
                    </div>

                    <div class="widget-content">
                        @if (_suggestedRecipes?.Any() == true)
                        {
                            @foreach (var recipe in _suggestedRecipes.Take(3))
                            {
                                <div class="recipe-suggestion-item" @onclick='() => Navigation.NavigateTo($"/recipes/{recipe.Id}")'>
                                    @if (!string.IsNullOrWhiteSpace(recipe.ImageUrl))
                                    {
                                        <img src="@recipe.ImageUrl" alt="@recipe.Title" class="recipe-thumb" />
                                    }
                                    else
                                    {
                                        <div class="recipe-thumb placeholder">🍳</div>
                                    }
                                    <div class="recipe-suggestion-info">
                                        <strong>@recipe.Title</strong>
                                        <span class="recipe-meta">⏱️ @recipe.TotalTimeMinutes min</span>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="widget-empty">
                                <p>Browse recipes safe for your family</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _isLoading = true;
    private string _userName = "there";
    private UserProfileDto? _userProfile;
    private InventorySummaryDto? _inventorySummary;
    private ShoppingSummaryDto? _shoppingSummary;
    private MealPlanSummaryDto? _mealPlanSummary;

    private List<MealPlanEntryDto>? _upcomingMeals;
    private List<InventoryItemDto>? _expiringItems;
    private List<ShoppingListDto>? _activeShoppingLists;
    private List<RecipeDto>? _suggestedRecipes;
    private List<SuspectedAllergenSummaryDto>? _allergenSuspects;
    private List<WorkQueueItemDto>? _queuePreview;
    private List<HouseholdTaskDto>? _householdTasks;
    private List<AllergenDiscoveryDto>? _allergenDiscoveries;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadDashboard();
        }
    }

    private async Task LoadDashboard()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            // First, try to get name from auth state (fastest and always available)
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var firstName = authState.User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value;
            if (!string.IsNullOrEmpty(firstName))
            {
                _userName = firstName;
            }

            // Try to load user profile to get additional details
            try
            {
                _userProfile = await UserProfileApi.GetProfileAsync();
                if (_userProfile != null && !string.IsNullOrEmpty(_userProfile.FirstName))
                {
                    _userName = _userProfile.FirstName;
                }
            }
            catch (ApiException ex) when (ex.Message.Contains("not found"))
            {
                // User profile doesn't exist yet (newly registered user) - this is okay
                Console.WriteLine("User profile not found - new user");
                _userProfile = null;
            }

            // Load all data in parallel for performance, with graceful error handling
            try
            {
                _inventorySummary = await InventoryApi.GetInventorySummaryAsync();
            }
            catch
            {
                _inventorySummary = null;
            }

            try
            {
                _shoppingSummary = await ShoppingApi.GetShoppingSummaryAsync();
            }
            catch
            {
                _shoppingSummary = null;
            }

            try
            {
                _mealPlanSummary = await MealPlanApi.GetMealPlanSummaryAsync();
            }
            catch
            {
                _mealPlanSummary = null;
            }

            // Load upcoming meals
            try
            {
                var weekView = await MealPlanApi.GetWeekViewAsync(DateTime.Today);
                if (weekView != null)
                {
                    _upcomingMeals = weekView.Days
                        .Where(d => d.Date >= DateTime.Today)
                        .SelectMany(d => d.Meals)
                        .Where(m => !m.IsPrepared)
                        .OrderBy(m => m.Date)
                        .ToList();
                }
            }
            catch
            {
                _upcomingMeals = null;
            }

            // Load expiring items
            try
            {
                var inventoryResult = await InventoryApi.SearchInventoryAsync(new InventorySearchRequest
                {
                    IsExpiringSoon = true,
                    Page = 1,
                    PageSize = 10,
                    SortBy = "ExpirationDate",
                    SortDescending = false
                });
                _expiringItems = inventoryResult?.Items ?? new();
            }
            catch
            {
                _expiringItems = null;
            }

            // Load active shopping lists
            try
            {
                var shoppingResult = await ShoppingApi.SearchShoppingListsAsync(new ShoppingListSearchRequest
                {
                    Status = "Active",
                    Page = 1,
                    PageSize = 5
                });
                _activeShoppingLists = shoppingResult?.Lists ?? new();
            }
            catch
            {
                _activeShoppingLists = null;
            }

            // Load recipe suggestions (filtered by user allergens)
            if (_userProfile != null)
            {
                try
                {
                    var allergensDto = await UserProfileApi.GetAllergensAndRestrictionsAsync();
                    var recipeResult = await RecipeApi.SearchRecipesAsync(new RecipeSearchRequest
                    {
                        ExcludeAllergens = allergensDto?.AllAllergens,
                        ExcludeIngredients = allergensDto?.AllDislikedFoods,
                        Page = 1,
                        PageSize = 10,
                        SortBy = "ViewCount"
                    });
                    _suggestedRecipes = recipeResult?.Recipes ?? new();
                }
                catch
                {
                    _suggestedRecipes = null;
                }
            }

            // Load suspected allergens
            try
            {
                _allergenSuspects = await AllergyApi.GetSuspectedAllergensAsync();
            }
            catch
            {
                _allergenSuspects = null;
            }

            // Load work queue preview
            try
            {
                _queuePreview = await WorkQueueApi.GetItemsAsync();
            }
            catch
            {
                _queuePreview = null;
            }

            // Load household tasks
            try
            {
                _householdTasks = await MealPlanApi.GetActiveTasksAsync();
            }
            catch
            {
                _householdTasks = null;
            }

            // Load allergen discoveries
            try
            {
                _allergenDiscoveries = await InventoryApi.GetAllergenDiscoveriesAsync();
            }
            catch
            {
                _allergenDiscoveries = null;
            }

            _isLoading = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            // Handle any unexpected errors
            Console.WriteLine($"Error loading dashboard: {ex.Message}");
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void DismissAllergenAlert() { _allergenSuspects = null; }

    private string GetMealTypeIcon(string mealType)
    {
        return mealType switch
        {
            "Breakfast" => "🍳",
            "Lunch" => "🥗",
            "Dinner" => "🍽️",
            "Snack" => "🍿",
            _ => "🍴"
        };
    }

    private string GetLocationIcon(string location)
    {
        return location.ToLower() switch
        {
            "pantry" => "🏺",
            "fridge" => "❄️",
            "freezer" => "🧊",
            _ => "📦"
        };
    }

    private static string GetTaskTypeCssClass(string taskType) => taskType switch
    {
        "ThawReminder"    => "thawreminder",
        "CookingReminder" => "cookingreminder",
        "LowStock"        => "lowstock",
        "Expiring"        => "expiring",
        _                 => "general"
    };

    private static string GetQueueItemPriorityClass(int priority) => priority switch
    {
        <= 2 => "expired",
        <= 4 => "high",
        _    => "normal"
    };

    private static string GetQueueItemIcon(string itemType) => itemType switch
    {
        "ExpirationAlert" => "⏰",
        "AllergenSuspect" => "⚠️",
        "ThawReminder"    => "🧊",
        "CookingRating"   => "⭐",
        "LowStock"        => "📉",
        "PriceAlert"      => "💰",
        _                 => "📋"
    };

    private static string GetRelativeTime(DateTime dt)
    {
        TimeSpan diff = DateTime.UtcNow - dt;
        if (diff.TotalMinutes < 60) { return $"{(int)diff.TotalMinutes}m ago"; }
        if (diff.TotalHours < 24)   { return $"{(int)diff.TotalHours}h ago"; }
        return $"{(int)diff.TotalDays}d ago";
    }

    private async Task CompleteTask(HouseholdTaskDto task, string action)
    {
        bool ok = await MealPlanApi.ActionTaskAsync(task.Id, action);
        if (ok)
        {
            _householdTasks?.Remove(task);
            StateHasChanged();
        }
    }
}
