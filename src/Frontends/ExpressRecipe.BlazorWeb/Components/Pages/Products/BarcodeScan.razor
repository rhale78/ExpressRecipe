@page "/products/scan"
@rendermode InteractiveServer
@inject NavigationManager Navigation

@code {
    [SupplyParameterFromQuery]
    private string? Mode { get; set; }

    protected override void OnInitialized()
    {
        string query = string.IsNullOrWhiteSpace(Mode) ? string.Empty : $"?Mode={Uri.EscapeDataString(Mode)}";
        Navigation.NavigateTo($"/scanner{query}", replace: true);
    }
}
