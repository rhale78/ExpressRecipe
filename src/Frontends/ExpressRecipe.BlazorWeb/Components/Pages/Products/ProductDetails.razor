@page "/products/{ProductId:guid}"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using ExpressRecipe.Client.Shared.Services
@using ExpressRecipe.Client.Shared.Models.Product
@using ExpressRecipe.Client.Shared.Models.Inventory
@using ExpressRecipe.Client.Shared.Models.Shopping
@using ExpressRecipe.BlazorWeb.Components.Pages.Allergy
@inject IProductApiClient ProductApi
@inject IInventoryApiClient InventoryApi
@inject IShoppingListApiClient ShoppingApi
@inject IToastService ToastService
@inject ILogger<ProductDetails> Logger
@inject NavigationManager Navigation

<PageTitle>@(_product?.Name ?? "Product Details") - ExpressRecipe</PageTitle>

<AuthorizeView>
    <Authorized>
<div class="product-details-container">
    <!-- Back Button -->
    <div class="navigation-bar">
        <button class="btn btn-outline" @onclick='() => Navigation.NavigateTo("/products")'>
            ← Back to Products
        </button>
    </div>

    @if (_isLoading)
    {
        <div class="loading-container">
            <div class="spinner"></div>
            <p>Loading product details...</p>
        </div>
    }
    else if (_product != null)
    {
        <div class="product-details-grid">
            <!-- Product Image Section -->
            <div class="product-image-section">
                @if (!string.IsNullOrEmpty(_product.ImageUrl))
                {
                    <img src="@_product.ImageUrl" alt="@_product.Name" class="product-detail-image" />
                }
                else
                {
                    <div class="product-detail-image-placeholder">
                        <div class="placeholder-icon">📦</div>
                        <p>No image available</p>
                    </div>
                }
            </div>

            <!-- Product Information Section -->
            <div class="product-info-section">
                <h1 class="product-title">@_product.Name</h1>
                <p class="product-brand-large">@_product.Brand</p>

                @if (!string.IsNullOrEmpty(_product.UPC))
                {
                    <div class="info-row">
                        <span class="info-label">UPC:</span>
                        <span class="info-value">@_product.UPC</span>
                    </div>
                }

                @if (!string.IsNullOrEmpty(_product.Description))
                {
                    <div class="product-description">
                        <h3>Description</h3>
                        <p>@_product.Description</p>
                    </div>
                }

                <!-- Allergen Information -->
                @if (_product.Allergens.Any())
                {
                    <div class="allergen-section">
                        <h3>⚠️ Allergen Information</h3>
                        <div class="allergen-tags-large">
                            @foreach (var allergen in _product.Allergens)
                            {
                                <span class="allergen-tag-large">@allergen</span>
                            }
                        </div>
                        <p class="allergen-warning">
                            This product contains or may contain the allergens listed above.
                            Please review carefully if you have dietary restrictions.
                        </p>
                    </div>
                }
                else
                {
                    <div class="allergen-section">
                        <h3>✅ Allergen Information</h3>
                        <p class="no-allergens">No major allergens detected in this product.</p>
                    </div>
                }

                <!-- Ingredients -->
                @if (_product.Ingredients.Any())
                {
                    <div class="ingredients-section">
                        <h3>Ingredients</h3>
                        <div class="ingredients-list">
                            @foreach (var ingredient in _product.Ingredients)
                            {
                                <span class="ingredient-item">@ingredient.IngredientName</span>
                            }
                        </div>
                    </div>
                }

                <!-- Action Buttons -->
                <div class="product-actions-section">
                    <button class="btn btn-primary" @onclick="AddToInventory">
                        📦 Add to Inventory
                    </button>
                    <button class="btn btn-outline" @onclick="AddToShoppingList">
                        🛒 Add to Shopping List
                    </button>
                    <button class="btn btn-outline" @onclick="ViewRecipes">
                        🍳 Find Recipes
                    </button>
                </div>

                <!-- Reaction Reporting -->
                <div class="reaction-report-section">
                    <AllergyDisclaimer />
                    <button class="btn btn-warning" @onclick="OpenReactionModal">
                        ⚠️ I Had a Reaction to This Product
                    </button>
                </div>

                <!-- Product Metadata -->
                <div class="product-metadata">
                    <p class="metadata-item">
                        <span class="metadata-label">Added:</span>
                        <span class="metadata-value">@_product.CreatedAt.ToString("MMMM dd, yyyy")</span>
                    </p>
                    <p class="metadata-item">
                        <span class="metadata-label">Product ID:</span>
                        <span class="metadata-value">@_product.Id.ToString("N").Substring(0, 8)...</span>
                    </p>
                </div>
            </div>
        </div>

        <!-- Price History Chart -->
        <PriceHistoryChart ProductId="ProductId" DaysBack="90" ShowAllStores="true" ShowUnitPrice="false" />

        <!-- Related Products Section -->
        <div class="related-products-section">
            <h2>Similar Products from @_product.Brand</h2>
            @if (_relatedProducts.Any())
            {
                <div class="related-products-grid">
                    @foreach (var related in _relatedProducts.Take(4))
                    {
                        <div class="related-product-card" @onclick="() => ViewProduct(related.Id)">
                            <div class="related-product-image">
                                @if (!string.IsNullOrEmpty(related.ImageUrl))
                                {
                                    <img src="@related.ImageUrl" alt="@related.Name" />
                                }
                                else
                                {
                                    <div class="related-image-placeholder">📦</div>
                                }
                            </div>
                            <h4>@related.Name</h4>
                            <p>@related.Brand</p>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="no-related">No related products found.</p>
            }
        </div>
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="error-container">
            <div class="error-icon">❌</div>
            <h2>Product Not Found</h2>
            <p>@_errorMessage</p>
            <button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("/products")'>
                Browse All Products
            </button>
        </div>
    }
</div>

<LogReactionModal @ref="_reactionModal" OnIncidentLogged="HandleReactionSaved" />
    </Authorized>
    <NotAuthorized>
        <div class="unauthorized-container">
            <h2>Authentication Required</h2>
            <p>Please <a href="/login">log in</a> to access this page.</p>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter]
    public Guid ProductId { get; set; }

    private ProductDto? _product;
    private List<ProductDto> _relatedProducts = new();
    private bool _isLoading = true;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadProductAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_product?.Id != ProductId)
        {
            await LoadProductAsync();
        }
    }

    private async Task LoadProductAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            _product = await ProductApi.GetProductAsync(ProductId);

            if (_product == null)
            {
                _errorMessage = "Product not found. It may have been removed or the ID is invalid.";
                return;
            }

            // Load related products from the same brand
            await LoadRelatedProductsAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load product: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadRelatedProductsAsync()
    {
        if (_product == null) return;

        try
        {
            var searchResult = await ProductApi.SearchProductsAsync(new ProductSearchRequest
            {
                Brand = _product.Brand,
                Page = 1,
                PageSize = 5
            });

            if (searchResult != null)
            {
                // Exclude the current product from related products
                _relatedProducts = searchResult.Products
                    .Where(p => p.Id != _product.Id)
                    .ToList();
            }
        }
        catch
        {
            // Silently fail for related products - not critical
            _relatedProducts = new();
        }
    }

    private void ViewProduct(Guid productId)
    {
        Navigation.NavigateTo($"/products/{productId}");
    }

    private async Task AddToInventory()
    {
        if (_product == null) return;
        try
        {
            var itemId = await InventoryApi.CreateInventoryItemAsync(new CreateInventoryItemRequest
            {
                ProductId = _product.Id,
                Name = _product.Name,
                Brand = _product.Brand,
                Quantity = 1
            });
            if (itemId.HasValue)
                ToastService.ShowSuccess("Added to inventory");
            else
                ToastService.ShowError("Failed to add to inventory");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Failed to add to inventory: {ex.Message}");
        }
    }

    private async Task AddToShoppingList()
    {
        if (_product == null) return;
        try
        {
            // Find or create the user's default active shopping list
            var listId = await GetOrCreateDefaultShoppingListAsync();
            if (listId == null)
            {
                ToastService.ShowError("Could not find or create a shopping list");
                return;
            }

            var itemId = await ShoppingApi.AddItemAsync(new AddShoppingListItemRequest
            {
                ShoppingListId = listId.Value,
                ProductId = _product.Id,
                Name = _product.Name,
                Brand = _product.Brand,
                Quantity = 1,
                Unit = "unit"
            });
            if (itemId.HasValue)
                ToastService.ShowSuccess("Added to shopping list");
            else
                ToastService.ShowError("Failed to add to shopping list");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Failed to add to shopping list: {ex.Message}");
        }
    }

    private async Task<Guid?> GetOrCreateDefaultShoppingListAsync()
    {
        try
        {
            var result = await ShoppingApi.SearchShoppingListsAsync(new ShoppingListSearchRequest { Status = "Active", PageSize = 1 });
            if (result?.Lists?.Count > 0)
                return result.Lists[0].Id;

            return await ShoppingApi.CreateShoppingListAsync(new CreateShoppingListRequest { Name = "My Shopping List" });
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to get or create default shopping list");
            return null;
        }
    }

    private void ViewRecipes()
    {
        // TODO: Implement recipe search by product
        // For now, navigate to recipes page
        Navigation.NavigateTo("/recipes");
    }

    private LogReactionModal? _reactionModal;

    private async Task OpenReactionModal()
    {
        if (_product != null && _reactionModal != null)
            await _reactionModal.ShowAsync(_product.Id, _product.Name);
    }

    private async Task HandleReactionSaved()
    {
        ToastService.ShowSuccess("Reaction logged. Run differential analysis from Allergy Log to update suspect list.");
        await Task.CompletedTask;
    }
}
