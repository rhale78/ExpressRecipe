@page "/shopping/{id:guid}"
@rendermode InteractiveServer
@using ExpressRecipe.Client.Shared.Models.Shopping
@using ExpressRecipe.Client.Shared.Models.Product
@using ExpressRecipe.Client.Shared.Models.Recipe
@using ExpressRecipe.Client.Shared.Models.Price
@using ExpressRecipe.Client.Shared.Services
@inject IShoppingListApiClient ShoppingApi
@inject IProductApiClient ProductApi
@inject IRecipeApiClient RecipeApi
@inject IPriceApiClient PriceApi
@inject IToastService ToastService
@inject ILogger<ShoppingListDetails> Logger
@inject NavigationManager Navigation

<PageTitle>@(_list?.Name ?? "Shopping List") - ExpressRecipe</PageTitle>

<div class="shopping-detail-container">
    @if (_isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Loading shopping list...</p>
        </div>
    }
    else if (_list == null)
    {
        <div class="error-state">
            <div class="error-icon">⚠️</div>
            <h3>List Not Found</h3>
            <p>The shopping list you're looking for doesn't exist or has been deleted.</p>
            <button class="btn btn-primary" @onclick="NavigateBack">Back to Lists</button>
        </div>
    }
    else
    {
        <!-- Header -->
        <div class="detail-header">
            <button class="back-button" @onclick="NavigateBack">← Back</button>
            <div class="header-title">
                <h1>@_list.Name</h1>
                <div class="list-status-badge @_list.Status.ToLower()">@_list.Status</div>
            </div>
            <div class="header-actions">
                <button class="btn btn-secondary" @onclick="ToggleShopMode">
                    @(_isShopModeActive ? "✓ Exit Shop Mode" : "🛒 Shop Mode")
                </button>
                <button class="btn btn-secondary" @onclick="ToggleEditMode">
                    @(_isEditMode ? "Done Editing" : "Edit List")
                </button>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_list.Description))
        {
            <p class="list-description-detail">@_list.Description</p>
        }

        <!-- Store Assignment Bar -->
        <div class="list-store-bar">
            <span class="store-label">🏪 Store:</span>
            @if (_assignedStore != null)
            {
                <span class="assigned-store-name">@_assignedStore.Name</span>
                <button class="btn-link" @onclick="ClearStoreAssignment">Change</button>
            }
            else
            {
                <button class="btn btn-outline btn-sm" @onclick="ShowStorePicker">
                    Assign a Store
                </button>
            }
        </div>

        @if (_isShopModeActive)
        {
            <div class="shop-mode-banner">
                <div class="shop-mode-info">
                    <span>🛒</span>
                    <strong>Shopping Mode Active</strong>
                    @if (_activeScanSession != null)
                    {
                        <span>@_activeScanSession.ItemsScanned items scanned</span>
                    }
                </div>
                <div class="shop-mode-controls">
                    <input type="text" class="scan-barcode-input" placeholder="Scan barcode..."
                           @bind="_shopBarcode" @bind:event="oninput"
                           @onkeydown="HandleShopBarcode" />
                    @if (_activeScanSession != null)
                    {
                        <button class="btn btn-success btn-sm" @onclick="FinishShopping">
                            ✓ Finish & Add to Inventory
                        </button>
                    }
                </div>
                @if (_lastShopScan != null)
                {
                    <div class="scan-last-result @(_lastShopScan.Success ? "scan-success" : "scan-error")">
                        @(_lastShopScan.Success ? "✓" : "✗") @_lastShopScan.Message
                    </div>
                }
            </div>
        }

        <!-- Progress Section -->
        <div class="progress-section-large">
            <div class="progress-stats">
                <div class="stat">
                    <span class="stat-value">@_list.CompletedItems</span>
                    <span class="stat-label">Completed</span>
                </div>
                <div class="stat">
                    <span class="stat-value">@_list.RemainingItems</span>
                    <span class="stat-label">Remaining</span>
                </div>
                <div class="stat">
                    <span class="stat-value">@_list.TotalItems</span>
                    <span class="stat-label">Total</span>
                </div>
            </div>
            <div class="progress-bar-container large">
                <div class="progress-bar" style="width: @_list.CompletionPercentage%"></div>
                <span class="progress-percentage">@_list.CompletionPercentage.ToString("0")%</span>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="quick-actions">
            <button class="btn btn-primary" @onclick="ShowAddItemModal">
                <span class="btn-icon">➕</span> Add Item
            </button>
            <button class="btn btn-secondary" @onclick="ShowAddFromRecipeModal">
                <span class="btn-icon">🍳</span> Add from Recipe
            </button>
            <button class="btn btn-secondary" @onclick="AddLowStockItems">
                <span class="btn-icon">📉</span> Add Low Stock Items
            </button>
        </div>

        <!-- Price Comparison (Plus feature) -->
        <FeatureGuard FeatureKey="price-comparison" RequiredTier="Plus"
                      Title="Price Comparison requires Plus"
                      Description="Compare prices across stores for items on your list and find the best deals. Available on Plus and above.">
            <div class="price-comparison-section">
                <div class="price-comparison-header">
                    <h2>💲 Price Comparison</h2>
                    <button class="btn btn-secondary-outline" @onclick="LoadPriceComparison" disabled="@_isPriceComparisonLoading">
                        @if (_isPriceComparisonLoading)
                        {
                            <span>Loading…</span>
                        }
                        else
                        {
                            <span>🔄 Compare Prices</span>
                        }
                    </button>
                </div>

                @if (_isPriceComparisonLoading)
                {
                    <div class="loading-state">
                        <div class="spinner"></div>
                        <p>Fetching prices…</p>
                    </div>
                }
                else if (_priceComparisonResult != null)
                {
                    @if (!string.IsNullOrWhiteSpace(_priceComparisonResult.BestStore))
                    {
                        <div class="best-store-banner">
                            🏆 Best store for this list: <strong>@_priceComparisonResult.BestStore</strong>
                            — potential savings of <strong>@_priceComparisonResult.PotentialSavings.ToString("C")</strong>
                        </div>
                    }

                    <div class="price-comparison-table-container">
                        <table class="data-table price-table">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    @foreach (var store in _priceComparisonResult.StoreTotals)
                                    {
                                        <th>@store.StoreName</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var product in _priceComparisonResult.Products)
                                {
                                    <tr>
                                        <td>@product.ProductName</td>
                                        @foreach (var store in _priceComparisonResult.StoreTotals)
                                        {
                                            var price = product.PricesByStore.TryGetValue(store.StoreName, out var p) ? p : (decimal?)null;
                                            <td class="@(store.StoreName == product.BestStore ? "price-best" : "")">
                                                @(price.HasValue ? price.Value.ToString("C") : "—")
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="store-total-row">
                                    <td><strong>Total</strong></td>
                                    @foreach (var store in _priceComparisonResult.StoreTotals)
                                    {
                                        <td><strong>@store.TotalPrice.ToString("C")</strong></td>
                                    }
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                }
                else
                {
                    <p class="price-comparison-hint">
                        Click <strong>Compare Prices</strong> to see which store has the best deal for items on your list.
                    </p>
                }
            </div>
        </FeatureGuard>

        <!-- Shopping Items -->
        <div class="items-container">

            <!-- Favorites Panel -->
            <div class="favorites-section">
                <button class="favorites-toggle" @onclick="ToggleFavorites">
                    ⭐ Favourites @(_showFavorites ? "▲" : "▼")
                    @if (_favorites?.Any() == true)
                    {
                        <span class="fav-count">@_favorites.Count</span>
                    }
                </button>

                @if (_showFavorites && _favorites != null)
                {
                    <div class="favorites-grid">
                        @foreach (FavoriteItemDto fav in _favorites)
                        {
                            <div class="fav-chip" @onclick="() => AddFavoriteToList(fav)">
                                <span class="fav-name">@fav.Name</span>
                                <span class="fav-qty">@fav.TypicalQuantity @fav.TypicalUnit</span>
                            </div>
                        }
                    </div>
                }
            </div>

            @if (_list.Items.Any())
            {
                @* Group by category and filter items *@
                var remainingItems = _list.Items.Where(i => !i.IsPurchased).ToList();
                var completedItems = _list.Items.Where(i => i.IsPurchased).ToList();

                <!-- Remaining Items -->
                @if (remainingItems.Any())
                {
                    <h2 class="items-section-title">To Buy (@remainingItems.Count)</h2>

                    @foreach (var category in remainingItems.GroupBy(i => i.Category ?? "Other").OrderBy(g => g.Key))
                    {
                        <div class="category-section">
                            <h3 class="category-title">@category.Key</h3>
                            <div class="items-list">
                                @foreach (var item in category.OrderBy(i => i.OrderIndex))
                                {
                                    <div class="shopping-item @(item.IsPurchased ? "purchased" : "")">
                                        <div class="item-checkbox-container">
                                            <input type="checkbox" class="item-checkbox-input"
                                                   checked="@item.IsPurchased"
                                                   @onchange="@(e => ToggleItemPurchased(item))" />
                                        </div>

                                        <div class="item-details">
                                            <div class="item-main">
                                                <h4 class="item-name">@item.Name</h4>
                                                @if (!string.IsNullOrWhiteSpace(item.Brand))
                                                {
                                                    <span class="item-brand">@item.Brand</span>
                                                }
                                                <span class="item-quantity">@item.Quantity @item.Unit</span>
                                            </div>

                                            @if (item.ProductAllergens.Any())
                                            {
                                                <div class="item-allergens">
                                                    @foreach (var allergen in item.ProductAllergens)
                                                    {
                                                        <span class="allergen-tag-sm">⚠️ @allergen</span>
                                                    }
                                                </div>
                                            }

                                            @if (!string.IsNullOrWhiteSpace(item.Notes))
                                            {
                                                <p class="item-notes-small">💬 @item.Notes</p>
                                            }

                                            @if (!string.IsNullOrWhiteSpace(item.Source))
                                            {
                                                <span class="item-source">From @item.Source</span>
                                            }

                                            @if (_bestPrices.TryGetValue(item.Id, out List<PriceComparisonDto>? prices) && prices.Any())
                                            {
                                                <div class="item-price-row">
                                                    <span class="best-price-label">Best price:</span>
                                                    @foreach (PriceComparisonDto price in prices.Take(3))
                                                    {
                                                        <span class="price-chip">
                                                            @price.StoreName — $@((price.UnitPrice ?? price.Price).ToString("0.00"))/@(price.Unit ?? "ea")
                                                            @if (IsSaleDeal(price.DealType)) { <span class="sale-badge">SALE</span> }
                                                        </span>
                                                    }
                                                </div>
                                            }
                                        </div>

                                        @if (item.Priority == "High")
                                        {
                                            <div class="priority-badge high">High Priority</div>
                                        }

                                        @if (_isEditMode)
                                        {
                                            <div class="item-actions-inline">
                                                <button class="btn-icon-sm" @onclick="() => EditItem(item)" title="Edit">✏️</button>
                                                <button class="btn-icon-sm" @onclick="() => DeleteItem(item.Id)" title="Delete">🗑️</button>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }

                <!-- Completed Items (Collapsible) -->
                @if (completedItems.Any())
                {
                    <div class="completed-section">
                        <button class="completed-header" @onclick="ToggleCompleted">
                            <h2 class="items-section-title">
                                @(_showCompleted ? "▼" : "▶") Completed (@completedItems.Count)
                            </h2>
                        </button>

                        @if (_showCompleted)
                        {
                            <div class="items-list">
                                @foreach (var item in completedItems.OrderByDescending(i => i.PurchasedAt))
                                {
                                    <div class="shopping-item purchased">
                                        <div class="item-checkbox-container">
                                            <input type="checkbox" class="item-checkbox-input"
                                                   checked="@item.IsPurchased"
                                                   @onchange="@(e => ToggleItemPurchased(item))" />
                                        </div>

                                        <div class="item-details">
                                            <div class="item-main">
                                                <h4 class="item-name">@item.Name</h4>
                                                @if (!string.IsNullOrWhiteSpace(item.Brand))
                                                {
                                                    <span class="item-brand">@item.Brand</span>
                                                }
                                                <span class="item-quantity">@item.Quantity @item.Unit</span>
                                            </div>

                                            @if (item.PurchasedAt.HasValue)
                                            {
                                                <span class="purchased-time">✓ @item.PurchasedAt.Value.ToString("MMM dd, h:mm tt")</span>
                                            }
                                        </div>

                                        @if (_isEditMode)
                                        {
                                            <div class="item-actions-inline">
                                                <button class="btn-icon-sm" @onclick="() => DeleteItem(item.Id)" title="Delete">🗑️</button>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <div class="empty-items">
                    <div class="empty-icon">📝</div>
                    <h3>No Items Yet</h3>
                    <p>Add items to your shopping list manually, from a recipe, or from low-stock inventory.</p>
                    <button class="btn btn-primary" @onclick="ShowAddItemModal">
                        <span class="btn-icon">➕</span> Add First Item
                    </button>
                </div>
            }
        </div>
    }
</div>

<!-- Store Picker Modal -->
@if (_showStorePicker && _nearbyStores != null)
{
    <div class="modal-overlay" @onclick="() => _showStorePicker = false">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>🏪 Choose a Store</h3>
                <button class="modal-close" @onclick="() => _showStorePicker = false">✕</button>
            </div>
            @if (!_nearbyStores.Any())
            {
                <p class="empty-message">No stores found. Add stores under Grocery Stores.</p>
            }
            else
            {
                <div class="store-picker-list">
                    @foreach (StoreDto store in _nearbyStores)
                    {
                        <div class="store-picker-item" @onclick="() => AssignStore(store)">
                            <strong>@store.Name</strong>
                            <span class="store-chain">@store.Chain</span>
                            <span class="store-address-sm">@store.Address</span>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

<!-- Add Item Modal -->
@if (_showAddItemModal)
{
    <div class="modal-overlay" @onclick="CloseAddItemModal">
        <div class="modal-content large" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>@(_editingItem != null ? "Edit" : "Add") Item</h2>
                <button class="modal-close" @onclick="CloseAddItemModal">✕</button>
            </div>

            <div class="modal-body">
                <!-- Product Search -->
                <div class="form-group">
                    <label>Search Product Database (Optional)</label>
                    <div class="product-search-bar">
                        <input type="text" class="form-control" placeholder="Search products..."
                               @bind="_productSearchTerm" @bind:event="oninput" />
                        <button class="btn btn-secondary" @onclick="SearchProducts">Search</button>
                    </div>

                    @if (_productSearchResults?.Any() == true)
                    {
                        <div class="product-search-results">
                                @foreach (var product in _productSearchResults.Take(5))
                                {
                                    <div class="product-result-card-small" @onclick="() => SelectProduct(product)">
                                        <strong>@product.Name</strong>
                                        <span class="text-muted">@product.Brand</span>
                                        <button class="btn btn-sm btn-primary" @onclick:stopPropagation="true" @onclick="() => SelectProduct(product)">Select</button>
                                    </div>
                                }
                        </div>
                    }
                </div>

                <div class="divider-small">OR</div>

                <!-- Manual Entry -->
                <div class="form-row">
                    <div class="form-group">
                        <label>Item Name *</label>
                        <input type="text" class="form-control" @bind="_newItem.Name" placeholder="e.g., Milk" />
                    </div>

                    <div class="form-group">
                        <label>Brand</label>
                        <input type="text" class="form-control" @bind="_newItem.Brand" placeholder="Optional" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Quantity *</label>
                        <input type="number" step="0.1" class="form-control" @bind="_newItem.Quantity" />
                    </div>

                    <div class="form-group">
                        <label>Unit *</label>
                        <select class="form-control" @bind="_newItem.Unit">
                            <option value="count">count</option>
                            <option value="lb">lb</option>
                            <option value="oz">oz</option>
                            <option value="kg">kg</option>
                            <option value="g">g</option>
                            <option value="L">L</option>
                            <option value="ml">ml</option>
                            <option value="gallon">gallon</option>
                            <option value="package">package</option>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Category</label>
                        <select class="form-control" @bind="_newItem.Category">
                            <option value="">Select category...</option>
                            <option value="Produce">Produce</option>
                            <option value="Dairy">Dairy</option>
                            <option value="Meat">Meat & Poultry</option>
                            <option value="Bakery">Bakery</option>
                            <option value="Frozen">Frozen</option>
                            <option value="Canned">Canned Goods</option>
                            <option value="Snacks">Snacks</option>
                            <option value="Beverages">Beverages</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Priority</label>
                        <select class="form-control" @bind="_newItem.Priority">
                            <option value="Normal">Normal</option>
                            <option value="High">High</option>
                            <option value="Low">Low</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>Notes</label>
                    <textarea class="form-control" rows="2" @bind="_newItem.Notes" placeholder="Optional notes..."></textarea>
                </div>

                @if (!string.IsNullOrEmpty(_addItemError))
                {
                    <div class="alert alert-error">@_addItemError</div>
                }
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary-outline" @onclick="CloseAddItemModal">Cancel</button>
                <button class="btn btn-primary" @onclick="SaveItem">
                    @(_editingItem != null ? "Update" : "Add") Item
                </button>
            </div>
        </div>
    </div>
}

<!-- Add from Recipe Modal -->
@if (_showAddFromRecipeModal)
{
    <div class="modal-overlay" @onclick="CloseAddFromRecipeModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>Add Ingredients from Recipe</h2>
                <button class="modal-close" @onclick="CloseAddFromRecipeModal">✕</button>
            </div>

            <div class="modal-body">
                <p class="info-text">This feature will be available once recipe backend is implemented.</p>
                <p>You'll be able to add all recipe ingredients to your shopping list and automatically subtract what you already have in inventory.</p>
            </div>

            <div class="modal-footer">
                <button class="btn btn-primary" @onclick="CloseAddFromRecipeModal">OK</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private bool _isLoading = true;
    private ShoppingListDto? _list;
    private bool _isEditMode = false;
    private bool _showCompleted = false;

    // Add/Edit item
    private bool _showAddItemModal = false;
    private AddShoppingListItemRequest _newItem = new() { Quantity = 1, Unit = "count" };
    private ShoppingListItemDto? _editingItem;
    private string _addItemError = string.Empty;
    private string _productSearchTerm = string.Empty;
    private List<ProductDto>? _productSearchResults;

    // Add from recipe
    private bool _showAddFromRecipeModal = false;

    // Price comparison (bulk — existing feature)
    private bool _isPriceComparisonLoading = false;
    private PriceComparisonResult? _priceComparisonResult;

    // Per-item best prices
    private Dictionary<Guid, List<PriceComparisonDto>> _bestPrices = new();

    // Store assignment
    private StoreDto? _assignedStore;
    private bool _showStorePicker;
    private List<StoreDto>? _nearbyStores;

    // Favorites
    private List<FavoriteItemDto>? _favorites;
    private bool _showFavorites;

    // Shop mode / scan session
    private bool _isShopModeActive;
    private ShoppingScanSessionDto? _activeScanSession;
    private string _shopBarcode = string.Empty;
    private ScanResult? _lastShopScan;

    private sealed record ScanResult(bool Success, string Message);

    protected override async Task OnInitializedAsync()
    {
        await LoadList();
        _favorites = await ShoppingApi.GetFavoritesAsync();
        try
        {
            await LoadPriceComparisons();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load price comparisons for list {ListId}", Id);
        }
    }

    private async Task LoadList()
    {
        _isLoading = true;
        StateHasChanged();

        _list = await ShoppingApi.GetShoppingListAsync(Id);

        _isLoading = false;
        StateHasChanged();
    }

    private async Task LoadPriceComparisons()
    {
        if (_list?.Items == null)
        {
            return;
        }

        List<ShoppingListItemDto> itemsWithProduct = _list.Items
            .Where(i => i.ProductId.HasValue)
            .ToList();

        if (!itemsWithProduct.Any())
        {
            _bestPrices = new Dictionary<Guid, List<PriceComparisonDto>>();
            StateHasChanged();
            return;
        }

        System.Collections.Concurrent.ConcurrentDictionary<Guid, List<PriceComparisonDto>> bestPricesLocal = new();
        const int MaxConcurrentRequests = 5;
        using System.Threading.SemaphoreSlim semaphore = new(MaxConcurrentRequests);

        List<Task> tasks = itemsWithProduct.Select(async item =>
        {
            await semaphore.WaitAsync();
            try
            {
                List<PriceComparisonDto>? prices = await ShoppingApi.GetBestPricesAsync(item.ProductId!.Value);
                if (prices?.Any() == true)
                {
                    bestPricesLocal[item.Id] = prices;
                }
            }
            finally
            {
                semaphore.Release();
            }
        }).ToList();

        await Task.WhenAll(tasks);

        _bestPrices = bestPricesLocal.ToDictionary(kvp => kvp.Key, kvp => kvp.Value);
        StateHasChanged();
    }

    // ── Store assignment ─────────────────────────────────────────────────────

    private async Task ShowStorePicker()
    {
        _nearbyStores = await ShoppingApi.GetNearbyStoresAsync(0, 0);

        if (_nearbyStores == null || !_nearbyStores.Any())
        {
            ToastService.ShowWarning("No nearby stores could be found. Please try again later or check your connection.");
            return;
        }

        _showStorePicker = true;
    }

    private async Task AssignStore(StoreDto store)
    {
        _assignedStore = store;
        _showStorePicker = false;

        bool ok = await ShoppingApi.SetPreferredStoreAsync(store.Id);
        if (ok)
        {
            ToastService.ShowInfo($"Preferred store set to {store.Name}.");
        }
    }

    private void ClearStoreAssignment()
    {
        _assignedStore = null;
    }

    // ── Favorites ────────────────────────────────────────────────────────────

    private void ToggleFavorites() { _showFavorites = !_showFavorites; }

    private async Task AddFavoriteToList(FavoriteItemDto fav)
    {
        Guid? itemId = await ShoppingApi.AddItemAsync(new AddShoppingListItemRequest
        {
            ShoppingListId = Id,
            Name = fav.Name,
            Quantity = fav.TypicalQuantity ?? 1,
            Unit = fav.TypicalUnit ?? "count",
            Category = fav.Category
        });

        if (itemId.HasValue)
        {
            await ShoppingApi.UpdateFavoriteUsageAsync(fav.Id);
            ToastService.ShowSuccess($"{fav.Name} added to list.");
            await LoadList();
        }
    }

    // ── Shop mode / scan session ─────────────────────────────────────────────

    private async Task ToggleShopMode()
    {
        if (_isShopModeActive)
        {
            _isShopModeActive = false;
            _activeScanSession = null;
            return;
        }

        _isShopModeActive = true;
        await ShoppingApi.StartShoppingScanSessionAsync(
            new StartShoppingScanRequest { ShoppingListId = Id });

        _activeScanSession = await ShoppingApi.GetActiveShoppingScanSessionAsync();

        if (_activeScanSession == null)
        {
            _isShopModeActive = false;
            ToastService.ShowError("Could not start a scan session. Please try again.");
        }
    }

    private async Task HandleShopBarcode(KeyboardEventArgs e)
    {
        if (e.Key != "Enter" || string.IsNullOrWhiteSpace(_shopBarcode))
        {
            return;
        }

        string barcode = _shopBarcode.Trim();
        _shopBarcode = string.Empty;

        if (_activeScanSession == null)
        {
            return;
        }

        bool ok = await ShoppingApi.ScanPurchaseItemAsync(
            _activeScanSession.Id,
            new ScanPurchaseRequest
            {
                Barcode = barcode,
                Quantity = 1,
                Price = 0m
            });

        _lastShopScan = new ScanResult(ok,
            ok ? $"✓ Recorded purchase for {barcode}" : $"Failed to record purchase for {barcode}");

        _activeScanSession = await ShoppingApi.GetActiveShoppingScanSessionAsync();
        await LoadList();
    }

    private async Task FinishShopping()
    {
        if (_activeScanSession == null)
        {
            return;
        }

        await ShoppingApi.EndShoppingScanSessionAsync(_activeScanSession.Id);
        ToastService.ShowSuccess("Shopping session ended. Check your Inventory page to add purchased items to stock.");

        _activeScanSession = null;
        _isShopModeActive = false;
        await LoadList();
    }

