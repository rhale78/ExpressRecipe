    private async Task LoadPriceComparison()
    {
        if (_list == null) return;

        _isPriceComparisonLoading = true;
        _priceComparisonResult = null;
        StateHasChanged();

        List<Guid> productIds = _list.Items
            .Select(i => i.ProductId)
            .OfType<Guid>()
            .Distinct()
            .ToList();

        if (productIds.Any())
        {
            PriceComparisonRequest request = new() { ProductIds = productIds };
            _priceComparisonResult = await PriceApi.ComparePricesAsync(request);
        }

        _isPriceComparisonLoading = false;
        StateHasChanged();
    }

    private static bool IsSaleDeal(string? dealType) =>
        dealType is "Sale" or "BOGO" or "BOGO50";
