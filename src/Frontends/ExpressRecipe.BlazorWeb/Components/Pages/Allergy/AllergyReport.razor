@page "/allergy/report"
@page "/allergy/report/{MemberId:guid}"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using ExpressRecipe.Client.Shared.Services
@using ExpressRecipe.Shared.DTOs.User
@inject IAllergyApiClient AllergyApi
@inject IToastService ToastService
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Allergy Report — ExpressRecipe</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="report-actions">
            <button class="btn btn-outline-secondary btn-sm" @onclick='() => Navigation.NavigateTo("/allergy")'>
                ← Back to Dashboard
            </button>
            <button class="btn btn-outline-primary btn-sm" @onclick="PrintReport">
                🖨️ Print
            </button>
        </div>

        @if (_isLoading)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2">Generating report…</p>
            </div>
        }
        else if (_report == null)
        {
            <div class="text-center py-5">
                <p class="text-muted">Unable to load report. Please try again.</p>
            </div>
        }
        else
        {
            <div class="report-container" id="allergy-report-content">

                <!-- Header -->
                <div class="report-header">
                    <h1>ExpressRecipe — Allergy &amp; Reaction History Report</h1>
                    <p><strong>Member:</strong> @_report.MemberName</p>
                    <p><strong>Generated:</strong> @_report.GeneratedAt.ToLocalTime().ToString("MMMM dd, yyyy 'at' h:mm tt")</p>
                </div>

                <!-- Disclaimer -->
                <div class="report-disclaimer-box">
                    <strong>⚕️ Important Notice:</strong> This report is generated from user-logged data.
                    It is intended as a reference for healthcare providers and does not constitute medical
                    diagnosis, treatment advice, or a substitute for professional medical evaluation.
                    Please consult a qualified healthcare provider before making any medical decisions.
                </div>

                <!-- Confirmed Allergens -->
                @if (_report.ConfirmedAllergens.Any())
                {
                    <div class="report-section">
                        <h2>✅ Confirmed Allergens</h2>
                        <table class="report-table">
                            <thead>
                                <tr>
                                    <th>Ingredient / Allergen</th>
                                    <th>Severity</th>
                                    <th>Requires Epi-pen</th>
                                    <th>Diagnosed Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var a in _report.ConfirmedAllergens)
                                {
                                    <tr>
                                        <td>@a.AllergenName</td>
                                        <td>@a.SeverityLevel</td>
                                        <td>@(a.RequiresEpiPen ? "Yes" : "No")</td>
                                        <td>@(a.DiagnosisDate.HasValue ? a.DiagnosisDate.Value.ToString("MMM dd, yyyy") : "—")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                <!-- Suspected Allergens -->
                @if (_report.SuspectedAllergens.Any())
                {
                    <div class="report-section">
                        <h2>🔬 Suspected Allergens (from incident analysis)</h2>
                        <table class="report-table">
                            <thead>
                                <tr>
                                    <th>Ingredient</th>
                                    <th>Confidence</th>
                                    <th># Incidents</th>
                                    <th>First Seen</th>
                                    <th>Last Updated</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in _report.SuspectedAllergens)
                                {
                                    <tr>
                                        <td>@s.IngredientName</td>
                                        <td>@((int)(s.ConfidenceScore * 100))%</td>
                                        <td>@s.IncidentCount</td>
                                        <td>@s.FirstSeenAt.ToString("MMM dd, yyyy")</td>
                                        <td>@s.LastUpdatedAt.ToString("MMM dd, yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                <!-- Cleared Ingredients -->
                @if (_report.ClearedIngredients.Any())
                {
                    <div class="report-section">
                        <h2>✅ Cleared / Confirmed Safe Ingredients</h2>
                        <table class="report-table">
                            <thead>
                                <tr>
                                    <th>Ingredient</th>
                                    <th>Cleared On</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in _report.ClearedIngredients)
                                {
                                    <tr>
                                        <td>@c.IngredientName</td>
                                        <td>@c.ClearedAt.ToString("MMM dd, yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                <!-- Incident Timeline -->
                @if (_report.Incidents.Any())
                {
                    <div class="report-section">
                        <h2>📋 Incident Timeline</h2>
                        <table class="report-table">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Products</th>
                                    <th>Exposure</th>
                                    <th>Latency</th>
                                    <th>Symptoms / Severity</th>
                                    <th>Treatment</th>
                                    <th>Resolution (min)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var inc in _report.Incidents)
                                {
                                    var firstMember = inc.Members.FirstOrDefault();
                                    <tr>
                                        <td>@inc.IncidentDate.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</td>
                                        <td>@string.Join(", ", inc.Products.Where(p => p.HadReaction).Select(p => p.ProductName))</td>
                                        <td>@inc.ExposureType</td>
                                        <td>@(inc.ReactionLatency ?? "—")</td>
                                        <td>@(firstMember != null ? $"{firstMember.Severity}{(string.IsNullOrEmpty(firstMember.ReactionTypes) ? "" : ": " + firstMember.ReactionTypes)}" : "—")</td>
                                        <td>@(firstMember?.TreatmentType ?? "—")</td>
                                        <td>@(firstMember?.ResolutionTimeMinutes?.ToString() ?? "—")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                <!-- Footer -->
                <div class="report-footer">
                    For healthcare provider review only. Not a medical document. Generated by ExpressRecipe.
                </div>

            </div>
        }
    </Authorized>
    <NotAuthorized>
        <div class="text-center py-5">
            <p>Please <a href="/login">log in</a> to view your allergy report.</p>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter] public Guid? MemberId { get; set; }

    private AllergyReportModel? _report;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _report = await AllergyApi.GetReportAsync(MemberId);
        }
        catch
        {
            _report = null;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task PrintReport()
    {
        await JS.InvokeVoidAsync("window.print");
    }
}