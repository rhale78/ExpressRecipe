@page "/scanner"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using ExpressRecipe.Client.Shared.Services
@using ExpressRecipe.Client.Shared.Models.Product
@using ExpressRecipe.Client.Shared.Models.Inventory
@inject IScannerApiClient ScannerClient
@inject IVisionApiClient VisionClient
@inject IProductApiClient ProductApi
@inject IInventoryApiClient InventoryClient
@inject IShoppingListApiClient ShoppingClient
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IToastService ToastService
@inject ILogger<BarcodeScanner> Logger
@implements IDisposable

<PageTitle>Scanner - ExpressRecipe</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="container-fluid py-3">
            <!-- Header -->
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="GoBackAsync">
                        <i class="bi bi-arrow-left"></i> Back
                    </button>
                    <h4 class="mb-0"><i class="bi bi-upc-scan me-2"></i>Scanner</h4>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span class="badge bg-primary">@GetEntryPointLabel()</span>
                    <div class="dropdown">
                        <button class="btn btn-outline-secondary btn-sm dropdown-toggle" data-bs-toggle="dropdown">
                            Mode
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            @foreach (ScannerEntryPoint ep in Enum.GetValues<ScannerEntryPoint>())
                            {
                                <li>
                                    <button class="dropdown-item @(_entryPoint == ep ? "active" : "")" @onclick="@(() => SetEntryPoint(ep))">
                                        @GetEntryPointLabel(ep)
                                    </button>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Input Mode Tabs -->
            <ul class="nav nav-tabs mb-3">
                <li class="nav-item">
                    <button class="nav-link @(_inputMode == InputMode.Camera ? "active" : "")" @onclick="@(() => SetInputMode(InputMode.Camera))">
                        📷 Camera
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(_inputMode == InputMode.File ? "active" : "")" @onclick="@(() => SetInputMode(InputMode.File))">
                        📁 File
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(_inputMode == InputMode.Manual ? "active" : "")" @onclick="@(() => SetInputMode(InputMode.Manual))">
                        ⌨ Manual
                    </button>
                </li>
            </ul>

            <div class="row g-3">
                <!-- Main Input Area -->
                <div class="col-lg-8">
                    @if (_inputMode == InputMode.Camera)
                    {
                        <div class="card">
                            <div class="card-body p-2">
                                @if (!_cameraAvailable)
                                {
                                    <div class="text-center py-5">
                                        <i class="bi bi-camera-video-off text-muted" style="font-size:3rem"></i>
                                        <p class="mt-3 text-muted">@_cameraUnavailableMessage</p>
                                        <button class="btn btn-outline-secondary" @onclick="@(() => SetInputMode(InputMode.Manual))">
                                            Switch to Manual Entry
                                        </button>
                                    </div>
                                }
                                else if (!_isCameraActive)
                                {
                                    <div class="text-center py-5">
                                        <button class="btn btn-primary btn-lg" @onclick="StartCameraAsync">
                                            <i class="bi bi-camera-video me-2"></i>Start Camera
                                        </button>
                                        <p class="text-muted mt-2 small">Your browser will request camera permission</p>
                                    </div>
                                }
                                else
                                {
                                    <div class="position-relative">
                                        <video id="scanner-video" autoplay playsinline muted class="w-100 rounded"></video>
                                        <canvas id="scanner-canvas" class="d-none"></canvas>
                                        <!-- Scan overlay corners -->
                                        <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center" style="pointer-events:none">
                                            <div class="border border-2 border-success rounded" style="width:60%;height:40%;opacity:0.7"></div>
                                        </div>
                                        @if (_isProcessing)
                                        {
                                            <div class="position-absolute bottom-0 start-0 w-100 text-center pb-2">
                                                <span class="badge bg-info">
                                                    <span class="spinner-border spinner-border-sm me-1"></span>Detecting…
                                                </span>
                                            </div>
                                        }
                                    </div>
                                    <div class="d-flex gap-2 mt-2 flex-wrap">
                                        <button class="btn btn-outline-danger btn-sm" @onclick="StopCameraAsync">
                                            <i class="bi bi-stop-circle me-1"></i>Stop
                                        </button>
                                        @if (_detectionMode == DetectionMode.Image)
                                        {
                                            <button class="btn btn-primary btn-sm" @onclick="CaptureAndIdentifyAsync">
                                                <i class="bi bi-search me-1"></i>Identify Image
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    else if (_inputMode == InputMode.File)
                    {
                        <div class="card">
                            <div class="card-body">
                                <h6>Upload product image(s)</h6>
                                <InputFile OnChange="HandleFileUploadAsync" multiple accept="image/*" class="form-control mb-2" />
                                @if (_fileQueue.Count > 0)
                                {
                                    <ul class="list-group mt-2">
                                        @foreach (string fname in _fileQueue)
                                        {
                                            <li class="list-group-item list-group-item-sm">@fname</li>
                                        }
                                    </ul>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <!-- Manual Entry -->
                        <div class="card">
                            <div class="card-body">
                                <label class="form-label fw-semibold">Enter UPC / Barcode</label>
                                <div class="input-group">
                                    <input type="text"
                                           class="form-control"
                                           placeholder="Enter barcode (12-14 digits)"
                                           @bind="_manualUpc"
                                           @bind:event="oninput"
                                           @onkeypress="HandleManualKeyPressAsync"
                                           maxlength="14"
                                           inputmode="numeric" />
                                    <button class="btn btn-primary" @onclick="SearchByManualUpcAsync"
                                            disabled="@(string.IsNullOrWhiteSpace(_manualUpc) || _isProcessing)">
                                        @if (_isProcessing)
                                        {
                                            <span class="spinner-border spinner-border-sm"></span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-search"></i>
                                        }
                                    </button>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Detection Mode + Session Mode controls -->
                    <div class="d-flex flex-wrap gap-2 mt-3 align-items-center">
                        <div class="btn-group btn-group-sm" role="group">
                            <button class="btn @(_detectionMode == DetectionMode.Upc ? "btn-primary" : "btn-outline-secondary")"
                                    @onclick="@(() => SetDetectionMode(DetectionMode.Upc))">
                                🔁 UPC Mode
                            </button>
                            <button class="btn @(_detectionMode == DetectionMode.Image ? "btn-primary" : "btn-outline-secondary")"
                                    @onclick="@(() => SetDetectionMode(DetectionMode.Image))">
                                🖼 Image Mode
                            </button>
                        </div>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" id="autoSearchToggle" @bind="_autoSearch" />
                            <label class="form-check-label" for="autoSearchToggle">Auto-Search</label>
                        </div>
                        <div class="btn-group btn-group-sm" role="group">
                            <button class="btn @(_sessionMode == SessionMode.Single ? "btn-secondary" : "btn-outline-secondary")"
                                    @onclick="@(() => _sessionMode = SessionMode.Single)">
                                Single
                            </button>
                            <button class="btn @(_sessionMode == SessionMode.Batch ? "btn-secondary" : "btn-outline-secondary")"
                                    @onclick="@(() => _sessionMode = SessionMode.Batch)">
                                Batch
                            </button>
                        </div>
                    </div>

                    <!-- Error/Status message -->
                    @if (!string.IsNullOrEmpty(_statusMessage))
                    {
                        <div class="alert alert-warning alert-dismissible mt-3 py-2" role="alert">
                            @_statusMessage
                            <button type="button" class="btn-close" @onclick="@(() => _statusMessage = null)"></button>
                        </div>
                    }
                </div>

                <!-- Batch Queue Panel (right side) -->
                @if (_sessionMode == SessionMode.Batch && _batchQueue.Count > 0)
                {
                    <div class="col-lg-4">
                        <div class="card">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <span class="fw-semibold">Queue (@_batchQueue.Count)</span>
                                <button class="btn btn-primary btn-sm" @onclick="ProcessBatchQueueAsync">
                                    Process All
                                </button>
                            </div>
                            <ul class="list-group list-group-flush" style="max-height:300px;overflow-y:auto">
                                @foreach (DetectedItem item in _batchQueue)
                                {
                                    <li class="list-group-item list-group-item-sm d-flex justify-content-between align-items-center">
                                        <span>@(item.ProductName ?? item.Upc)</span>
                                        <button class="btn btn-outline-danger btn-sm py-0" @onclick="@(() => _batchQueue.Remove(item))">×</button>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                }
            </div>

            <!-- Result Card -->
            @if (_currentResult != null)
            {
                <div class="card mt-3">
                    <div class="card-body">
                        @if (_currentResult.ProductFound)
                        {
                            <div class="d-flex align-items-start gap-3">
                                @if (!string.IsNullOrEmpty(_currentResult.ImageUrl))
                                {
                                    <img src="@_currentResult.ImageUrl" alt="product" class="rounded" style="width:80px;height:80px;object-fit:cover" />
                                }
                                else
                                {
                                    <div class="rounded bg-light d-flex align-items-center justify-content-center" style="width:80px;height:80px;font-size:2rem">📦</div>
                                }
                                <div class="flex-grow-1">
                                    <h5 class="mb-1">@_currentResult.ProductName</h5>
                                    <p class="text-muted mb-1">@_currentResult.Brand</p>
                                    @if (!string.IsNullOrEmpty(_currentResult.Upc))
                                    {
                                        <small class="text-muted">UPC: @_currentResult.Upc</small>
                                    }
                                    @if (_currentResult.DetectionProvider != null)
                                    {
                                        <span class="badge bg-light text-dark ms-2 small">via @_currentResult.DetectionProvider</span>
                                    }
                                </div>
                            </div>
                            <div class="d-flex gap-2 mt-3 flex-wrap">
                                @if (_sessionMode == SessionMode.Single && _currentResult.ProductId.HasValue)
                                {
                                    <button class="btn btn-success" @onclick="ConfirmAndDispatchAsync">
                                        <i class="bi bi-check-lg me-1"></i>Confirm
                                    </button>
                                }
                                <button class="btn btn-outline-warning" @onclick="ShowWrongItemAsync">
                                    ❌ Wrong item?
                                </button>
                                @if (_sessionMode == SessionMode.Batch)
                                {
                                    <button class="btn btn-primary" @onclick="AddToBatchQueue">
                                        <i class="bi bi-plus me-1"></i>Add to Queue
                                    </button>
                                }
                            </div>
                            <!-- Wrong item correction overlay -->
                            @if (_showCorrectionForm)
                            {
                                <div class="mt-3 p-3 border rounded bg-light">
                                    <h6>Report incorrect match</h6>
                                    <input type="text" class="form-control mb-2" placeholder="What is the correct product name?" @bind="_correctionText" />
                                    <textarea class="form-control mb-2" rows="2" placeholder="Additional notes (optional)" @bind="_correctionNote"></textarea>
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-primary btn-sm" @onclick="SubmitCorrectionAsync">Submit</button>
                                        <button class="btn btn-outline-secondary btn-sm" @onclick="@(() => _showCorrectionForm = false)">Cancel</button>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <!-- Product Not Found -->
                            <div class="text-center py-3">
                                <i class="bi bi-question-circle text-muted" style="font-size:2.5rem"></i>
                                <h6 class="mt-2">Not in Database</h6>
                                <p class="text-muted small mb-3">UPC: @_currentResult.Upc</p>
                                <div class="d-flex gap-2 justify-content-center flex-wrap">
                                    <div class="input-group input-group-sm" style="max-width:300px">
                                        <input type="text" class="form-control" placeholder="Search by name…" @bind="_productSearchText" />
                                        <button class="btn btn-outline-primary" @onclick="SearchByNameAsync">Search</button>
                                    </div>
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="NavigateToAddProductAsync">
                                        <i class="bi bi-plus me-1"></i>Add Product
                                    </button>
                                    <button class="btn btn-outline-warning btn-sm" @onclick="ReportUnknownProductAsync">
                                        <i class="bi bi-flag me-1"></i>Flag for Review
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="container py-5 text-center">
            <h4>Authentication Required</h4>
            <p>Please <a href="/login">sign in</a> to use the scanner.</p>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private enum InputMode { Camera, File, Manual }
    private enum DetectionMode { Upc, Image }
    private enum SessionMode { Single, Batch }

    private enum ScannerEntryPoint
    {
        Default,
        AddInventory,
        RemoveInventory,
        AddPrice,
        AllergenCheck,
        AddProduct,
        AddAllergy
    }

    private class DetectedItem
    {
        public string Upc { get; set; } = string.Empty;
        public string? ProductName { get; set; }
        public string? Brand { get; set; }
        public string? ImageUrl { get; set; }
        public Guid? ProductId { get; set; }
        public bool ProductFound { get; set; }
        public string? CaptureBase64 { get; set; }
        public Guid? CaptureId { get; set; }
        public string? DetectionProvider { get; set; }
    }

    [SupplyParameterFromQuery]
    private string? Mode { get; set; }

    private InputMode _inputMode = InputMode.Camera;
    private DetectionMode _detectionMode = DetectionMode.Upc;
    private SessionMode _sessionMode = SessionMode.Single;
    private ScannerEntryPoint _entryPoint = ScannerEntryPoint.Default;

    private bool _autoSearch = true;
    private bool _cameraAvailable = true;
    private bool _isCameraActive = false;
    private bool _isProcessing = false;
    private bool _saveForTraining = true;
    private string _cameraFacingMode = "environment";
    private string? _cameraUnavailableMessage;
    private string? _statusMessage;

    private string _manualUpc = string.Empty;
    private string _productSearchText = string.Empty;
    private string _correctionText = string.Empty;
    private string _correctionNote = string.Empty;

    private DetectedItem? _currentResult;
    private List<DetectedItem> _batchQueue = new();
    private List<string> _fileQueue = new();

    private bool _showCorrectionForm = false;

    private DotNetObjectReference<BarcodeScanner>? _dotNetRef;

    protected override async Task OnInitializedAsync()
    {
        ParseMode();
        await LoadPreferencesAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            bool available = await JS.InvokeAsync<bool>("scannerInterop.checkCameraAvailable");
            _cameraAvailable = available;
            if (!available)
            {
                _inputMode = InputMode.Manual;
            }

            // Load saved preferences now that JS interop is available
            await LoadPreferencesAsync();
            StateHasChanged();
        }
    }

    private async Task LoadPreferencesAsync()
    {
        try
        {
            string? autoSearch = await JS.InvokeAsync<string?>("scannerInterop.loadPreference", "autoSearch");
            string? sessionMode = await JS.InvokeAsync<string?>("scannerInterop.loadPreference", "defaultSessionMode");
            string? training = await JS.InvokeAsync<string?>("scannerInterop.loadPreference", "saveForTraining");
            string? facing = await JS.InvokeAsync<string?>("scannerInterop.loadPreference", "cameraFacingMode");
            string? detMode = await JS.InvokeAsync<string?>("scannerInterop.loadPreference", "detectionMode");

            if (bool.TryParse(autoSearch, out bool autoSearchVal)) { _autoSearch = autoSearchVal; }
            if (!string.IsNullOrWhiteSpace(sessionMode) && Enum.TryParse<SessionMode>(sessionMode, ignoreCase: true, out SessionMode sm)) { _sessionMode = sm; }
            if (bool.TryParse(training, out bool trainingVal)) { _saveForTraining = trainingVal; }
            if (!string.IsNullOrWhiteSpace(facing)) { _cameraFacingMode = facing; }
            if (!string.IsNullOrWhiteSpace(detMode) && Enum.TryParse<DetectionMode>(detMode, ignoreCase: true, out DetectionMode dm)) { _detectionMode = dm; }
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Could not load scanner preferences");
        }
    }

    private void ParseMode()
    {
        if (string.IsNullOrWhiteSpace(Mode))
        {
            return;
        }

        if (Enum.TryParse<ScannerEntryPoint>(Mode, ignoreCase: true, out ScannerEntryPoint ep))
        {
            _entryPoint = ep;
        }
    }

    private async Task StartCameraAsync()
    {
        _dotNetRef?.Dispose();
        _dotNetRef = DotNetObjectReference.Create(this);
        try
        {
            await JS.InvokeVoidAsync("scannerInterop.startCamera", _dotNetRef, "scanner-video", "scanner-canvas", _cameraFacingMode);
            _isCameraActive = true;
        }
        catch (Exception ex)
        {
            _statusMessage = $"Camera error: {ex.Message}";
            _cameraAvailable = false;
        }
    }

    private async Task StopCameraAsync()
    {
        await JS.InvokeVoidAsync("scannerInterop.stopCamera");
        _isCameraActive = false;
    }

    [JSInvokable]
    public async Task OnBarcodeDetected(BarcodeDetectPayload payload)
    {
        _isProcessing = true;
        await InvokeAsync(StateHasChanged);

        Guid? captureId = null;
        if (!string.IsNullOrWhiteSpace(payload.CaptureBase64))
        {
            captureId = await TrySaveCaptureAsync(payload.CaptureBase64, payload.Upc, null);
        }

        if (_autoSearch)
        {
            await SearchByUpcAsync(payload.Upc, payload.CaptureBase64, captureId);
        }
        else
        {
            DetectedItem item = new DetectedItem
            {
                Upc = payload.Upc,
                CaptureBase64 = payload.CaptureBase64,
                CaptureId = captureId
            };

            if (_sessionMode == SessionMode.Batch)
            {
                _batchQueue.Add(item);
            }
            else
            {
                _currentResult = item;
            }
        }

        _isProcessing = false;
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnCameraUnavailable(string errorName)
    {
        _cameraAvailable = false;
        _isCameraActive = false;
        _inputMode = InputMode.Manual;
        _cameraUnavailableMessage = errorName == "NotAllowedError"
            ? "Camera permission denied. Please allow camera access or use manual entry."
            : "Camera not available. Please use manual entry or file upload.";
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnFrameCaptured(string base64)
    {
        if (_detectionMode != DetectionMode.Image)
        {
            return;
        }

        _isProcessing = true;
        await InvokeAsync(StateHasChanged);

        await AnalyzeImageAsync(base64);

        _isProcessing = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task CaptureAndIdentifyAsync()
    {
        string? base64 = await JS.InvokeAsync<string?>("scannerInterop.captureFrame", "scanner-canvas");
        if (string.IsNullOrWhiteSpace(base64))
        {
            _statusMessage = "No frame available. Make sure camera is active.";
            return;
        }

        await AnalyzeImageAsync(base64);
    }

    private async Task AnalyzeImageAsync(string base64)
    {
        VisionAnalyzeResponse? result = await VisionClient.AnalyzeAsync(base64);

        if (result == null || !result.Success)
        {
            _currentResult = new DetectedItem { ProductFound = false };
            _statusMessage = "Could not identify product from image.";
            return;
        }

        Guid? captureId = await TrySaveCaptureAsync(base64, detectedBarcode: null, result.ProductName);

        DetectedItem item = new DetectedItem
        {
            Upc = string.Empty,
            ProductName = result.ProductName,
            Brand = result.Brand,
            ProductFound = !string.IsNullOrWhiteSpace(result.ProductName),
            CaptureBase64 = base64,
            CaptureId = captureId,
            DetectionProvider = result.ProviderUsed
        };

        if (_sessionMode == SessionMode.Batch)
        {
            _batchQueue.Add(item);
        }
        else
        {
            _currentResult = item;
        }
    }

    private async Task SearchByUpcAsync(string upc, string? captureBase64 = null, Guid? captureId = null)
    {
        ProductDto? product = await ProductApi.GetProductByUpcAsync(upc);

        DetectedItem item = new DetectedItem
        {
            Upc = upc,
            ProductFound = product != null,
            ProductId = product?.Id,
            ProductName = product?.Name,
            Brand = product?.Brand,
            ImageUrl = product?.ImageUrl,
            CaptureBase64 = captureBase64,
            CaptureId = captureId,
            DetectionProvider = "ZXing"
        };

        if (_sessionMode == SessionMode.Batch)
        {
            _batchQueue.Add(item);
        }
        else
        {
            _currentResult = item;
        }
    }

    private async Task SearchByManualUpcAsync()
    {
        if (string.IsNullOrWhiteSpace(_manualUpc))
        {
            return;
        }

        _isProcessing = true;
        await SearchByUpcAsync(_manualUpc.Trim());
        _isProcessing = false;
    }

    private async Task HandleManualKeyPressAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_manualUpc))
        {
            await SearchByManualUpcAsync();
        }
    }

    private async Task HandleFileUploadAsync(InputFileChangeEventArgs e)
    {
        _fileQueue.Clear();
        foreach (IBrowserFile file in e.GetMultipleFiles(10))
        {
            _fileQueue.Add(file.Name);
            try
            {
                using Stream stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                using MemoryStream ms = new MemoryStream();
                await stream.CopyToAsync(ms);
                string base64 = Convert.ToBase64String(ms.ToArray());
                await AnalyzeImageAsync(base64);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to process file {FileName}", file.Name);
                ToastService.ShowError($"Could not process {file.Name}", "File Error");
            }
        }
    }

    private async Task<Guid?> TrySaveCaptureAsync(string? base64, string? detectedBarcode, string? detectedProductName)
    {
        if (string.IsNullOrWhiteSpace(base64))
        {
            return null;
        }

        try
        {
            VisionCaptureRequest request = new VisionCaptureRequest
            {
                CaptureBase64 = base64,
                DetectedBarcode = detectedBarcode,
                DetectedProductName = detectedProductName,
                IsTrainingData = _saveForTraining
            };

            return await ScannerClient.SaveVisionCaptureAsync(request);
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Fire-and-forget vision capture save failed");
            return null;
        }
    }

    private async Task ConfirmAndDispatchAsync()
    {
        if (_currentResult?.ProductId == null)
        {
            return;
        }

        await StopCameraAsync();
        await DispatchToEntryPoint(_currentResult.ProductId.Value);
    }

    private async Task DispatchToEntryPoint(Guid productId)
    {
        // If an active scan session exists, record inline instead of navigating
        ScanSessionDto? session = await InventoryClient.GetActiveScanSessionAsync();
        if (session != null && _entryPoint == ScannerEntryPoint.AddInventory)
        {
            bool addedSuccessfully = await InventoryClient.ScanAddItemAsync(session.Id,
                new ScanAddItemRequest { ProductId = productId });
            ToastService.ShowSuccess(addedSuccessfully ? "Added to inventory session." : "Could not add item.");
            return;
        }

        string destination = _entryPoint switch
        {
            ScannerEntryPoint.AddInventory => $"/inventory/add?productId={productId}",
            ScannerEntryPoint.RemoveInventory => $"/inventory/remove?productId={productId}",
            ScannerEntryPoint.AddPrice => $"/prices/add?productId={productId}",
            ScannerEntryPoint.AllergenCheck => $"/allergens/check?productId={productId}",
            ScannerEntryPoint.AddProduct => $"/products/add?productId={productId}",
            ScannerEntryPoint.AddAllergy => $"/allergens/add?productId={productId}",
            _ => $"/products/{productId}"
        };

        Navigation.NavigateTo(destination);
    }

    private async Task ShowWrongItemAsync()
    {
        _showCorrectionForm = true;
        await Task.CompletedTask;
    }

    private async Task SubmitCorrectionAsync()
    {
        if (_currentResult?.CaptureId == null)
        {
            _showCorrectionForm = false;
            return;
        }

        try
        {
            CorrectionReportRequest report = new CorrectionReportRequest
            {
                VisionCaptureId = _currentResult.CaptureId.Value,
                AiGuess = _currentResult.ProductName,
                UserCorrection = _correctionText,
                UserNote = _correctionNote
            };

            bool success = await ScannerClient.CreateCorrectionReportAsync(report);

            if (success)
            {
                ToastService.ShowSuccess("Thanks for the correction! It will be reviewed.", "Flagged");
            }

            _showCorrectionForm = false;
            _correctionText = string.Empty;
            _correctionNote = string.Empty;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to submit correction report");
            ToastService.ShowError("Could not submit correction.", "Error");
        }
    }

    private void AddToBatchQueue()
    {
        if (_currentResult != null)
        {
            _batchQueue.Add(_currentResult);
            _currentResult = null;
        }
    }

    private async Task ProcessBatchQueueAsync()
    {
        // Navigate to the first confirmed item only; navigating away clears the rest of the queue
        DetectedItem? first = _batchQueue.FirstOrDefault(i => i.ProductId.HasValue);

        if (first == null)
        {
            _batchQueue.Clear();
            return;
        }

        List<DetectedItem> remaining = _batchQueue.Where(i => i != first && i.ProductId.HasValue).ToList();
        _batchQueue.Clear();

        await StopCameraAsync();

        // If there are more items, pass them as a serialised query param so the destination page can show a queue
        if (remaining.Count > 0)
        {
            string moreIds = string.Join(",", remaining.Select(i => i.ProductId!.Value));
            Navigation.NavigateTo($"{BuildDispatchUrl(first.ProductId!.Value)}&batchIds={Uri.EscapeDataString(moreIds)}");
        }
        else
        {
            await DispatchToEntryPoint(first.ProductId!.Value);
        }
    }

    private string BuildDispatchUrl(Guid productId)
    {
        return _entryPoint switch
        {
            ScannerEntryPoint.AddInventory => $"/inventory/add?productId={productId}",
            ScannerEntryPoint.RemoveInventory => $"/inventory/remove?productId={productId}",
            ScannerEntryPoint.AddPrice => $"/prices/add?productId={productId}",
            ScannerEntryPoint.AllergenCheck => $"/allergens/check?productId={productId}",
            ScannerEntryPoint.AddProduct => $"/products/add?productId={productId}",
            ScannerEntryPoint.AddAllergy => $"/allergens/add?productId={productId}",
            _ => $"/products/{productId}"
        };
    }

    private async Task SearchByNameAsync()
    {
        if (string.IsNullOrWhiteSpace(_productSearchText))
        {
            return;
        }

        Navigation.NavigateTo($"/products/search?q={Uri.EscapeDataString(_productSearchText)}");
        await Task.CompletedTask;
    }

    private async Task NavigateToAddProductAsync()
    {
        string upc = _currentResult?.Upc ?? string.Empty;
        Navigation.NavigateTo($"/products/add?upc={Uri.EscapeDataString(upc)}");
        await Task.CompletedTask;
    }

    private async Task ReportUnknownProductAsync()
    {
        if (_currentResult == null)
        {
            return;
        }

        try
        {
            bool reported = await ScannerClient.ReportMissingProductAsync(_currentResult.Upc, _currentResult.ProductName ?? string.Empty);
            if (reported)
            {
                ToastService.ShowSuccess("Product flagged for admin review.", "Reported");
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to report unknown product");
        }
    }

    private void SetInputMode(InputMode mode)
    {
        if (_isCameraActive && mode != InputMode.Camera)
        {
            // Fire-and-forget: camera stop is best-effort when switching modes
            _ = StopCameraAsync().ContinueWith(t =>
            {
                if (t.IsFaulted)
                {
                    Logger.LogWarning(t.Exception, "Camera stop encountered an error during mode switch");
                }
                else if (t.IsCanceled)
                {
                    Logger.LogDebug("Camera stop was cancelled during mode switch");
                }
            }, TaskScheduler.Default);
        }
        _inputMode = mode;
        _currentResult = null;
    }

    private void SetDetectionMode(DetectionMode mode)
    {
        _detectionMode = mode;
    }

    private void SetEntryPoint(ScannerEntryPoint ep)
    {
        _entryPoint = ep;
    }

    private async Task GoBackAsync()
    {
        // Use scannerInterop.goBack() which safely checks history length in JS
        bool hasHistory = await JS.InvokeAsync<bool>("scannerInterop.canGoBack");
        if (hasHistory)
        {
            await JS.InvokeVoidAsync("scannerInterop.goBack");
        }
        else
        {
            Navigation.NavigateTo("/");
        }
    }

    private string GetEntryPointLabel(ScannerEntryPoint? ep = null)
    {
        ScannerEntryPoint target = ep ?? _entryPoint;
        return target switch
        {
            ScannerEntryPoint.AddInventory => "Add Inventory",
            ScannerEntryPoint.RemoveInventory => "Remove Inventory",
            ScannerEntryPoint.AddPrice => "Add Price",
            ScannerEntryPoint.AllergenCheck => "Allergen Check",
            ScannerEntryPoint.AddProduct => "Add Product",
            ScannerEntryPoint.AddAllergy => "Add Allergy",
            _ => "General Scan"
        };
    }

    public void Dispose()
    {
        if (_isCameraActive)
        {
            // Best-effort stop: fire-and-forget release of media tracks
            _ = JS.InvokeVoidAsync("scannerInterop.stopCamera").AsTask().ContinueWith(t =>
            {
                if (t.IsFaulted || t.IsCanceled) { /* ignore — page is navigating away */ }
            }, TaskScheduler.Default);
            _isCameraActive = false;
        }

        _dotNetRef?.Dispose();
        _dotNetRef = null;
    }

    // Payload class for JS interop
    public class BarcodeDetectPayload
    {
        public string Upc { get; set; } = string.Empty;
        public string? CaptureBase64 { get; set; }
    }
}
