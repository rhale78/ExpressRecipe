@page "/recipes/create"
@page "/recipes/{RecipeId:guid}/edit"
@rendermode InteractiveServer
@implements IDisposable
@using Microsoft.AspNetCore.Components.Authorization
@using ExpressRecipe.Client.Shared.Services
@using ExpressRecipe.Client.Shared.Models.Recipe
@using ExpressRecipe.Client.Shared.Models.AI
@using Blazored.LocalStorage
@using System.Text.RegularExpressions
@inject IRecipeApiClient RecipeApi
@inject IAIApiClient AIApi
@inject ILocalStorageService LocalStorage
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>@(string.IsNullOrWhiteSpace(_recipe.Title) ? (_isEditMode ? "Edit Recipe" : "Create New Recipe") : _recipe.Title) - ExpressRecipe</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="cr-page">

            <!-- Page header -->
            <div class="cr-header">
                <button class="btn btn-outline btn-sm" @onclick="GoBack">← Back</button>
                <h1 class="cr-page-title">@(_isEditMode ? "✏️ Edit Recipe" : "📝 Create New Recipe")</h1>
                @if (_draftSavedAt != null)
                {
                    <span class="cr-draft-saved">🟢 Draft saved @_draftSavedAt</span>
                }
            </div>

            <!-- Draft restore banner -->
            @if (_showDraftRestoreBanner)
            {
                <div class="cr-draft-banner">
                    <span>📝 Draft found from @_draftRestoreTime. Restore your work?</span>
                    <div class="cr-draft-actions">
                        <button class="btn btn-sm btn-primary" @onclick="RestoreDraftAsync">Restore</button>
                        <button class="btn btn-sm btn-outline" @onclick="DismissDraft">Dismiss</button>
                    </div>
                </div>
            }

            <!-- Error alert -->
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="cr-alert cr-alert-error">
                    <strong>⚠️ Error:</strong> @_errorMessage
                    <button class="cr-alert-close" @onclick="ClearError">×</button>
                </div>
            }

            <!-- Loading state -->
            @if (_isLoading)
            {
                <div class="cr-loading">
                    <div class="cr-spinner"></div>
                    <p>Loading recipe...</p>
                </div>
            }
            else
            {
                <!-- Progress stepper -->
                <div class="cr-stepper">
                    @{
                        var stepLabels = new[] { "Import", "Basic Info", "Ingredients", "Instructions", "Finish" };
                    }
                    @for (int si = 0; si < stepLabels.Length; si++)
                    {
                        var stepNum = si + 1;
                        var label = stepLabels[si];
                        var stateClass = stepNum < _currentStep ? "cr-stepper-step completed"
                                       : stepNum == _currentStep ? "cr-stepper-step active"
                                       : "cr-stepper-step future";
                        <div class="@stateClass">
                            <div class="cr-step-circle">
                                @if (stepNum < _currentStep)
                                {
                                    <span>✓</span>
                                }
                                else
                                {
                                    <span>@stepNum</span>
                                }
                            </div>
                            <span class="cr-step-label">@label</span>
                        </div>
                        @if (si < stepLabels.Length - 1)
                        {
                            <div class="cr-step-connector @(stepNum < _currentStep ? "done" : "")"></div>
                        }
                    }
                </div>

                <!-- Step content -->
                <div class="cr-content">

                    <!-- Step 1: Import (full-width) -->
                    @if (_currentStep == 1)
                    {
                        <div class="cr-step1">
                            <div class="cr-step1-header">
                                <h2>📋 Paste or Type Your Recipe</h2>
                                <p>Drop in any recipe from anywhere — we'll parse the title, ingredients, times, and instructions for you automatically.</p>
                            </div>

                            <textarea class="cr-textarea"
                                      value="@_recipeText"
                                      @oninput="OnRecipeTextChanged"
                                      placeholder="@ExamplePlaceholderText"></textarea>

                            <div class="cr-parse-row">
                                <button class="btn btn-primary"
                                        @onclick="ParseWithAIAsync"
                                        disabled="@(_isParsing || string.IsNullOrWhiteSpace(_recipeText))">
                                    @if (_isParsing)
                                    {
                                        <span class="cr-spinner-sm"></span><span>Analyzing...</span>
                                    }
                                    else
                                    {
                                        <span>✨ Parse with AI</span>
                                    }
                                </button>
                                <button class="btn btn-outline"
                                        @onclick="ParseWithRegexManual"
                                        disabled="@string.IsNullOrWhiteSpace(_recipeText)">
                                    🔄 Smart Parse
                                </button>
                            </div>

                            @if (_isParsing)
                            {
                                <div class="cr-parse-status cr-ps-parsing">
                                    <span class="cr-spinner-sm"></span>
                                    <span>AI is analyzing your recipe...</span>
                                </div>
                            }
                            else if (_parseStatus == "ai")
                            {
                                <div class="cr-parse-status cr-ps-success">✅ AI parsed · @ConfidenceLabel</div>
                            }
                            else if (_parseStatus == "ai-fallback")
                            {
                                <div class="cr-parse-status cr-ps-warning">⚠️ AI unavailable, using smart parsing</div>
                            }
                            else if (_parseStatus == "regex")
                            {
                                <div class="cr-parse-status cr-ps-info">🔍 Smart parsed · @ConfidenceLabel</div>
                            }

                            @foreach (var suggestion in _unitSuggestions)
                            {
                                var s = suggestion;
                                <div class="cr-suggestion">
                                    <span>💡 Did you mean '<strong>@s.Suggested</strong>' instead of '<strong>@s.Original</strong>' in "@s.Context"?</span>
                                    <div class="cr-suggestion-actions">
                                        <button class="btn btn-sm btn-warning" @onclick="() => AcceptSuggestion(s)">Accept</button>
                                        <button class="btn btn-sm btn-outline" @onclick="() => DismissSuggestion(s)">Dismiss</button>
                                    </div>
                                </div>
                            }

                            <div class="cr-skip-link">
                                Already have all details?
                                <button class="btn btn-sm btn-outline" @onclick="() => _currentStep = 2">Skip to Basic Info →</button>
                            </div>
                        </div>
                    }

                    <!-- Steps 2–5: two-column editor + preview -->
                    @if (_currentStep >= 2)
                    {
                        <div class="cr-editor">

                            <!-- Left: form fields -->
                            <div class="cr-fields">

                                <!-- Step 2: Basic Info -->
                                @if (_currentStep == 2)
                                {
                                    <div class="cr-section">
                                        <h2>📝 Basic Info</h2>

                                        <div class="cr-form-group">
                                            <label>Title <span class="cr-required">*</span></label>
                                            <input type="text" class="cr-input" value="@_recipe.Title"
                                                   @oninput="OnTitleChanged" placeholder="Recipe title" />
                                        </div>

                                        <div class="cr-form-group">
                                            <label>Description</label>
                                            <textarea class="cr-input" rows="3" value="@_recipe.Description"
                                                      @oninput="OnDescriptionChanged"
                                                      placeholder="Brief description of the recipe..."></textarea>
                                        </div>

                                        <div class="cr-form-grid">
                                            <div class="cr-form-group">
                                                <label>Category</label>
                                                <select class="cr-input" value="@_recipe.Category" @onchange="OnCategoryChanged">
                                                    <option value="">— Select —</option>
                                                    @foreach (var opt in _categoryOptions)
                                                    {
                                                        <option value="@opt">@opt</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="cr-form-group">
                                                <label>Cuisine</label>
                                                <select class="cr-input" value="@_recipe.Cuisine" @onchange="OnCuisineChanged">
                                                    <option value="">— Select —</option>
                                                    @foreach (var opt in _cuisineOptions)
                                                    {
                                                        <option value="@opt">@opt</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="cr-form-group">
                                                <label>Difficulty</label>
                                                <select class="cr-input" value="@_recipe.Difficulty" @onchange="OnDifficultyChanged">
                                                    <option value="Easy">Easy</option>
                                                    <option value="Medium">Medium</option>
                                                    <option value="Hard">Hard</option>
                                                </select>
                                            </div>
                                        </div>

                                        <div class="cr-form-grid cr-form-grid-3">
                                            <div class="cr-form-group">
                                                <label>Prep Time (min)</label>
                                                <input type="number" class="cr-input" value="@_recipe.PrepTimeMinutes"
                                                       @oninput="OnPrepTimeChanged" min="0" />
                                            </div>
                                            <div class="cr-form-group">
                                                <label>Cook Time (min)</label>
                                                <input type="number" class="cr-input" value="@_recipe.CookTimeMinutes"
                                                       @oninput="OnCookTimeChanged" min="0" />
                                            </div>
                                            <div class="cr-form-group">
                                                <label>Servings</label>
                                                <input type="number" class="cr-input" value="@_recipe.Servings"
                                                       @oninput="OnServingsChanged" min="1" />
                                            </div>
                                        </div>
                                    </div>
                                }

                                <!-- Step 3: Ingredients -->
                                @if (_currentStep == 3)
                                {
                                    <div class="cr-section">
                                        <h2>🥕 Ingredients</h2>

                                        @if (!_recipe.Ingredients.Any())
                                        {
                                            <p class="cr-empty">No ingredients yet. Add some below!</p>
                                        }

                                        @foreach (var ingredient in _recipe.Ingredients)
                                        {
                                            var ing = ingredient;
                                            <div class="cr-ingredient-row">
                                                <span class="cr-row-num">@ing.OrderIndex</span>
                                                <input type="number" class="cr-input cr-qty-input" placeholder="Qty" step="0.25"
                                                       @bind="ing.Quantity" />
                                                <input type="text" class="cr-input cr-unit-input" placeholder="Unit"
                                                       value="@ing.Unit"
                                                       @oninput="@(e => OnIngredientFieldChanged(ing, "unit", e.Value?.ToString()))" />
                                                <input type="text" class="cr-input cr-name-input" placeholder="Ingredient name"
                                                       value="@ing.Name"
                                                       @oninput="@(e => OnIngredientFieldChanged(ing, "name", e.Value?.ToString()))" />
                                                <input type="text" class="cr-input cr-notes-input" placeholder="Notes (optional)"
                                                       value="@ing.Notes"
                                                       @oninput="@(e => OnIngredientFieldChanged(ing, "notes", e.Value?.ToString()))" />
                                                <button class="btn btn-sm btn-outline cr-row-delete"
                                                        @onclick="() => RemoveIngredient(ing)">
                                                    ✕
                                                </button>
                                            </div>
                                        }

                                        <button class="btn btn-outline btn-sm cr-add-btn"
                                                @onclick="AddIngredient">
                                            + Add Ingredient
                                        </button>
                                    </div>
                                }

                                <!-- Step 4: Instructions -->
                                @if (_currentStep == 4)
                                {
                                    <div class="cr-section">
                                        <h2>📖 Instructions</h2>

                                        @if (!_recipe.Steps.Any())
                                        {
                                            <p class="cr-empty">No steps yet. Add your first instruction below!</p>
                                        }

                                        @foreach (var recipeStep in _recipe.Steps)
                                        {
                                            var step = recipeStep;
                                            <div class="cr-step-row">
                                                <span class="cr-step-num">@step.OrderIndex</span>
                                                <textarea class="cr-input cr-step-textarea" rows="3"
                                                          placeholder="Describe this step..."
                                                          value="@step.Instruction"
                                                          @oninput="@(e => OnStepInstructionChanged(step, e.Value?.ToString()))"></textarea>
                                                <button class="btn btn-sm btn-outline cr-row-delete"
                                                        @onclick="() => RemoveStep(step)">
                                                    ✕
                                                </button>
                                            </div>
                                        }

                                        <button class="btn btn-outline btn-sm cr-add-btn"
                                                @onclick="AddStep">
                                            + Add Step
                                        </button>
                                    </div>
                                }

                                <!-- Step 5: Finishing Touches -->
                                @if (_currentStep == 5)
                                {
                                    <div class="cr-section">
                                        <h2>🏁 Finishing Touches</h2>

                                        <!-- Tags -->
                                        <div class="cr-form-group">
                                            <label>Tags</label>
                                            <input type="text" class="cr-input" value="@_tagsInput"
                                                   @oninput="OnTagsChanged"
                                                   placeholder="chocolate, quick, dinner (comma-separated)" />
                                            @if (_recipe.Tags.Any())
                                            {
                                                <div class="cr-tag-chips">
                                                    @foreach (var tag in _recipe.Tags)
                                                    {
                                                        var t = tag;
                                                        <span class="cr-tag-chip">
                                                            @t
                                                            <button @onclick="() => RemoveTag(t)">×</button>
                                                        </span>
                                                    }
                                                </div>
                                            }
                                        </div>

                                        <!-- Dietary info -->
                                        <div class="cr-form-group">
                                            <label>Dietary Info</label>
                                            <div class="cr-checkbox-grid">
                                                @foreach (var diet in _dietaryOptions)
                                                {
                                                    var d = diet;
                                                    <label class="cr-checkbox-label">
                                                        <input type="checkbox"
                                                               checked="@_recipe.DietaryInfo.Contains(d)"
                                                               @onchange="(e) => ToggleDietary(d, (bool)(e.Value ?? false))" />
                                                        @d
                                                    </label>
                                                }
                                            </div>
                                        </div>

                                        <!-- Sources -->
                                        <div class="cr-form-group">
                                            <label>Sources</label>
                                            <div class="cr-source-form">
                                                <select class="cr-input cr-source-type" @bind="_newSourceType">
                                                    <option value="Website">Website</option>
                                                    <option value="Book">Book</option>
                                                    <option value="Magazine">Magazine</option>
                                                    <option value="Person">Person</option>
                                                    <option value="Video">Video</option>
                                                    <option value="TVShow">TV Show</option>
                                                    <option value="Other">Other</option>
                                                </select>
                                                <input type="text" class="cr-input" @bind="_newSourceName"
                                                       placeholder="@GetSourceNamePlaceholder()" />
                                                <input type="text" class="cr-input" @bind="_newSourceAuthor"
                                                       placeholder="@GetSourceAuthorPlaceholder()" />
                                                <input type="url" class="cr-input" @bind="_newSourceUrl"
                                                       placeholder="URL (optional)" />
                                                <button class="btn btn-outline btn-sm" @onclick="AddSource"
                                                        disabled="@string.IsNullOrWhiteSpace(_newSourceName)">
                                                    + Add
                                                </button>
                                            </div>
                                            @if (_sources.Any())
                                            {
                                                <div class="cr-source-list">
                                                    @foreach (var src in FilteredSources)
                                                    {
                                                        var source = src;
                                                        <div class="cr-source-item">
                                                            <span class="cr-source-badge">@source.Type</span>
                                                            <span class="cr-source-name">@source.Name</span>
                                                            @if (!string.IsNullOrWhiteSpace(source.Author))
                                                            {
                                                                <span class="cr-source-author">· @source.Author</span>
                                                            }
                                                            @if (!string.IsNullOrWhiteSpace(source.Url))
                                                            {
                                                                <a href="@source.Url" target="_blank" class="cr-source-url">🔗</a>
                                                            }
                                                            <button class="btn btn-sm btn-outline cr-row-delete"
                                                                    @onclick="() => RemoveSource(source)">✕</button>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>

                                        <!-- Recipe image -->
                                        <div class="cr-form-group">
                                            <label>Recipe Image</label>
                                            <div class="cr-image-inputs">
                                                <input type="url" class="cr-input" value="@_recipe.ImageUrl"
                                                       @oninput="OnImageUrlChanged" placeholder="Paste image URL" />
                                                <div class="cr-file-label">
                                                    <span>or upload:</span>
                                                    <InputFile OnChange="OnImageFileSelectedAsync" accept="image/*" class="cr-file-input" />
                                                </div>
                                            </div>
                                            @if (!string.IsNullOrWhiteSpace(_imagePreviewUrl))
                                            {
                                                <div class="cr-image-preview">
                                                    <img src="@_imagePreviewUrl" alt="Recipe preview" />
                                                    <button class="btn btn-sm btn-outline" @onclick="ClearImage">Remove</button>
                                                </div>
                                            }
                                        </div>

                                        <!-- Public toggle -->
                                        <div class="cr-form-group">
                                            <label class="cr-checkbox-label">
                                                <input type="checkbox" @bind="_recipe.IsPublic" />
                                                Make this recipe public
                                            </label>
                                        </div>
                                    </div>
                                }

                            </div>

                            <!-- Right: live preview sidebar -->
                            <div class="cr-preview">
                                <div class="cr-preview-card">
                                    <div class="cr-preview-header">
                                        <span>👁️ Live Preview</span>
                                        @if (_parsed.IsAIParsed)
                                        {
                                            <span class="cr-badge-ai">AI</span>
                                        }
                                    </div>
                                    <div class="cr-preview-body">
                                        @if (string.IsNullOrWhiteSpace(_recipe.Title) && !_recipe.Ingredients.Any() && !_recipe.Steps.Any())
                                        {
                                            <div class="cr-preview-empty">
                                                <p>👨‍🍳 Start filling in details to see your recipe preview here.</p>
                                            </div>
                                        }
                                        else
                                        {
                                            @if (!string.IsNullOrWhiteSpace(_imagePreviewUrl))
                                            {
                                                <img class="cr-preview-img" src="@_imagePreviewUrl" alt="Recipe" />
                                            }
                                            @if (!string.IsNullOrWhiteSpace(_recipe.Title))
                                            {
                                                <h2 class="cr-preview-title">@_recipe.Title</h2>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(_recipe.Description))
                                            {
                                                <p class="cr-preview-desc">@_recipe.Description</p>
                                            }
                                            <div class="cr-preview-meta">
                                                @if (_recipe.PrepTimeMinutes > 0)
                                                {
                                                    <span class="cr-meta-chip">⏱️ @_recipe.PrepTimeMinutes min prep</span>
                                                }
                                                @if (_recipe.CookTimeMinutes > 0)
                                                {
                                                    <span class="cr-meta-chip">🍳 @_recipe.CookTimeMinutes min cook</span>
                                                }
                                                @if (_recipe.PrepTimeMinutes > 0 && _recipe.CookTimeMinutes > 0)
                                                {
                                                    <span class="cr-meta-chip">⏰ @(_recipe.PrepTimeMinutes + _recipe.CookTimeMinutes) min total</span>
                                                }
                                                @if (_recipe.Servings > 0)
                                                {
                                                    <span class="cr-meta-chip">🍴 @_recipe.Servings servings</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(_recipe.Difficulty))
                                                {
                                                    <span class="cr-meta-chip">🎯 @_recipe.Difficulty</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(_recipe.Cuisine))
                                                {
                                                    <span class="cr-meta-chip">🌍 @_recipe.Cuisine</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(_recipe.Category))
                                                {
                                                    <span class="cr-meta-chip">🏷️ @_recipe.Category</span>
                                                }
                                            </div>

                                            @if (_recipe.Ingredients.Any())
                                            {
                                                <div class="cr-preview-section">
                                                    <h3>Ingredients (@_recipe.Ingredients.Count)</h3>
                                                    <ul class="cr-preview-ingredients">
                                                        @foreach (var ing in _recipe.Ingredients)
                                                        {
                                                            <li>
                                                                @if (ing.Quantity > 0)
                                                                {
                                                                    <span class="cr-ing-qty">@FormatQuantity(ing.Quantity) @ing.Unit</span>
                                                                }
                                                                <span>@ing.Name</span>
                                                                @if (!string.IsNullOrWhiteSpace(ing.Notes))
                                                                {
                                                                    <span class="cr-ing-notes">, @ing.Notes</span>
                                                                }
                                                            </li>
                                                        }
                                                    </ul>
                                                </div>
                                            }

                                            @if (_recipe.Steps.Any())
                                            {
                                                <div class="cr-preview-section">
                                                    <h3>Instructions (@_recipe.Steps.Count)</h3>
                                                    <ol class="cr-preview-steps">
                                                        @foreach (var step in _recipe.Steps)
                                                        {
                                                            <li>@step.Instruction</li>
                                                        }
                                                    </ol>
                                                </div>
                                            }

                                            @if (_recipe.DietaryInfo.Any())
                                            {
                                                <div class="cr-preview-section">
                                                    <h3>Dietary</h3>
                                                    <div class="cr-preview-dietary">
                                                        @foreach (var d in _recipe.DietaryInfo)
                                                        {
                                                            <span class="cr-badge-diet">@d</span>
                                                        }
                                                    </div>
                                                </div>
                                            }

                                            @if (_recipe.Tags.Any())
                                            {
                                                <div class="cr-preview-section">
                                                    <h3>Tags</h3>
                                                    <div class="cr-preview-tags">
                                                        @foreach (var tag in _recipe.Tags)
                                                        {
                                                            <span class="cr-meta-chip">@tag</span>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        }
                                    </div>
                                </div>
                            </div>

                        </div>
                    }

                </div>

                <!-- Bottom navigation bar -->
                <div class="cr-nav">
                    <div class="cr-nav-left">
                        @if (_currentStep > 1)
                        {
                            <button class="btn btn-outline" @onclick="() => _currentStep--">← Back</button>
                        }
                    </div>
                    <div class="cr-nav-right">
                        @if (_currentStep < 5)
                        {
                            <button class="btn btn-primary"
                                    @onclick="() => _currentStep++"
                                    disabled="@((_currentStep == 1 && !IsStep1Ready()) || (_currentStep == 2 && string.IsNullOrWhiteSpace(_recipe.Title)))">
                                Next →
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-secondary" @onclick="SaveDraftAsync" disabled="@_isSaving">
                                💾 Save Draft
                            </button>
                            <button class="btn btn-primary"
                                    @onclick="PublishRecipeAsync"
                                    disabled="@(!IsValid() || _isSaving)">
                                @if (_isSaving)
                                {
                                    <span class="cr-spinner-sm"></span>
                                }
                                @if (_isEditMode)
                                {
                                    <span>💾 Save Changes</span>
                                }
                                else
                                {
                                    <span>✅ Publish Recipe</span>
                                }
                            </button>
                        }
                    </div>
                </div>
            }

        </div>
    </Authorized>
    <NotAuthorized>
        <div class="cr-unauthorized">
            <h2>🔒 Sign In Required</h2>
            <p>You must be signed in to create or edit recipes.</p>
            <a class="btn btn-primary" href="/login">Sign In</a>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private int _currentStep = 1;
    private bool IsStep1Ready() => !string.IsNullOrWhiteSpace(_recipeText) || !string.IsNullOrWhiteSpace(_recipe.Title);

    [Parameter] public Guid? RecipeId { get; set; }

    private bool _isEditMode => RecipeId.HasValue;
    private string DraftKey => _isEditMode ? $"recipe_draft_edit_{RecipeId}" : "recipe_draft_create";
    private string ConfidenceLabel =>
        _parseConfidence >= 80 ? $"{_parseConfidence:0}% confident" :
        _parseConfidence >= 50 ? "Estimated - please verify" :
        "Basic parse - please review";

    private bool _isLoading = false;
    private bool _isSaving = false;
    private bool _isParsing = false;
    private string? _parseStatus = null;
    private double _parseConfidence = 0;
    private string? _errorMessage = null;
    private string? _draftSavedAt = null;
    private bool _showDraftRestoreBanner = false;
    private string? _draftRestoreTime = null;
    private bool _afterRenderInitialized = false;
    private bool _hasChangedSinceLastSave = false;
    private HashSet<string> _userEditedFields = new();
    private System.Timers.Timer? _debounceTimer;
    private System.Timers.Timer? _autoSaveTimer;

    private string _recipeText = string.Empty;
    private ParsedRecipeResult _parsed = new();
    private CreateRecipeRequest _recipe = new()
    {
        Title = string.Empty,
        Description = string.Empty,
        PrepTimeMinutes = 0,
        CookTimeMinutes = 0,
        Servings = 4,
        Difficulty = "Medium",
        Ingredients = new(),
        Steps = new(),
        Tags = new(),
        DietaryInfo = new(),
        IsPublic = true
    };

    private string _tagsInput = string.Empty;
    private static readonly string[] _dietaryOptions =
        { "Vegetarian", "Vegan", "Gluten-Free", "Dairy-Free", "Keto", "Paleo", "Low-Carb", "Low-Fat" };
    private static readonly string[] _categoryOptions =
