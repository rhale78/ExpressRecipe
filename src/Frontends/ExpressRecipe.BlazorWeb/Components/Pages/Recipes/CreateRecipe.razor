    protected override async Task OnInitializedAsync()
    {
        if (_isEditMode) { _currentStep = 2; await LoadExistingRecipeAsync(); }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_afterRenderInitialized)
        {
            _afterRenderInitialized = true;
            await CheckForDraftAsync();
            InitializeTimers();
        }
    }

    public void Dispose()
    {
        _debounceTimer?.Stop(); _debounceTimer?.Dispose();
        _autoSaveTimer?.Stop(); _autoSaveTimer?.Dispose();
    }

    private void InitializeTimers()
    {
        _debounceTimer = new System.Timers.Timer(500) { AutoReset = false };
        _debounceTimer.Elapsed += async (sender, e) =>
        {
            try { await InvokeAsync(() => { RunRegexParse(); StateHasChanged(); }); }
            catch (ObjectDisposedException) { }
        };
        _autoSaveTimer = new System.Timers.Timer(30_000) { AutoReset = true };
        _autoSaveTimer.Elapsed += async (sender, e) =>
        {
            try
            {
                if (_hasChangedSinceLastSave)
                    await InvokeAsync(async () => { await SaveDraftAsync(); StateHasChanged(); });
            }
            catch (ObjectDisposedException) { }
        };
        _autoSaveTimer.Start();
    }

    private async Task LoadExistingRecipeAsync()
    {
        _isLoading = true;
        try
        {
            var existing = await RecipeApi.GetRecipeAsync(RecipeId!.Value);
            if (existing != null)
            {
                _recipe.Title = existing.Title;
                _recipe.Description = existing.Description;
                _recipe.ImageUrl = existing.ImageUrl;
                _recipe.PrepTimeMinutes = existing.PrepTimeMinutes;
                _recipe.CookTimeMinutes = existing.CookTimeMinutes;
                _recipe.Servings = existing.Servings;
                _recipe.Difficulty = existing.Difficulty;
                _recipe.Source = existing.Source;
                _recipe.SourceUrl = existing.SourceUrl;
                _recipe.Cuisine = existing.Cuisine;
                _recipe.Category = existing.Category;
                _recipe.Tags = new List<string>(existing.Tags);
                _recipe.DietaryInfo = new List<string>(existing.DietaryInfo);
                _recipe.IsPublic = existing.IsPublic;
                _recipe.Ingredients = existing.Ingredients.Select(i => new CreateRecipeIngredientRequest
                {
                    OrderIndex = i.OrderIndex, Name = i.Name, Quantity = i.Quantity,
                    Unit = i.Unit, Notes = i.Notes, IsOptional = i.IsOptional, GroupName = i.GroupName
                }).ToList();
                _recipe.Steps = existing.Steps.Select(s => new CreateRecipeStepRequest
                {
                    OrderIndex = s.OrderIndex, Instruction = s.Instruction,
                    DurationMinutes = s.DurationMinutes, Tips = s.Tips
                }).ToList();
                _tagsInput = string.Join(", ", _recipe.Tags);
                _imagePreviewUrl = _recipe.ImageUrl;
            }
        }
        catch (Exception ex) { _errorMessage = $"Failed to load recipe: {ex.Message}"; }
        finally { _isLoading = false; }
    }

    private async Task CheckForDraftAsync()
    {
        try
        {
            var draft = await LocalStorage.GetItemAsync<RecipeDraftData>(DraftKey);
            if (draft != null && !string.IsNullOrWhiteSpace(draft.RecipeText))
            {
                _showDraftRestoreBanner = true;
                _draftRestoreTime = FormatTimeAgo(DateTime.UtcNow - draft.SavedAt);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch { }
    }

    private async Task RestoreDraftAsync()
    {
        try
        {
            var draft = await LocalStorage.GetItemAsync<RecipeDraftData>(DraftKey);
            if (draft != null)
            {
                _recipeText = draft.RecipeText;
                if (draft.RecipeData != null)
                {
                    var d = draft.RecipeData;
                    _recipe.Title = d.Title; _recipe.Description = d.Description;
                    _recipe.PrepTimeMinutes = d.PrepTimeMinutes; _recipe.CookTimeMinutes = d.CookTimeMinutes;
                    _recipe.Servings = d.Servings; _recipe.Difficulty = d.Difficulty;
                    _recipe.Cuisine = d.Cuisine; _recipe.Category = d.Category;
                    _recipe.DietaryInfo = new List<string>(d.DietaryInfo);
                    _recipe.Tags = new List<string>(d.Tags);
                    _recipe.IsPublic = d.IsPublic; _recipe.ImageUrl = d.ImageUrl;
                    _imagePreviewUrl = _recipe.ImageUrl;
                    _tagsInput = string.Join(", ", _recipe.Tags);
                }
                if (draft.Sources != null)
                    _sources = draft.Sources.Select(s => new SourceEntry
                    {
                        Id = s.Id, Type = s.Type, Name = s.Name,
                        Url = s.Url, Author = s.Author, Notes = s.Notes
                    }).ToList();
                RunRegexParse();
            }
        }
        catch (Exception ex) { _errorMessage = $"Failed to restore draft: {ex.Message}"; }
        _showDraftRestoreBanner = false;
    }

    private void DismissDraft() => _showDraftRestoreBanner = false;

    private async Task SaveDraftAsync()
    {
        try
        {
            var draft = new RecipeDraftData
            {
                RecipeText = _recipeText, SavedAt = DateTime.UtcNow,
                RecipeData = new CreateRecipeRequest
                {
                    Title = _recipe.Title, Description = _recipe.Description,
