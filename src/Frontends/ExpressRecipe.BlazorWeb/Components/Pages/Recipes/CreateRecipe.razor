    private void ParseTagsFromInput()
    {
        _recipe.Tags = _tagsInput.Split(',').Select(t => t.Trim())
            .Where(t => !string.IsNullOrEmpty(t)).Distinct().ToList();
    }

    private void AddIngredient()
    {
        _recipe.Ingredients.Add(new CreateRecipeIngredientRequest { OrderIndex = _recipe.Ingredients.Count + 1 });
        _hasChangedSinceLastSave = true;
    }

    private void RemoveIngredient(CreateRecipeIngredientRequest ing)
    {
        _recipe.Ingredients.Remove(ing);
        for (int i = 0; i < _recipe.Ingredients.Count; i++)
            _recipe.Ingredients[i].OrderIndex = i + 1;
        _hasChangedSinceLastSave = true;
    }

    private void OnIngredientFieldChanged(CreateRecipeIngredientRequest ing, string field, string? value)
    {
        switch (field)
        {
            case "unit":  ing.Unit  = value ?? string.Empty; break;
            case "name":  ing.Name  = value ?? string.Empty; break;
            case "notes": ing.Notes = value;                 break;
        }
        _hasChangedSinceLastSave = true;
    }

    private void AddStep()
    {
        _recipe.Steps.Add(new CreateRecipeStepRequest { OrderIndex = _recipe.Steps.Count + 1 });
        _hasChangedSinceLastSave = true;
    }

    private void RemoveStep(CreateRecipeStepRequest step)
    {
        _recipe.Steps.Remove(step);
        for (int i = 0; i < _recipe.Steps.Count; i++)
            _recipe.Steps[i].OrderIndex = i + 1;
        _hasChangedSinceLastSave = true;
    }

    private void OnStepInstructionChanged(CreateRecipeStepRequest step, string? value)
    {
        step.Instruction = value ?? string.Empty;
        _hasChangedSinceLastSave = true;
    }

    private void RemoveTag(string tag)
    { _recipe.Tags.Remove(tag); _tagsInput = string.Join(", ", _recipe.Tags); _hasChangedSinceLastSave = true; }

    private void ToggleDietary(string diet, bool isChecked)
    {
        if (isChecked && !_recipe.DietaryInfo.Contains(diet)) _recipe.DietaryInfo.Add(diet);
        else if (!isChecked) _recipe.DietaryInfo.Remove(diet);
        _userEditedFields.Add("dietaryInfo"); _hasChangedSinceLastSave = true;
    }

    private void OnImageUrlChanged(ChangeEventArgs e)
    { _recipe.ImageUrl = e.Value?.ToString(); _imagePreviewUrl = _recipe.ImageUrl; _hasChangedSinceLastSave = true; }

    private async Task OnImageFileSelectedAsync(InputFileChangeEventArgs e)
    {
        const long maxSize = 5 * 1024 * 1024;
        if (e.File.Size > maxSize) { _errorMessage = "Image too large (max 5 MB)."; return; }
        try
        {
            using var stream = e.File.OpenReadStream(maxSize);
            using var ms = new System.IO.MemoryStream();
            await stream.CopyToAsync(ms);
            var dataUrl = $"data:{e.File.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
            _recipe.ImageUrl = dataUrl; _imagePreviewUrl = dataUrl; _hasChangedSinceLastSave = true;
        }
        catch (Exception ex) { _errorMessage = $"Failed to load image: {ex.Message}"; }
    }

    private void ClearImage()
    { _recipe.ImageUrl = null; _imagePreviewUrl = null; _hasChangedSinceLastSave = true; }

    private void AddSource()
    {
        if (string.IsNullOrWhiteSpace(_newSourceName)) return;
        _sources.Add(new SourceEntry
        {
            Type   = _newSourceType,
            Name   = _newSourceName,
            Url    = string.IsNullOrWhiteSpace(_newSourceUrl)    ? null : _newSourceUrl,
            Author = string.IsNullOrWhiteSpace(_newSourceAuthor) ? null : _newSourceAuthor,
            Notes  = string.IsNullOrWhiteSpace(_newSourceNotes)  ? null : _newSourceNotes
        });
        _newSourceName = _newSourceUrl = _newSourceAuthor = _newSourceNotes = string.Empty;
        _hasChangedSinceLastSave = true;
    }

    private void RemoveSource(SourceEntry src)
    { _sources.Remove(src); _hasChangedSinceLastSave = true; }

    private string GetSourceNamePlaceholder() => _newSourceType switch
    {
        "Book"     => "Book title",
        "Person"   => "Person name",
        "Video"    => "Video title",
        "TVShow"   => "Show name",
        "Magazine" => "Publication name",
        _          => "Source name"
    };

    private string GetSourceAuthorPlaceholder() => _newSourceType switch
    {
        "Book"     => "Author name",
        "Person"   => "Relationship (e.g., Grandma)",
        "Magazine" => "Issue / date",
        _          => "Author"
    };

    private bool IsValid() =>
        !string.IsNullOrWhiteSpace(_recipe.Title) &&
        _recipe.PrepTimeMinutes >= 0 &&
        _recipe.CookTimeMinutes >= 0 &&
        _recipe.Servings > 0;

    private async Task PublishRecipeAsync()
    {
        _isSaving = true; _errorMessage = null;
        ParseTagsFromInput();
        try
        {
            Guid? resultId;
            if (_isEditMode)
            {
                var upd = new UpdateRecipeRequest
                {
                    Title = _recipe.Title, Description = _recipe.Description,
                    Difficulty = _recipe.Difficulty,
                    PrepTimeMinutes = _recipe.PrepTimeMinutes,
                    CookTimeMinutes = _recipe.CookTimeMinutes,
                    Servings = _recipe.Servings,
                    ImageUrl = _recipe.ImageUrl,
                    Source = _recipe.Source, SourceUrl = _recipe.SourceUrl,
                    Cuisine = _recipe.Cuisine, Category = _recipe.Category,
                    Ingredients = _recipe.Ingredients, Steps = _recipe.Steps,
                    Tags = _recipe.Tags, DietaryInfo = _recipe.DietaryInfo,
                    Nutrition = _recipe.Nutrition, IsPublic = _recipe.IsPublic
                };
                var ok = await RecipeApi.UpdateRecipeAsync(RecipeId!.Value, upd);
                resultId = ok ? RecipeId : null;
            }
            else
            {
                resultId = await RecipeApi.CreateRecipeAsync(_recipe);
            }
            if (resultId.HasValue)
            {
                try { await LocalStorage.RemoveItemAsync(DraftKey); } catch { }
                Navigation.NavigateTo($"/recipes/{resultId.Value}");
            }
            else
            {
                _errorMessage = $"Failed to {(_isEditMode ? "update" : "create")} recipe. Please try again.";
            }
        }
        catch (Exception ex) { _errorMessage = $"Failed to save recipe: {ex.Message}"; }
        finally { _isSaving = false; }
    }

    private void GoBack()
    {
        if (_isEditMode) Navigation.NavigateTo($"/recipes/{RecipeId}");
        else Navigation.NavigateTo("/recipes");
    }

    private void ClearError() => _errorMessage = null;

    private static string FormatQuantity(decimal qty)
    {
        if (qty == Math.Floor(qty)) return ((int)qty).ToString();
        return qty.ToString("G4", System.Globalization.CultureInfo.InvariantCulture);
    }

    private static string FormatTimeAgo(TimeSpan age)
    {
        if (age.TotalSeconds < 10) return "just now";
        if (age.TotalMinutes < 1)  return $"{(int)age.TotalSeconds}s ago";
        if (age.TotalHours   < 1)  return $"{(int)age.TotalMinutes}m ago";
        if (age.TotalDays    < 1)  return $"{(int)age.TotalHours}h ago";
        return $"{(int)age.TotalDays}d ago";
    }

    public class SourceEntry
    {
        public Guid    Id     { get; set; } = Guid.NewGuid();
        public string  Type   { get; set; } = "Website";
        public string  Name   { get; set; } = string.Empty;
        public string? Url    { get; set; }
        public string? Author { get; set; }
        public string? Notes  { get; set; }
    }

    public class UnitSuggestion
    {
        public string Original  { get; set; } = string.Empty;
        public string Suggested { get; set; } = string.Empty;
        public string Context   { get; set; } = string.Empty;
    }
