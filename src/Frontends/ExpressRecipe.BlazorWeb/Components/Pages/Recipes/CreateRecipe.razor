    private async Task OnImageFileSelectedAsync(InputFileChangeEventArgs e)
    {
        const long maxSize = 5 * 1024 * 1024;
        if (e.File.Size > maxSize) { _errorMessage = "Image too large (max 5 MB)."; return; }
        try
        {
            using var stream = e.File.OpenReadStream(maxSize);
            using var ms = new System.IO.MemoryStream();
            await stream.CopyToAsync(ms);
            var dataUrl = $"data:{e.File.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
            _recipe.ImageUrl = dataUrl; _imagePreviewUrl = dataUrl; _hasChangedSinceLastSave = true;
        }
        catch (Exception ex) { _errorMessage = $"Failed to load image: {ex.Message}"; }
    }

