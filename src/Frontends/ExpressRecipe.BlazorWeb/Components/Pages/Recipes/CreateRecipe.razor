    private void OnRecipeTextChanged(ChangeEventArgs e)
    {
        _recipeText = e.Value?.ToString() ?? string.Empty;
        _hasChangedSinceLastSave = true;
        _debounceTimer?.Stop();
        _debounceTimer?.Start();
