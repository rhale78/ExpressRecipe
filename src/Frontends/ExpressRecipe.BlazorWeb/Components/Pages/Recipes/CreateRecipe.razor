    private void ParseWithRegexManual() => RunRegexParse();

    private void RunRegexParse()
    {
        if (string.IsNullOrWhiteSpace(_recipeText)) return;
        _parsed = ParseRecipeFromText(_recipeText);
        _parseStatus = "regex";
        _parseConfidence = _parsed.Confidence;
        ApplyParsedToForm(_parsed);
        _unitSuggestions = AnalyzeUnitSuggestions(_parsed.Ingredients);
    }

    private async Task ParseWithAIAsync()
    {
        if (string.IsNullOrWhiteSpace(_recipeText)) return;
        _isParsing = true; _errorMessage = null; StateHasChanged();
        try
        {
            var result = await AIApi.ExtractRecipeAsync(new RecipeExtractionRequest { RecipeText = _recipeText });
            if (result != null)
            {
                _parsed = ConvertExtractedToParseResult(result);
                _parsed.IsAIParsed = true;
                _parseStatus = "ai";
                _parseConfidence = result.ConfidenceScore * 100;
                ApplyParsedToForm(_parsed);
                _unitSuggestions = AnalyzeUnitSuggestions(_parsed.Ingredients);
            }
            else
            {
                RunRegexParse(); _parseStatus = "ai-fallback";
            }
        }
        catch { RunRegexParse(); _parseStatus = "ai-fallback"; }
        finally { _isParsing = false; }
    }

    private static ParsedRecipeResult ConvertExtractedToParseResult(ExtractedRecipeDto e)
    {
        var r = new ParsedRecipeResult
        {
            Title = e.Title, Description = e.Description,
            PrepTimeMinutes = e.PrepTimeMinutes, CookTimeMinutes = e.CookTimeMinutes,
            Servings = e.Servings,
            Difficulty = string.IsNullOrWhiteSpace(e.Difficulty) ? "Medium" : e.Difficulty,
            DietaryInfo = new List<string>(e.DietaryInfo),
            IsAIParsed = true, Confidence = e.ConfidenceScore * 100
        };
        int idx = 1;
        foreach (var ing in e.Ingredients)
        {
            decimal.TryParse(ing.Quantity, System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var qty);
            r.Ingredients.Add(new CreateRecipeIngredientRequest
            {
                OrderIndex = idx++, Name = ing.Name, Quantity = qty, Unit = ing.Unit, Notes = ing.Notes
            });
        }
        for (int i = 0; i < e.Instructions.Count; i++)
            r.Steps.Add(new CreateRecipeStepRequest { OrderIndex = i + 1, Instruction = e.Instructions[i] });
        return r;
    }

    private void ApplyParsedToForm(ParsedRecipeResult p)
    {
        if (!_userEditedFields.Contains("title") && !string.IsNullOrWhiteSpace(p.Title))
            _recipe.Title = p.Title;
        if (!_userEditedFields.Contains("description") && !string.IsNullOrWhiteSpace(p.Description))
            _recipe.Description = p.Description;
        if (!_userEditedFields.Contains("prepTime") && p.PrepTimeMinutes > 0)
            _recipe.PrepTimeMinutes = p.PrepTimeMinutes;
        if (!_userEditedFields.Contains("cookTime") && p.CookTimeMinutes > 0)
            _recipe.CookTimeMinutes = p.CookTimeMinutes;
        if (!_userEditedFields.Contains("servings") && p.Servings > 0)
            _recipe.Servings = p.Servings;
        if (!_userEditedFields.Contains("difficulty"))
            _recipe.Difficulty = p.Difficulty;
        if (!_userEditedFields.Contains("cuisine") && p.Cuisine != null)
            _recipe.Cuisine = p.Cuisine;
        if (!_userEditedFields.Contains("category") && p.Category != null)
            _recipe.Category = p.Category;
        if (!_userEditedFields.Contains("dietaryInfo") && p.DietaryInfo.Any())
            _recipe.DietaryInfo = new List<string>(p.DietaryInfo);
        if (!_userEditedFields.Contains("tags") && p.Tags.Any())
        {
            _recipe.Tags = new List<string>(p.Tags);
            _tagsInput = string.Join(", ", _recipe.Tags);
        }
        _recipe.Ingredients = new List<CreateRecipeIngredientRequest>(p.Ingredients);
        _recipe.Steps = new List<CreateRecipeStepRequest>(p.Steps);
    }

    private static ParsedRecipeResult ParseRecipeFromText(string text)
    {
        var result = new ParsedRecipeResult();
        if (string.IsNullOrWhiteSpace(text)) return result;

        var allLines = text.Split('\n').Select(l => l.Trim()).ToArray();
        var nonEmpty = allLines.Where(l => l.Length > 0).ToArray();
        if (nonEmpty.Length == 0) return result;

        result.Title = nonEmpty[0];

        var servMatch = Regex.Match(text, @"(?:serves|makes|yields|servings?)\s*:?\s*(\d+)", RegexOptions.IgnoreCase);
        if (servMatch.Success && int.TryParse(servMatch.Groups[1].Value, out var serv))
            result.Servings = serv;

        var prepMatch = Regex.Match(text, @"prep(?:\s*time)?\s*:?\s*(\d+)\s*(?:min(?:utes?)?|hr?s?)", RegexOptions.IgnoreCase);
        if (prepMatch.Success && int.TryParse(prepMatch.Groups[1].Value, out var prepVal))
            result.PrepTimeMinutes = prepVal;
        else
        {
            var altPrep = Regex.Match(text, @"(\d+)\s*min(?:utes?)?\s+prep", RegexOptions.IgnoreCase);
            if (altPrep.Success && int.TryParse(altPrep.Groups[1].Value, out var ap))
                result.PrepTimeMinutes = ap;
        }

        var cookMatch = Regex.Match(text, @"(?:cook|bake)(?:\s*time)?\s*:?\s*(\d+)\s*(?:min(?:utes?)?|hr?s?)", RegexOptions.IgnoreCase);
        if (cookMatch.Success && int.TryParse(cookMatch.Groups[1].Value, out var cookVal))
            result.CookTimeMinutes = cookVal;
        else
        {
            var altCook = Regex.Match(text, @"(\d+)\s*min(?:utes?)?\s+cook", RegexOptions.IgnoreCase);
            if (altCook.Success && int.TryParse(altCook.Groups[1].Value, out var ac))
                result.CookTimeMinutes = ac;
        }

        if (Regex.IsMatch(text, @"\b(?:easy|simple|beginner)\b", RegexOptions.IgnoreCase))
            result.Difficulty = "Easy";
        else if (Regex.IsMatch(text, @"\b(?:advanced|difficult|hard|complex|challenging)\b", RegexOptions.IgnoreCase))
            result.Difficulty = "Hard";

        var cuisines = new[] { "Italian", "Mexican", "Chinese", "Indian", "French", "American", "Japanese", "Mediterranean", "Thai", "Greek" };
        foreach (var cui in cuisines)
        {
            if (Regex.IsMatch(text, $@"\b{cui}\b", RegexOptions.IgnoreCase))
            { result.Cuisine = cui; break; }
        }

        var categoryMap = new (string Cat, string[] Kw)[]
        {
            ("Dessert",     new[] { "dessert", "cake", "cookie", "brownie", "pie", "tart", "pudding" }),
            ("Soup",        new[] { "soup", "stew", "chowder", "bisque" }),
            ("Salad",       new[] { "salad" }),
            ("Bread",       new[] { "bread", "roll", "bun", "loaf", "muffin" }),
            ("Breakfast",   new[] { "breakfast", "brunch", "pancake", "waffle" }),
            ("Drinks",      new[] { "smoothie", "juice", "cocktail", "drink", "beverage" }),
            ("Appetizer",   new[] { "appetizer", "starter", "dip" }),
            ("Main Course", new[] { "main course", "entree" }),
            ("Snack",       new[] { "snack", "chips" })
        };
        foreach (var (cat, kws) in categoryMap)
        {
            if (kws.Any(k => text.Contains(k, StringComparison.OrdinalIgnoreCase)))
            { result.Category = cat; break; }
        }

        var dietMap = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            ["Vegetarian"] = @"\bvegetarian\b",
            ["Vegan"]      = @"\bvegan\b",
            ["Gluten-Free"]= @"\bgluten[- ]free\b",
            ["Dairy-Free"] = @"\bdairy[- ]free\b",
            ["Keto"]       = @"\bketo\b",
            ["Paleo"]      = @"\bpaleo\b",
            ["Low-Carb"]   = @"\blow[- ]carb\b",
            ["Low-Fat"]    = @"\blow[- ]fat\b"
        };
        foreach (var (diet, pattern) in dietMap)
            if (Regex.IsMatch(text, pattern, RegexOptions.IgnoreCase))
                result.DietaryInfo.Add(diet);

        var section = "none";
        var numberedLine = new Regex(@"^\d+[\.)\-]\s+(.+)$");
        var ingHeader    = new Regex(@"^ingredients?:?\s*$", RegexOptions.IgnoreCase);
        var stepHeader   = new Regex(@"^(?:instructions?|directions?|steps?|method):?\s*$", RegexOptions.IgnoreCase);
        int stepIdx = 1, ingIdx = 1;

        for (int i = 1; i < allLines.Length; i++)
        {
            var line = allLines[i];
            if (string.IsNullOrWhiteSpace(line)) continue;
            if (ingHeader.IsMatch(line))  { section = "ingredients"; continue; }
            if (stepHeader.IsMatch(line)) { section = "steps";       continue; }

            if (section == "ingredients")
            {
                var ing = TryParseIngredientLine(line);
                if (ing != null) { ing.OrderIndex = ingIdx++; result.Ingredients.Add(ing); }
            }
            else if (section == "steps")
            {
                var nm = numberedLine.Match(line);
                result.Steps.Add(new CreateRecipeStepRequest
                {
                    OrderIndex = stepIdx++,
                    Instruction = nm.Success ? nm.Groups[1].Value.Trim() : line
                });
            }
            else
            {
                var ing = TryParseIngredientLine(line);
                if (ing != null) { ing.OrderIndex = ingIdx++; result.Ingredients.Add(ing); }
                else
                {
                    var nm = numberedLine.Match(line);
                    if (nm.Success)
                        result.Steps.Add(new CreateRecipeStepRequest
                        { OrderIndex = stepIdx++, Instruction = nm.Groups[1].Value.Trim() });
                }
            }
        }
        result.Confidence = CalculateConfidence(result);
        return result;
    }

    private static CreateRecipeIngredientRequest? TryParseIngredientLine(string line)
    {
        var match = Regex.Match(line, @"^(\d+\s+\d+/\d+|\d+[./]\d+|\d+)\s+([a-zA-Z]+\.?)\s+(.+)$");
        if (!match.Success) return null;
        var unit = match.Groups[2].Value.TrimEnd('.');
        var name = match.Groups[3].Value.Trim();
        var knownUnits = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            "cup","cups","tsp","tbsp","oz","lb","lbs","g","kg","ml","l",
            "teaspoon","teaspoons","tablespoon","tablespoons","ounce","ounces",
            "pound","pounds","gram","grams","clove","cloves","large","medium",
            "small","pinch","dash","can","cans","package","packages",
            "stick","sticks","bunch","bunches","slice","slices","piece","pieces",
            "sprig","sprigs","head","heads","sheet","sheets"
        };
        if (!knownUnits.Contains(unit)) return null;
        if (!TryParseFractionQuantity(match.Groups[1].Value.Trim(), out var qty)) return null;
        string? notes = null;
        var commaIdx = name.IndexOf(',');
        if (commaIdx > 0)
        { notes = name[(commaIdx + 1)..].Trim(); name = name[..commaIdx].Trim(); }
        var notesMatch = Regex.Match(name, @"\s*\((.+)\)\s*$");
        if (notesMatch.Success)
        { notes ??= notesMatch.Groups[1].Value; name = name[..notesMatch.Index].Trim(); }
        return new CreateRecipeIngredientRequest { Name = name, Quantity = qty, Unit = unit, Notes = notes };
    }

    private static bool TryParseFractionQuantity(string s, out decimal result)
    {
        result = 0;
        if (decimal.TryParse(s, System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.InvariantCulture, out result)) return true;
        var frac = Regex.Match(s, @"^(\d+)/(\d+)$");
        if (frac.Success &&
            decimal.TryParse(frac.Groups[1].Value, out var fn) &&
            decimal.TryParse(frac.Groups[2].Value, out var fd))
        {
            if (fd == 0) return false;
            result = fn / fd;
            return true;
        }
        var mixed = Regex.Match(s, @"^(\d+)\s+(\d+)/(\d+)$");
        if (mixed.Success &&
            decimal.TryParse(mixed.Groups[1].Value, out var mw) &&
            decimal.TryParse(mixed.Groups[2].Value, out var mn) &&
            decimal.TryParse(mixed.Groups[3].Value, out var md))
        {
            if (md == 0) return false;
            result = mw + mn / md;
            return true;
        }
        return false;
    }

    private static double CalculateConfidence(ParsedRecipeResult r)
    {
        double s = 0;
        if (!string.IsNullOrWhiteSpace(r.Title)) s += 20;
        if (r.Ingredients.Count > 0) s += 30;
        if (r.Steps.Count > 0) s += 30;
        if (r.PrepTimeMinutes > 0 || r.CookTimeMinutes > 0) s += 10;
        if (r.Servings > 1) s += 10;
        return s;
    }

    private static List<UnitSuggestion> AnalyzeUnitSuggestions(List<CreateRecipeIngredientRequest> ingredients)
    {
        var suggestions = new List<UnitSuggestion>();
        var map = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            ["tbs"] = "tbsp", ["T"] = "tbsp",
            ["cp"]  = "cup",  ["c."] = "cup",
            ["oz."] = "oz",   ["tsp."] = "tsp"
        };
        foreach (var ing in ingredients)
            if (map.TryGetValue(ing.Unit, out var suggested))
                suggestions.Add(new UnitSuggestion
                { Original = ing.Unit, Suggested = suggested,
                  Context = $"{FormatQuantity(ing.Quantity)} {ing.Unit} {ing.Name}" });
        return suggestions;
    }

    private void AcceptSuggestion(UnitSuggestion s)
    {
        foreach (var ing in _recipe.Ingredients.Where(i =>
            string.Equals(i.Unit, s.Original, StringComparison.OrdinalIgnoreCase)))
            ing.Unit = s.Suggested;
        foreach (var ing in _parsed.Ingredients.Where(i =>
            string.Equals(i.Unit, s.Original, StringComparison.OrdinalIgnoreCase)))
            ing.Unit = s.Suggested;
        _unitSuggestions.Remove(s);
    }

    private void DismissSuggestion(UnitSuggestion s) => _unitSuggestions.Remove(s);

