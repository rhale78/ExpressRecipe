@using ExpressRecipe.Client.Shared.Services
@using ExpressRecipe.Client.Shared.Models.Inventory
@inject InventoryApiClient InventoryClient
@inject IJSRuntime JS

<div class="storage-location-selector">
    @if (_isLoading)
    {
        <div class="spinner-border spinner-border-sm" role="status">
            <span class="visually-hidden">Loading storage locations...</span>
        </div>
    }
    else if (_locations != null && _locations.Any())
    {
        <div class="d-flex gap-2 align-items-center">
            <div class="dropdown flex-grow-1">
                <button class="btn btn-outline-secondary dropdown-toggle w-100" type="button" id="locationDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                    @if (_selectedLocation != null)
                    {
                        <i class="@GetLocationIcon(_selectedLocation.LocationType)"></i>
                        <span>@_selectedLocation.Name</span>
                    }
                    else
                    {
                        <i class="bi bi-box"></i>
                        <span>Select Storage Location</span>
                    }
                </button>
                <ul class="dropdown-menu w-100" aria-labelledby="locationDropdown">
                    @foreach (var location in _locations)
                    {
                        <li>
                            <a class="dropdown-item @(location.Id == _selectedLocation?.Id ? "active" : "")" href="#" @onclick="() => SelectLocation(location)" @onclick:preventDefault>
                                <div class="d-flex align-items-center">
                                    <i class="@GetLocationIcon(location.LocationType) me-2"></i>
                                    <div class="flex-grow-1">
                                        <div>@location.Name</div>
                                        @if (!string.IsNullOrEmpty(location.Description))
                                        {
                                            <small class="text-muted d-block">@location.Description</small>
                                        }
                                    </div>
                                    <span class="badge bg-secondary">@location.LocationType</span>
                                </div>
                            </a>
                        </li>
                    }
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <a class="dropdown-item" href="#" @onclick="ShowAddLocationModal" @onclick:preventDefault>
                            <i class="bi bi-plus-circle"></i> Add New Location
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    }
    else if (AddressId.HasValue)
    {
        <div class="text-center py-3">
            <p class="text-muted mb-2">No storage locations added yet</p>
            <button class="btn btn-primary btn-sm" @onclick="ShowAddLocationModal">
                <i class="bi bi-plus-circle"></i> Add Location
            </button>
        </div>
    }

    @if (_error != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mt-2" role="alert">
            @_error
            <button type="button" class="btn-close" @onclick="() => _error = null"></button>
        </div>
    }
</div>

<!-- Add Storage Location Modal -->
<div class="modal fade" id="addLocationModal" tabindex="-1" aria-labelledby="addLocationModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addLocationModalLabel">Add Storage Location</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="locationName" class="form-label">Location Name *</label>
                    <input type="text" class="form-control" id="locationName" @bind="_newLocation.Name" placeholder="e.g., Kitchen Pantry, Garage Freezer">
                </div>
                <div class="mb-3">
                    <label for="locationType" class="form-label">Type *</label>
                    <select class="form-select" id="locationType" @bind="_newLocation.LocationType">
                        <option value="">-- Select Type --</option>
                        <option value="Refrigerator">Refrigerator</option>
                        <option value="Freezer">Freezer</option>
                        <option value="Pantry">Pantry</option>
                        <option value="Cabinet">Cabinet</option>
                        <option value="Closet">Closet</option>
                        <option value="Garage">Garage</option>
                        <option value="Basement">Basement</option>
                        <option value="Storage">Storage</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label for="locationDescription" class="form-label">Description (optional)</label>
                    <textarea class="form-control" id="locationDescription" @bind="_newLocation.Description" rows="2" placeholder="Brief description or notes"></textarea>
                </div>
                <div class="mb-3">
                    <label for="locationSubLocation" class="form-label">Sub-Location (optional)</label>
                    <input type="text" class="form-control" id="locationSubLocation" @bind="_newLocation.SubLocation" placeholder="e.g., Top Shelf, Bottom Drawer">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" @onclick="CreateLocation" disabled="@(_isCreating || !IsLocationValid())">
                    @if (_isCreating)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                    }
                    Add Location
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public Guid? AddressId { get; set; }

    [Parameter]
    public EventCallback<StorageLocationDto?> OnLocationChanged { get; set; }

    private List<StorageLocationDto>? _locations;
    private StorageLocationDto? _selectedLocation;
    private bool _isLoading = false;
    private bool _isCreating = false;
    private string? _error;
    private CreateStorageLocationRequest _newLocation = new();

    protected override async Task OnParametersSetAsync()
    {
        if (AddressId.HasValue)
        {
            await LoadLocations();
        }
        else
        {
            _locations = null;
            _selectedLocation = null;
        }
    }

    private async Task LoadLocations()
    {
        if (!AddressId.HasValue)
            return;

        try
        {
            _isLoading = true;
            _error = null;
            _locations = await InventoryClient.GetStorageLocationsAsync(AddressId.Value);
            
            // Auto-select first location if none selected
            if (_locations != null && _locations.Any() && _selectedLocation == null)
            {
                await SelectLocation(_locations.First());
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to load storage locations: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SelectLocation(StorageLocationDto? location)
    {
        _selectedLocation = location;
        await OnLocationChanged.InvokeAsync(location);
    }

    private async Task ShowAddLocationModal()
    {
        _newLocation = new CreateStorageLocationRequest 
        { 
            AddressId = AddressId ?? Guid.Empty,
            LocationType = ""
        };
        await JS.InvokeVoidAsync("eval", "new bootstrap.Modal(document.getElementById('addLocationModal')).show()");
    }

    private async Task CreateLocation()
    {
        if (!IsLocationValid())
            return;

        try
        {
            _isCreating = true;
            _error = null;

            var created = await InventoryClient.CreateStorageLocationAsync(_newLocation);
            
            if (created != null)
            {
                await LoadLocations();
                await SelectLocation(created);
                await JS.InvokeVoidAsync("eval", "bootstrap.Modal.getInstance(document.getElementById('addLocationModal')).hide()");
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to create storage location: {ex.Message}";
        }
        finally
        {
            _isCreating = false;
        }
    }

    private bool IsLocationValid()
    {
        return !string.IsNullOrWhiteSpace(_newLocation.Name)
            && !string.IsNullOrWhiteSpace(_newLocation.LocationType);
    }

    private string GetLocationIcon(string? locationType) => locationType switch
    {
        "Refrigerator" => "bi bi-snow2",
        "Freezer" => "bi bi-snow3",
        "Pantry" => "bi bi-door-closed",
        "Cabinet" => "bi bi-cabinet",
        "Closet" => "bi bi-door-open",
        "Garage" => "bi bi-house-door",
        "Basement" => "bi bi-house",
        "Storage" => "bi bi-box-seam",
        _ => "bi bi-box"
    };
}
