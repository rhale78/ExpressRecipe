@using ExpressRecipe.Client.Shared.Services
@using ExpressRecipe.Client.Shared.Models.Inventory
@inject InventoryApiClient InventoryClient
@inject IJSRuntime JS

<div class="address-selector">
    @if (_isLoading)
    {
        <div class="spinner-border spinner-border-sm" role="status">
            <span class="visually-hidden">Loading addresses...</span>
        </div>
    }
    else if (_addresses != null && _addresses.Any())
    {
        <div class="d-flex gap-2 align-items-center">
            <div class="dropdown flex-grow-1">
                <button class="btn btn-outline-secondary dropdown-toggle w-100" type="button" id="addressDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-geo-alt"></i>
                    @if (_selectedAddress != null)
                    {
                        <span>@_selectedAddress.Street</span>
                        @if (_selectedAddress.DistanceKm.HasValue)
                        {
                            <small class="text-muted ms-2">(@_selectedAddress.DistanceKm.Value.ToString("F1") km)</small>
                        }
                    }
                    else
                    {
                        <span>Select Address</span>
                    }
                </button>
                <ul class="dropdown-menu w-100" aria-labelledby="addressDropdown">
                    @foreach (var address in _addresses)
                    {
                        <li>
                            <a class="dropdown-item @(address.Id == _selectedAddress?.Id ? "active" : "")" href="#" @onclick="() => SelectAddress(address)" @onclick:preventDefault>
                                <div class="d-flex justify-content-between align-items-start">
                                    <div class="flex-grow-1">
                                        <div><i class="bi bi-geo-alt"></i> @address.Street</div>
                                        @if (!string.IsNullOrEmpty(address.Street2))
                                        {
                                            <small class="text-muted d-block">@address.Street2</small>
                                        }
                                        <small class="text-muted d-block">@address.City, @address.State @address.ZipCode</small>
                                    </div>
                                    @if (address.DistanceKm.HasValue)
                                    {
                                        <span class="badge bg-info">@address.DistanceKm.Value.ToString("F1") km</span>
                                    }
                                </div>
                            </a>
                        </li>
                    }
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <a class="dropdown-item" href="#" @onclick="ShowAddAddressModal" @onclick:preventDefault>
                            <i class="bi bi-plus-circle"></i> Add New Address
                        </a>
                    </li>
                </ul>
            </div>

            @if (_canDetectLocation)
            {
                <button class="btn btn-outline-info" @onclick="DetectLocation" disabled="@_isDetecting" title="Detect my current location">
                    @if (_isDetecting)
                    {
                        <span class="spinner-border spinner-border-sm" role="status"></span>
                    }
                    else
                    {
                        <i class="bi bi-crosshair"></i>
                    }
                </button>
            }
        </div>
    }
    else if (HouseholdId.HasValue)
    {
        <div class="text-center py-3">
            <p class="text-muted mb-2">No addresses added yet</p>
            <button class="btn btn-primary" @onclick="ShowAddAddressModal">
                <i class="bi bi-plus-circle"></i> Add Address
            </button>
        </div>
    }

    @if (_error != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mt-2" role="alert">
            @_error
            <button type="button" class="btn-close" @onclick="() => _error = null"></button>
        </div>
    }

    @if (_locationMessage != null)
    {
        <div class="alert alert-info alert-dismissible fade show mt-2" role="alert">
            @_locationMessage
            <button type="button" class="btn-close" @onclick="() => _locationMessage = null"></button>
        </div>
    }
</div>

<!-- Add Address Modal -->
<div class="modal fade" id="addAddressModal" tabindex="-1" aria-labelledby="addAddressModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addAddressModalLabel">Add New Address</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="addressLine1" class="form-label">Address Line 1 *</label>
                    <input type="text" class="form-control" id="addressLine1" @bind="_newAddress.Street" placeholder="Street address">
                </div>
                <div class="mb-3">
                    <label for="addressLine2" class="form-label">Address Line 2</label>
                    <input type="text" class="form-control" id="addressLine2" @bind="_newAddress.Street2" placeholder="Apt, Suite, etc.">
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label for="city" class="form-label">City *</label>
                        <input type="text" class="form-control" id="city" @bind="_newAddress.City">
                    </div>
                    <div class="col-md-3">
                        <label for="state" class="form-label">State *</label>
                        <input type="text" class="form-control" id="state" @bind="_newAddress.State" maxlength="2" placeholder="TX">
                    </div>
                    <div class="col-md-3">
                        <label for="postalCode" class="form-label">ZIP *</label>
                        <input type="text" class="form-control" id="postalCode" @bind="_newAddress.ZipCode" maxlength="10">
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label for="latitude" class="form-label">Latitude</label>
                        <input type="number" class="form-control" id="latitude" @bind="_newAddress.Latitude" step="0.000001" placeholder="Optional">
                    </div>
                    <div class="col-md-6">
                        <label for="longitude" class="form-label">Longitude</label>
                        <input type="number" class="form-control" id="longitude" @bind="_newAddress.Longitude" step="0.000001" placeholder="Optional">
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" @onclick="CreateAddress" disabled="@(_isCreating || !IsAddressValid())">
                    @if (_isCreating)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                    }
                    Add Address
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public Guid? HouseholdId { get; set; }

    [Parameter]
    public EventCallback<AddressDto?> OnAddressChanged { get; set; }

    private List<AddressDto>? _addresses;
    private AddressDto? _selectedAddress;
    private bool _isLoading = false;
    private bool _isDetecting = false;
    private bool _isCreating = false;
    private bool _canDetectLocation = false;
    private string? _error;
    private string? _locationMessage;
    private CreateAddressRequest _newAddress = new();

    protected override async Task OnInitializedAsync()
    {
        await CheckGeolocationSupport();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (HouseholdId.HasValue)
        {
            await LoadAddresses();
        }
        else
        {
            _addresses = null;
            _selectedAddress = null;
        }
    }

    private async Task LoadAddresses()
    {
        if (!HouseholdId.HasValue)
            return;

        try
        {
            _isLoading = true;
            _error = null;
            _addresses = await InventoryClient.GetHouseholdAddressesAsync(HouseholdId.Value);
            
            // Auto-select first address if none selected
            if (_addresses != null && _addresses.Any() && _selectedAddress == null)
            {
                await SelectAddress(_addresses.First());
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to load addresses: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SelectAddress(AddressDto? address)
    {
        _selectedAddress = address;
        await OnAddressChanged.InvokeAsync(address);
    }

    private async Task DetectLocation()
    {
        try
        {
            _isDetecting = true;
            _error = null;
            _locationMessage = null;

            var position = await JS.InvokeAsync<GeolocationPosition>("getGeolocation");
            
            if (position != null && HouseholdId.HasValue)
            {
                var request = new DetectAddressRequest
                {
                    Latitude = (decimal)position.Latitude,
                    Longitude = (decimal)position.Longitude,
                    RadiusKm = 1
                };

                var detectedAddress = await InventoryClient.DetectCurrentAddressAsync(HouseholdId.Value, request);

                if (detectedAddress != null)
                {
                    _locationMessage = $"Detected address: {detectedAddress.Street}";
                    await LoadAddresses(); // Refresh with distance info
                    await SelectAddress(detectedAddress);
                }
                else
                {
                    _locationMessage = "No addresses found within 1km of your location.";
                }
            }
        }
        catch (Exception ex)
        {
            _error = $"Location detection failed: {ex.Message}";
        }
        finally
        {
            _isDetecting = false;
        }
    }

    private async Task CheckGeolocationSupport()
    {
        try
        {
            _canDetectLocation = await JS.InvokeAsync<bool>("isGeolocationSupported");
        }
        catch
        {
            _canDetectLocation = false;
        }
    }

    private async Task ShowAddAddressModal()
    {
        _newAddress = new CreateAddressRequest { HouseholdId = HouseholdId ?? Guid.Empty };
        await JS.InvokeVoidAsync("eval", "new bootstrap.Modal(document.getElementById('addAddressModal')).show()");
    }

    private async Task CreateAddress()
    {
        if (!IsAddressValid())
            return;

        try
        {
            _isCreating = true;
            _error = null;

            var created = await InventoryClient.CreateAddressAsync(HouseholdId!.Value, _newAddress);
            
            if (created != null)
            {
                await LoadAddresses();
                await SelectAddress(created);
                await JS.InvokeVoidAsync("eval", "bootstrap.Modal.getInstance(document.getElementById('addAddressModal')).hide()");
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to create address: {ex.Message}";
        }
        finally
        {
            _isCreating = false;
        }
    }

    private bool IsAddressValid()
    {
        return !string.IsNullOrWhiteSpace(_newAddress.Street)
            && !string.IsNullOrWhiteSpace(_newAddress.City)
            && !string.IsNullOrWhiteSpace(_newAddress.State)
            && !string.IsNullOrWhiteSpace(_newAddress.ZipCode);
    }

    private class GeolocationPosition
    {
        public double Latitude { get; set; }
        public double Longitude { get; set; }
    }
}
