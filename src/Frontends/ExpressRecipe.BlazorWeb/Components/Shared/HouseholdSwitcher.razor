@using ExpressRecipe.Client.Shared.Services
@using ExpressRecipe.Client.Shared.Models.Inventory
@inject InventoryApiClient InventoryClient
@inject IJSRuntime JS

<div class="household-switcher">
    @if (_isLoading)
    {
        <div class="spinner-border spinner-border-sm" role="status">
            <span class="visually-hidden">Loading households...</span>
        </div>
    }
    else if (_households != null && _households.Any())
    {
        <div class="dropdown">
            <button class="btn btn-outline-primary dropdown-toggle" type="button" id="householdDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-house-door"></i>
                @if (_activeHousehold != null)
                {
                    <span>@_activeHousehold.Name</span>
                    <span class="badge bg-@GetRoleBadgeColor(_activeHousehold.UserRole) ms-2">@_activeHousehold.UserRole</span>
                }
                else
                {
                    <span>Personal</span>
                }
            </button>
            <ul class="dropdown-menu" aria-labelledby="householdDropdown">
                <li>
                    <a class="dropdown-item @(_activeHousehold == null ? "active" : "")" href="#" @onclick="() => SelectHousehold(null)" @onclick:preventDefault>
                        <i class="bi bi-person"></i> Personal
                    </a>
                </li>
                <li><hr class="dropdown-divider"></li>
                @foreach (var household in _households)
                {
                    <li>
                        <a class="dropdown-item @(household.Id == _activeHousehold?.Id ? "active" : "")" href="#" @onclick="() => SelectHousehold(household)" @onclick:preventDefault>
                            <i class="bi bi-house"></i> @household.Name
                            <span class="badge bg-@GetRoleBadgeColor(household.UserRole) ms-2">@household.UserRole</span>
                            <small class="text-muted d-block">@household.MemberCount members</small>
                        </a>
                    </li>
                }
                <li><hr class="dropdown-divider"></li>
                <li>
                    <a class="dropdown-item" href="#" @onclick="ShowCreateHouseholdModal" @onclick:preventDefault>
                        <i class="bi bi-plus-circle"></i> Create New Household
                    </a>
                </li>
            </ul>
        </div>
    }
    else
    {
        <button class="btn btn-primary" @onclick="ShowCreateHouseholdModal">
            <i class="bi bi-plus-circle"></i> Create Household
        </button>
    }

    @if (_error != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mt-2" role="alert">
            @_error
            <button type="button" class="btn-close" @onclick="() => _error = null"></button>
        </div>
    }
</div>

<!-- Create Household Modal -->
<div class="modal fade" id="createHouseholdModal" tabindex="-1" aria-labelledby="createHouseholdModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createHouseholdModalLabel">Create New Household</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="householdName" class="form-label">Household Name</label>
                    <input type="text" class="form-control" id="householdName" @bind="_newHouseholdName" placeholder="e.g., Smith Family, Roommates, etc.">
                </div>
                <div class="mb-3">
                    <label for="householdDescription" class="form-label">Description (optional)</label>
                    <textarea class="form-control" id="householdDescription" @bind="_newHouseholdDescription" rows="3" placeholder="Brief description of this household"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" @onclick="CreateHousehold" disabled="@(_isCreating || string.IsNullOrWhiteSpace(_newHouseholdName))">
                    @if (_isCreating)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                    }
                    Create
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback<HouseholdDto?> OnHouseholdChanged { get; set; }

    private List<HouseholdDto>? _households;
    private HouseholdDto? _activeHousehold;
    private bool _isLoading = true;
    private bool _isCreating = false;
    private string? _error;
    private string _newHouseholdName = "";
    private string _newHouseholdDescription = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadHouseholds();
    }

    private async Task LoadHouseholds()
    {
        try
        {
            _isLoading = true;
            _error = null;
            _households = await InventoryClient.GetUserHouseholdsAsync();
            
            // Load active household from local storage or use first household
            var savedHouseholdId = await GetSavedHouseholdId();
            if (savedHouseholdId.HasValue && _households != null)
            {
                _activeHousehold = _households.FirstOrDefault(h => h.Id == savedHouseholdId.Value);
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to load households: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SelectHousehold(HouseholdDto? household)
    {
        _activeHousehold = household;
        await SaveActiveHouseholdId(household?.Id);
        await OnHouseholdChanged.InvokeAsync(household);
    }

    private async Task ShowCreateHouseholdModal()
    {
        _newHouseholdName = "";
        _newHouseholdDescription = "";
        await JS.InvokeVoidAsync("eval", "new bootstrap.Modal(document.getElementById('createHouseholdModal')).show()");
    }

    private async Task CreateHousehold()
    {
        if (string.IsNullOrWhiteSpace(_newHouseholdName))
            return;

        try
        {
            _isCreating = true;
            _error = null;

            var request = new CreateHouseholdRequest
            {
                Name = _newHouseholdName.Trim(),
                Description = string.IsNullOrWhiteSpace(_newHouseholdDescription) ? null : _newHouseholdDescription.Trim()
            };

            var newHousehold = await InventoryClient.CreateHouseholdAsync(request);
            
            if (newHousehold != null)
            {
                await LoadHouseholds();
                await SelectHousehold(newHousehold);
                await JS.InvokeVoidAsync("eval", "bootstrap.Modal.getInstance(document.getElementById('createHouseholdModal')).hide()");
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to create household: {ex.Message}";
        }
        finally
        {
            _isCreating = false;
        }
    }

    private string GetRoleBadgeColor(string? role) => role switch
    {
        "Owner" => "danger",
        "Admin" => "warning",
        "Member" => "info",
        "Viewer" => "secondary",
        _ => "secondary"
    };

    private async Task<Guid?> GetSavedHouseholdId()
    {
        try
        {
            var saved = await JS.InvokeAsync<string?>("localStorage.getItem", "activeHouseholdId");
            return string.IsNullOrEmpty(saved) ? null : Guid.Parse(saved);
        }
        catch
        {
            return null;
        }
    }

    private async Task SaveActiveHouseholdId(Guid? householdId)
    {
        try
        {
            if (householdId.HasValue)
            {
                await JS.InvokeVoidAsync("localStorage.setItem", "activeHouseholdId", householdId.Value.ToString());
            }
            else
            {
                await JS.InvokeVoidAsync("localStorage.removeItem", "activeHouseholdId");
            }
        }
        catch
        {
            // Ignore localStorage errors
        }
    }
}
