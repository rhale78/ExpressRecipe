    protected override async Task OnInitializedAsync()
    {
        // Load restrictions enabled state from localStorage
        try
        {
            var enabledStr = await JS.InvokeAsync<string>("localStorage.getItem", "dietaryRestrictionsEnabled");
            if (!string.IsNullOrEmpty(enabledStr))
            {
                _restrictionsEnabled = bool.Parse(enabledStr);
            }
        }
        catch { /* Ignore localStorage errors */ }

        // Load cached filters from localStorage (preserves across navigation)
        try
        {
            var cachedFiltersJson = await JS.InvokeAsync<string>("localStorage.getItem", "dietaryFiltersCache");
            if (!string.IsNullOrEmpty(cachedFiltersJson))
            {
                var cachedFilters = System.Text.Json.JsonSerializer.Deserialize<List<string>>(cachedFiltersJson);
                if (cachedFilters != null && cachedFilters.Any())
                {
                    _activeFilters = cachedFilters;
                }
            }
        }
        catch { /* Ignore cache errors */ }

        if (AutoLoadUserProfile)
        {
            await LoadUserProfile();
        }

        if (InitialFilters.Any())
        {
            _activeFilters = new List<string>(InitialFilters);
        }

        // Save initial state for change tracking
        _initialFilters = new List<string>(_activeFilters);

        // Register navigation guard to prompt save on exit
        _locationChangingRegistration = Navigation.RegisterLocationChangingHandler(OnLocationChanging);
    }

    private async ValueTask OnLocationChanging(LocationChangingContext context)
    {
        if (!HasUnsavedChanges())
            return;

        // Don't prompt when navigating within product pages (e.g., to product details)
        var targetPath = context.TargetLocation;
        var isProductNavigation = targetPath.Contains("/products/", StringComparison.OrdinalIgnoreCase) ||
                                  targetPath.Contains("/product-details", StringComparison.OrdinalIgnoreCase);

        if (isProductNavigation)
        {
            // Allow navigation to product pages without prompting
            return;
        }

        // Show custom save dialog
        _showSaveDialog = true;
        context.PreventNavigation();

        // Store the target location for later
        _pendingNavigationUrl = targetPath;
        StateHasChanged();
    }

    private bool HasUnsavedChanges()
    {
        // Check if current filters differ from initial filters
        if (_activeFilters.Count != _initialFilters.Count)
            return true;

        return _activeFilters.Except(_initialFilters).Any() || _initialFilters.Except(_activeFilters).Any();
    }

