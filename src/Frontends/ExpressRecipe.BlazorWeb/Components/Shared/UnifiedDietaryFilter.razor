    private async Task AddCustomRestriction()
    {
        if (string.IsNullOrWhiteSpace(_customInput))
            return;

        // Split by comma to support comma-separated input
        var items = _customInput.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        var addedCount = 0;
        foreach (var item in items)
        {
            if (string.IsNullOrWhiteSpace(item))
                continue;

            // Capitalize first letter
            var restriction = char.ToUpper(item[0]) + item.Substring(1).ToLower();

            // Check for duplicates (case-insensitive)
            if (!_activeFilters.Any(f => f.Equals(restriction, StringComparison.OrdinalIgnoreCase)))
            {
                _activeFilters.Add(restriction);
                addedCount++;
            }
        }

        if (addedCount > 0)
        {
            await NotifyChange();
        }

        _customInput = string.Empty;
        _showAutocomplete = false;
        _filteredIngredients.Clear();
    }

    private async Task SelectIngredient(string ingredient)
    {
        // Add the selected ingredient directly to active filters
        if (!_activeFilters.Contains(ingredient))
        {
            _activeFilters.Add(ingredient);
            await NotifyChange();
        }

        // Handle comma-separated input: replace the last incomplete item with the selected ingredient
        if (_customInput.Contains(','))
        {
            var items = _customInput.Split(',').Select(s => s.Trim()).ToList();
            items[items.Count - 1] = ingredient; // Replace last item with selected ingredient
            _customInput = string.Join(", ", items) + ", "; // Keep comma for continuing to add more
        }
        else
        {
            // Single item - clear and allow adding more
            _customInput = ingredient + ", ";
        }

        _showAutocomplete = false;
        _filteredIngredients.Clear();
        _selectedAutocompleteIndex = -1;
        _preventTabDefault = false; // Re-enable normal Tab behavior
    }

    private async Task NotifyChange()
    {
        // Cache filters to localStorage for persistence across navigation
        try
        {
            var filtersJson = System.Text.Json.JsonSerializer.Serialize(_activeFilters);
            await JS.InvokeVoidAsync("localStorage.setItem", "dietaryFiltersCache", filtersJson);
        }
        catch { /* Ignore localStorage errors */ }

        // Send empty list if restrictions are disabled, otherwise send active filters
        var filtersToSend = _restrictionsEnabled ? _activeFilters : new List<string>();
        await OnFiltersChanged.InvokeAsync(filtersToSend);
    }

    private enum FilterTarget
    {
        Me,
        Everyone,
        Custom
    }

    private record FilterDefinition(string Name, string Description);
