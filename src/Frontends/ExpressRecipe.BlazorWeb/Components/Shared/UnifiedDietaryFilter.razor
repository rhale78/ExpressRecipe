@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing
@using ExpressRecipe.Client.Shared.Models.User
@using ExpressRecipe.Client.Shared.Services
@inject AuthenticationStateProvider AuthStateProvider
@inject IUserProfileApiClient UserProfileClient
@inject NavigationManager Navigation
@inject IJSRuntime JS
@implements IDisposable

<div class="unified-dietary-filter">
    <!-- DEBUG BANNER - VERSION TRACKING -->
    <div style="background-color: red; color: white; padding: 1rem; text-align: center; font-size: 1.5rem; font-weight: bold; margin-bottom: 1rem;">
        ⚠️ VERSION 14 - UNIFIED GROUP BOX & ? REPOSITIONING ⚠️
    </div>

    <!-- Header -->
    <div style="display: flex; justify-content: space-between; align-items: center; padding: 1rem 1.5rem; background-color: #f9fafb; border-bottom: 1px solid #e5e7eb; border-radius: 0.75rem 0.75rem 0 0;">
        <h3 style="margin: 0; font-size: 1.25rem; font-weight: 600; color: #111827;">🍽️ Dietary Filters</h3>
        <div style="display: flex; align-items: center; gap: 1rem;">
            <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; user-select: none;">
                <input type="checkbox" style="width: 1.25rem; height: 1.25rem; cursor: pointer;"
                       checked="@_restrictionsEnabled"
                       @onchange="ToggleRestrictions" />
                <span style="font-size: 0.875rem; font-weight: 500; color: @(_restrictionsEnabled ? "#111827" : "#9ca3af");">
                    @(_restrictionsEnabled ? "✅ Restrictions Active" : "⭕ Restrictions Disabled")
                </span>
            </label>
            @if (!_isExpanded)
            {
                <button style="background-color: #2563eb; color: white; border: none; padding: 0.5rem 1rem; border-radius: 0.5rem; font-size: 0.875rem; font-weight: 600; cursor: pointer; transition: all 0.2s;" @onclick="ToggleExpanded">
                    ▼ Expand (@_activeFilters.Count filters)
                </button>
            }
            else
            {
                <button style="background-color: #2563eb; color: white; border: none; padding: 0.5rem 1rem; border-radius: 0.5rem; font-size: 0.875rem; font-weight: 600; cursor: pointer; transition: all 0.2s;" @onclick="ToggleExpanded">
                    ▲ Collapse
                </button>
            }
        </div>
    </div>

    @if (_isExpanded)
    {
        <div class="filter-content">
            <!-- Who are you filtering for? -->
            <div class="filter-section">
                <h4>👥 Who are you filtering for?</h4>
                <div class="family-selection">
                    <label class="family-option">
                        <input type="radio" name="filterTarget" value="me"
                               checked="@(_filterTarget == FilterTarget.Me)"
                               @onchange="() => SetFilterTarget(FilterTarget.Me)" />
                        <span>🙋 Just Me</span>
                    </label>

                    @if (_familyMembers.Any())
                    {
                        @foreach (var member in _familyMembers)
                        {
                            <label class="family-option">
                                <input type="checkbox"
                                       checked="@_selectedFamilyMemberIds.Contains(member.Id)"
                                       @onchange="() => ToggleFamilyMember(member.Id)" />
                                <span>👨‍👩‍👧‍👦 @member.Name (@member.Relationship)</span>
                            </label>
                        }

                        <label class="family-option">
                            <input type="radio" name="filterTarget" value="everyone"
                                   checked="@(_filterTarget == FilterTarget.Everyone)"
                                   @onchange="() => SetFilterTarget(FilterTarget.Everyone)" />
                            <span>👨‍👩‍👧‍👦 Entire Family</span>
                        </label>
                    }

                    <label class="family-option">
                        <input type="radio" name="filterTarget" value="custom"
                               checked="@(_filterTarget == FilterTarget.Custom)"
                               @onchange="() => SetFilterTarget(FilterTarget.Custom)" />
                        <span>✏️ Custom Selection</span>
                    </label>
                </div>
            </div>

            <hr class="section-divider" />

            <!-- Dietary Restrictions Group -->
            <div style="border: 2px solid #2563eb; border-radius: 0.75rem; padding: 1rem; background-color: white; opacity: @(_restrictionsEnabled ? "1" : "0.5"); pointer-events: @(_restrictionsEnabled ? "auto" : "none");">
                <h4 style="margin: 0 0 1rem 0; font-size: 1.125rem; font-weight: 600; color: #2563eb; display: flex; align-items: center; gap: 0.5rem;">
                    <span>🛡️</span>
                    <span>Dietary Restrictions</span>
                    @if (!_restrictionsEnabled)
                    {
                        <span style="font-size: 0.875rem; color: #9ca3af; font-weight: 400;">(Disabled - Enable checkbox above to activate)</span>
                    }
                </h4>

                <!-- Religious Restrictions -->
                <div style="background-color: #f9fafb; border: 1px solid #e5e7eb; border-radius: 0.5rem; margin-bottom: 1rem; overflow: visible;">
                    <div style="display: flex; align-items: center; gap: 1rem; padding: 1rem; cursor: pointer; transition: background-color 0.2s ease; border-radius: 0.5rem; user-select: none; background-color: @(_religiousHover ? "#f3f4f6" : "#f9fafb");"
                         @onclick="() => _religiousExpanded = !_religiousExpanded"
                         @onmouseover="@(() => _religiousHover = true)"
                         @onmouseout="@(() => _religiousHover = false)">
                        <span style="font-size: 1.5rem;">🕌</span>
                        <span style="font-weight: 600; font-size: 1rem; color: #111827;">Religious Restrictions</span>
                        <span style="position: relative; background-color: #2563eb; border: 2px solid #1e40af; color: white; border-radius: 50%; width: 1.5rem; height: 1.5rem; display: inline-flex; align-items: center; justify-content: center; cursor: help; font-size: 0.75rem; font-weight: 700; margin-right: auto;"
                              title="Religious dietary laws help you follow your faith's guidelines. Hover over each option for specific details."
                              @onclick:stopPropagation="true">?</span>
                        <span style="color: #6b7280; font-size: 0.875rem; font-weight: 500;">@(_religiousExpanded ? "Click to collapse" : "Click to expand")</span>
                        <span style="color: #6b7280; font-size: 1.25rem; font-weight: bold;">@(_religiousExpanded ? "▼" : "▶")</span>
                    </div>
                @if (_religiousExpanded)
                {
                    <div style="padding: 1rem; display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; background-color: white;">
                        @foreach (var item in _religiousRestrictions)
                        {
                            <label style="display: flex; align-items: center; gap: 0.625rem; padding: 0.75rem 1rem; background-color: #2563eb; border: 2px solid #1e40af; border-radius: 0.5rem; cursor: pointer; box-shadow: 0 2px 4px rgba(37, 99, 235, 0.2); transition: all 0.2s ease;"
                                   title="@item.Description">
                                <input type="checkbox"
                                       style="cursor: pointer; width: 1.125rem; height: 1.125rem; accent-color: white;"
                                       checked="@_activeFilters.Contains(item.Name)"
                                       @onchange="() => ToggleFilter(item.Name)" />
                                <span style="font-size: 0.875rem; color: white; user-select: none; font-weight: 500;">@item.Name</span>
                            </label>
                        }
                    </div>
                }
            </div>

            <!-- Diet/Belief Restrictions -->
            <div style="background-color: #f9fafb; border: 1px solid #e5e7eb; border-radius: 0.5rem; margin-bottom: 1rem; overflow: visible;">
                <div style="display: flex; align-items: center; gap: 1rem; padding: 1rem; cursor: pointer; transition: background-color 0.2s ease; border-radius: 0.5rem; user-select: none; background-color: @(_dietHover ? "#f3f4f6" : "#f9fafb");"
                     @onclick="() => _dietExpanded = !_dietExpanded"
                     @onmouseover="@(() => _dietHover = true)"
                     @onmouseout="@(() => _dietHover = false)">
                    <span style="font-size: 1.5rem;">🌱</span>
                    <span style="font-weight: 600; font-size: 1rem; color: #111827;">Diet & Belief Restrictions</span>
                    <span style="position: relative; background-color: #2563eb; border: 2px solid #1e40af; color: white; border-radius: 50%; width: 1.5rem; height: 1.5rem; display: inline-flex; align-items: center; justify-content: center; cursor: help; font-size: 0.75rem; font-weight: 700; margin-right: auto;"
                          title="Lifestyle-based dietary choices. Selecting these will exclude products containing prohibited ingredients."
                          @onclick:stopPropagation="true">?</span>
                    <span style="color: #6b7280; font-size: 0.875rem; font-weight: 500;">@(_dietExpanded ? "Click to collapse" : "Click to expand")</span>
                    <span style="color: #6b7280; font-size: 1.25rem; font-weight: bold;">@(_dietExpanded ? "▼" : "▶")</span>
                </div>
                @if (_dietExpanded)
                {
                    <div style="padding: 1rem; display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; background-color: white;">
                        @foreach (var item in _dietRestrictions)
                        {
                            <label style="display: flex; align-items: center; gap: 0.625rem; padding: 0.75rem 1rem; background-color: #2563eb; border: 2px solid #1e40af; border-radius: 0.5rem; cursor: pointer; box-shadow: 0 2px 4px rgba(37, 99, 235, 0.2); transition: all 0.2s ease;"
                                   title="@item.Description">
                                <input type="checkbox"
                                       style="cursor: pointer; width: 1.125rem; height: 1.125rem; accent-color: white;"
                                       checked="@_activeFilters.Contains(item.Name)"
                                       @onchange="() => ToggleFilter(item.Name)" />
                                <span style="font-size: 0.875rem; color: white; user-select: none; font-weight: 500;">@item.Name</span>
                            </label>
                        }
                    </div>
                }
            </div>

            <!-- Common Allergens -->
            <div style="background-color: #f9fafb; border: 1px solid #e5e7eb; border-radius: 0.5rem; margin-bottom: 1rem; overflow: visible;">
                <div style="display: flex; align-items: center; gap: 1rem; padding: 1rem; cursor: pointer; transition: background-color 0.2s ease; border-radius: 0.5rem; user-select: none; background-color: @(_allergenHover ? "#f3f4f6" : "#f9fafb");"
                     @onclick="() => _allergenExpanded = !_allergenExpanded"
                     @onmouseover="@(() => _allergenHover = true)"
                     @onmouseout="@(() => _allergenHover = false)">
                    <span style="font-size: 1.5rem;">⚠️</span>
                    <span style="font-weight: 600; font-size: 1rem; color: #111827;">Common Allergens</span>
                    <span style="position: relative; background-color: #2563eb; border: 2px solid #1e40af; color: white; border-radius: 50%; width: 1.5rem; height: 1.5rem; display: inline-flex; align-items: center; justify-content: center; cursor: help; font-size: 0.75rem; font-weight: 700; margin-right: auto;"
                          title="Major food allergens recognized by FDA and health organizations. Products containing these will be filtered out."
                          @onclick:stopPropagation="true">?</span>
                    <span style="color: #6b7280; font-size: 0.875rem; font-weight: 500;">@(_allergenExpanded ? "Click to collapse" : "Click to expand")</span>
                    <span style="color: #6b7280; font-size: 1.25rem; font-weight: bold;">@(_allergenExpanded ? "▼" : "▶")</span>
                </div>
                @if (_allergenExpanded)
                {
                    <div style="padding: 1rem; display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; background-color: white;">
                        @foreach (var item in _allergenRestrictions)
                        {
                            <label style="display: flex; align-items: center; gap: 0.625rem; padding: 0.75rem 1rem; background-color: #2563eb; border: 2px solid #1e40af; border-radius: 0.5rem; cursor: pointer; box-shadow: 0 2px 4px rgba(37, 99, 235, 0.2); transition: all 0.2s ease;"
                                   title="@item.Description">
                                <input type="checkbox"
                                       style="cursor: pointer; width: 1.125rem; height: 1.125rem; accent-color: white;"
                                       checked="@_activeFilters.Contains(item.Name)"
                                       @onchange="() => ToggleFilter(item.Name)" />
                                <span style="font-size: 0.875rem; color: white; user-select: none; font-weight: 500;">@item.Name</span>
                            </label>
                        }
                    </div>
                }
            </div>

            <!-- Custom Individual Restrictions -->
            <div style="background-color: #f9fafb; border: 1px solid #e5e7eb; border-radius: 0.5rem; margin-bottom: 1rem; overflow: visible;">
                <div style="display: flex; align-items: center; gap: 1rem; padding: 1rem; cursor: pointer; transition: background-color 0.2s ease; border-radius: 0.5rem; user-select: none; background-color: @(_customHover ? "#f3f4f6" : "#f9fafb");"
                     @onclick="() => _customExpanded = !_customExpanded"
                     @onmouseover="@(() => _customHover = true)"
                     @onmouseout="@(() => _customHover = false)">
                    <span style="font-size: 1.5rem;">➕</span>
                    <span style="font-weight: 600; font-size: 1rem; color: #111827;">Custom Restrictions</span>
                    <span style="position: relative; background-color: #2563eb; border: 2px solid #1e40af; color: white; border-radius: 50%; width: 1.5rem; height: 1.5rem; display: inline-flex; align-items: center; justify-content: center; cursor: help; font-size: 0.75rem; font-weight: 700; margin-right: auto;"
                          title="Add any specific ingredients your family avoids. Type to search, or enter multiple separated by commas."
                          @onclick:stopPropagation="true">?</span>
                    <span style="color: #6b7280; font-size: 0.875rem; font-weight: 500;">@(_customExpanded ? "Click to collapse" : "Click to expand")</span>
                    <span style="color: #6b7280; font-size: 1.25rem; font-weight: bold;">@(_customExpanded ? "▼" : "▶")</span>
                </div>
                @if (_customExpanded)
                {
                    <div style="padding: 1rem; border-top: 1px solid #e5e7eb; background-color: white; border-radius: 0 0 0.5rem 0.5rem;">
                        <p style="margin: 0 0 0.75rem 0; font-size: 0.875rem; color: #6b7280; display: flex; align-items: center; gap: 0.5rem;">💡 Add ingredients to avoid (comma-separated or one at a time)</p>
                        <div style="position: relative; margin-bottom: 1rem;">
                            <div style="display: flex; gap: 0.5rem;">
                                <input type="text"
                                       style="flex: 1; padding: 0.625rem 1rem; border: 1px solid #d1d5db; border-radius: 0.5rem; font-size: 0.9375rem; transition: border-color 0.2s, box-shadow 0.2s;"
                                       placeholder="Type ingredient(s) to avoid: annatto, palm oil, MSG..."
                                       @bind="_customInput"
                                       @bind:event="oninput"
                                       @bind:after="OnCustomInputChanged"
                                       @onkeydown="HandleAutocompleteKeyDown"
                                       @onkeydown:preventDefault="@_preventTabDefault"
                                       @onpaste="HandlePaste"
                                       @onfocus="() => _showAutocomplete = true" />
                                <button style="background-color: #2563eb; color: white; border: none; padding: 0 1.25rem; border-radius: 0.5rem; font-weight: 600; cursor: pointer; transition: background-color 0.2s;" @onclick="AddCustomRestriction">+ Add</button>
                            </div>

                            <!-- Autocomplete Dropdown -->
                            @if (_showAutocomplete && _filteredIngredients.Any() && !string.IsNullOrWhiteSpace(_customInput))
                            {
                                <div style="position: absolute; top: 100%; left: 0; right: 0; background-color: white; border: 1px solid #e5e7eb; border-radius: 0.5rem; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1); z-index: 20; margin-top: 0.25rem; max-height: 250px; overflow-y: auto;">
                                    <div style="padding: 0.5rem 1rem; font-size: 0.75rem; font-weight: 600; color: #6b7280; background-color: #f9fafb; border-bottom: 1px solid #f3f4f6; text-transform: uppercase;">Suggestions (↓↑ arrows to navigate, Tab/Enter to select):</div>
                                    @for (int i = 0; i < Math.Min(_filteredIngredients.Count, 8); i++)
                                    {
                                        var ingredient = _filteredIngredients[i];
                                        var isSelected = i == _selectedAutocompleteIndex;
                                        <button style="display: block; width: 100%; text-align: left; padding: 0.625rem 1rem; background: @(isSelected ? "#eff6ff" : "none"); border: none; cursor: pointer; font-size: 0.9375rem; color: @(isSelected ? "#1e40af" : "#374151"); transition: background-color 0.15s;" @onclick="() => SelectIngredient(ingredient)"
                                                onmouseover="this.style.backgroundColor='#eff6ff'; this.style.color='#1e40af';"
                                                onmouseout="this.style.backgroundColor='@(isSelected ? "#eff6ff" : "")'; this.style.color='@(isSelected ? "#1e40af" : "#374151")';">
                                            <span>@ingredient</span>
                                        </button>
                                    }
                                </div>
                            }
                        </div>

                        @if (_userCustomRestrictions.Any())
                        {
                            <div style="margin-top: 1rem;">
                                <small style="color: #6b7280; font-size: 0.875rem;">From your profile:</small>
                                <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 0.5rem;">
                                    @foreach (var item in _userCustomRestrictions)
                                    {
                                        <label style="display: flex; align-items: center; gap: 0.625rem; padding: 0.75rem 1rem; background-color: #2563eb; border: 2px solid #1e40af; border-radius: 0.5rem; cursor: pointer; box-shadow: 0 2px 4px rgba(37, 99, 235, 0.2); transition: all 0.2s ease;">
                                            <input type="checkbox"
                                                   style="cursor: pointer; width: 1.125rem; height: 1.125rem; accent-color: white;"
                                                   checked="@_activeFilters.Contains(item)"
                                                   @onchange="() => ToggleFilter(item)" />
                                            <span style="font-size: 0.875rem; color: white; user-select: none; font-weight: 500;">@item</span>
                                        </label>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Active Filters Summary -->
            @if (_activeFilters.Any())
            {
                <div style="margin-top: 2rem; padding-top: 1.5rem; border-top: 2px solid #2563eb;">
                    <h4 style="margin: 0 0 1rem 0; font-size: 1rem; font-weight: 600; color: #2563eb;">Active Filters (@_activeFilters.Count)</h4>
                    <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem;">
                        @foreach (var filter in _activeFilters)
                        {
                            <span style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.5rem 0.75rem; background-color: #2563eb; border: 1px solid #1e40af; border-radius: 9999px; color: white; font-size: 0.875rem; font-weight: 500;">
                                @filter
                                <button style="background: none; border: none; color: white; cursor: pointer; padding: 0; font-size: 1rem; line-height: 1; display: flex; align-items: center; justify-content: center; border-radius: 50%; width: 1.25rem; height: 1.25rem;" @onclick="() => RemoveFilter(filter)">✖</button>
                            </span>
                        }
                    </div>
                    <button style="background-color: #ef4444; color: white; border: none; padding: 0.5rem 1rem; border-radius: 0.5rem; font-size: 0.875rem; font-weight: 600; cursor: pointer;" @onclick="ClearAllFilters">Clear All</button>
                </div>
            }
            </div> <!-- End Complete Dietary Filters Group -->
        </div>
    }
</div>

<!-- Custom Save Dialog -->
@if (_showSaveDialog)
{
    <div style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.5); display: flex; align-items: center; justify-content: center; z-index: 9999;" @onclick="() => _showSaveDialog = false">
        <div style="background: white; border-radius: 1rem; padding: 2rem; max-width: 500px; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);" @onclick:stopPropagation="true">
            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
                <span style="font-size: 2.5rem;">💾</span>
                <h3 style="margin: 0; font-size: 1.5rem; font-weight: 600; color: #111827;">Save Dietary Filters?</h3>
            </div>

            <p style="color: #6b7280; margin-bottom: 2rem; line-height: 1.6;">
                You have unsaved dietary filter changes. Would you like to save them to your profile before leaving?
            </p>

            <div style="display: flex; gap: 1rem; justify-content: flex-end;">
                <button style="background-color: #f3f4f6; color: #374151; border: none; padding: 0.75rem 1.5rem; border-radius: 0.5rem; font-size: 1rem; font-weight: 600; cursor: pointer; transition: background-color 0.2s;"
                        @onclick="DontSaveAndContinue"
                        onmouseover="this.style.backgroundColor='#e5e7eb'"
                        onmouseout="this.style.backgroundColor='#f3f4f6'">
                    Don't Save
                </button>
                <button style="background-color: #2563eb; color: white; border: none; padding: 0.75rem 1.5rem; border-radius: 0.5rem; font-size: 1rem; font-weight: 600; cursor: pointer; transition: background-color 0.2s;"
                        @onclick="SaveAndContinue"
                        onmouseover="this.style.backgroundColor='#1d4ed8'"
                        onmouseout="this.style.backgroundColor='#2563eb'">
                    Save & Continue
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public EventCallback<List<string>> OnFiltersChanged { get; set; }

    [Parameter]
    public List<string> InitialFilters { get; set; } = new();

    [Parameter]
    public bool AutoLoadUserProfile { get; set; } = true;

    // State
    private bool _isExpanded = true;
    private bool _restrictionsEnabled = true; // Toggle to enable/disable all restrictions
    private bool _religiousExpanded = false;
    private bool _dietExpanded = false;
    private bool _allergenExpanded = true; // Allergens expanded by default
    private bool _customExpanded = false;

    // Hover states for collapsible sections
    private bool _religiousHover = false;
    private bool _dietHover = false;
    private bool _allergenHover = false;
    private bool _customHover = false;

    private FilterTarget _filterTarget = FilterTarget.Me;
    private HashSet<Guid> _selectedFamilyMemberIds = new();
    private List<string> _activeFilters = new();
    private List<string> _initialFilters = new(); // Track initial state for comparison
    private string _customInput = string.Empty;

    private IDisposable? _locationChangingRegistration;
    private bool _showSaveDialog = false;
    private string _pendingNavigationUrl = string.Empty;

    // Autocomplete
    private bool _showAutocomplete = false;
    private List<string> _filteredIngredients = new();
    private int _selectedAutocompleteIndex = -1;
    private bool _preventTabDefault = false; // Only prevent Tab when autocomplete is active

    // User data
    private UserProfileDto? _userProfile;
    private List<FamilyMemberDto> _familyMembers = new();
    private List<string> _userCustomRestrictions = new();

    // Filter definitions
    private readonly List<FilterDefinition> _religiousRestrictions = new()
    {
        new("Kosher", "Jewish dietary laws - no pork, shellfish, or mixing meat and dairy"),
        new("Halal", "Islamic dietary laws - no pork, alcohol, or non-halal meat"),
        new("No Pork", "Excludes pork and pork-derived products"),
        new("No Beef", "Excludes beef and beef-derived products"),
        new("No Alcohol", "Excludes alcohol and alcohol-containing ingredients"),
        new("Jain", "No root vegetables, onions, garlic, or animal products")
    };

    private readonly List<FilterDefinition> _dietRestrictions = new()
    {
        new("Vegan", "No animal products (meat, dairy, eggs, honey)"),
        new("Vegetarian", "No meat or fish, but dairy and eggs allowed"),
        new("Pescatarian", "Vegetarian plus fish/seafood allowed"),
        new("Plant-Based", "Focuses on whole plant foods, minimal animal products"),
        new("Whole30", "No grains, dairy, legumes, sugar, or processed foods"),
        new("Paleo", "No grains, dairy, legumes, or processed foods"),
        new("Keto", "Very low carb, high fat diet"),
        new("Low-Carb", "Reduced carbohydrate intake"),
        new("Raw", "Uncooked, unprocessed plant foods")
    };

    private readonly List<FilterDefinition> _allergenRestrictions = new()
    {
        new("Gluten", "Wheat, barley, rye, and related proteins"),
        new("Dairy", "Milk and milk-derived products"),
        new("Eggs", "Eggs and egg-derived products"),
        new("Fish", "All fish species"),
        new("Shellfish", "Crustaceans and mollusks"),
        new("Tree Nuts", "Almonds, cashews, walnuts, etc."),
        new("Peanuts", "Peanuts and peanut-derived products"),
        new("Wheat", "Wheat and wheat-derived products"),
        new("Soy", "Soybeans and soy-derived products"),
        new("Sesame", "Sesame seeds and sesame oil"),
