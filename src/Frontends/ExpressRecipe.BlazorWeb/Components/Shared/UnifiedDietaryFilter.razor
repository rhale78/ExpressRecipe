        await SaveFiltersToProfile();

        // Navigate to the pending URL
        if (!string.IsNullOrEmpty(_pendingNavigationUrl))
        {
            Navigation.NavigateTo(_pendingNavigationUrl);
        }
    }

    private void DontSaveAndContinue()
    {
        _showSaveDialog = false;

        // Navigate to the pending URL without saving
        if (!string.IsNullOrEmpty(_pendingNavigationUrl))
        {
            Navigation.NavigateTo(_pendingNavigationUrl);
        }
    }

