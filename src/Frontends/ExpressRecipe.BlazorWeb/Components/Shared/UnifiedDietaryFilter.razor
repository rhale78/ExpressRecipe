    private async Task OnCustomInputChanged()
    {
        // Check if user just typed a comma - auto-add the item before the comma
        if (_customInput.EndsWith(",") || _customInput.EndsWith(", "))
        {
            await ProcessCommaInput();
        }
        else
        {
            _showAutocomplete = true;
            _selectedAutocompleteIndex = -1; // Reset selection when typing
            UpdateAutocompleteFiltering();
            _preventTabDefault = false; // Don't prevent default while typing - only when navigating with arrows
        }
    }

    private async Task ProcessCommaInput()
    {
        // Extract all comma-separated items
        var items = _customInput.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(s => !string.IsNullOrWhiteSpace(s))
            .ToList();

        if (!items.Any())
        {
            _showAutocomplete = false;
            return;
        }

        // Add all items except the last empty one (after the trailing comma)
        foreach (var item in items)
        {
            var restriction = char.ToUpper(item[0]) + item.Substring(1).ToLower();
            if (!_activeFilters.Any(f => f.Equals(restriction, StringComparison.OrdinalIgnoreCase)))
            {
                _activeFilters.Add(restriction);
            }
        }

        await NotifyChange();

        // Keep the comma in the input for continuing to type, but close autocomplete
        _showAutocomplete = false;
        _filteredIngredients.Clear();
        _selectedAutocompleteIndex = -1;
        _preventTabDefault = false;
    }

    private async Task HandlePaste(ClipboardEventArgs e)
    {
        // Wait a moment for the paste to complete, then process
        await Task.Delay(50);

        // Check if pasted content contains commas - if so, auto-parse
        if (_customInput.Contains(','))
        {
            var items = _customInput.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Where(s => !string.IsNullOrWhiteSpace(s))
                .ToList();

            foreach (var item in items)
            {
                var restriction = char.ToUpper(item[0]) + item.Substring(1).ToLower();
                if (!_activeFilters.Any(f => f.Equals(restriction, StringComparison.OrdinalIgnoreCase)))
                {
                    _activeFilters.Add(restriction);
                }
            }

            await NotifyChange();

            // Clear the input after paste processing
            _customInput = string.Empty;
            _showAutocomplete = false;
            _filteredIngredients.Clear();
        }
    }

    private async Task HandleAutocompleteKeyDown(KeyboardEventArgs e)
    {
        if (!_showAutocomplete || !_filteredIngredients.Any())
        {
            _preventTabDefault = false; // Allow normal Tab behavior when no dropdown
            // If dropdown not showing, handle Enter to add custom input
            if (e.Key == "Enter")
            {
                await AddCustomRestriction();
            }
            return;
        }

        var maxIndex = Math.Min(_filteredIngredients.Count, 8) - 1;

        switch (e.Key)
        {
            case "ArrowDown":
                // Entering navigation mode - prevent Tab from leaving input
                if (_selectedAutocompleteIndex < 0)
                {
                    _selectedAutocompleteIndex = 0; // Start at first item
                }
                else
                {
                    _selectedAutocompleteIndex = _selectedAutocompleteIndex < maxIndex
                        ? _selectedAutocompleteIndex + 1
                        : 0; // Wrap to top
                }
                _preventTabDefault = true; // Now in navigation mode - prevent Tab from moving focus
                break;

            case "ArrowUp":
                // Entering or continuing navigation mode
                if (_selectedAutocompleteIndex < 0)
                {
                    _selectedAutocompleteIndex = maxIndex; // Start at last item
                }
                else
                {
                    _selectedAutocompleteIndex = _selectedAutocompleteIndex > 0
                        ? _selectedAutocompleteIndex - 1
                        : maxIndex; // Wrap to bottom
                }
                _preventTabDefault = true; // Now in navigation mode - prevent Tab from moving focus
                break;

            case "Tab":
            case "Enter":
                if (_selectedAutocompleteIndex >= 0 && _selectedAutocompleteIndex <= maxIndex)
                {
                    // Select the highlighted suggestion
                    await SelectIngredient(_filteredIngredients[_selectedAutocompleteIndex]);
                    _preventTabDefault = false; // Exit navigation mode
                }
                else if (e.Key == "Enter")
                {
                    // Enter without navigation adds custom input
                    await AddCustomRestriction();
                }
                // Tab without navigation does nothing - allows normal Tab behavior to next control
                break;

            case "Escape":
                _showAutocomplete = false;
                _selectedAutocompleteIndex = -1;
                _filteredIngredients.Clear();
                _preventTabDefault = false; // Exit navigation mode
                break;
        }
    }

    private void UpdateAutocompleteFiltering()
    {
        if (string.IsNullOrWhiteSpace(_customInput))
        {
            _filteredIngredients.Clear();
            _showAutocomplete = false;
            return;
        }

        // Get the last item being typed (for comma-separated input)
        var items = _customInput.Split(',');
        var currentItem = items.LastOrDefault()?.Trim() ?? "";

        if (string.IsNullOrWhiteSpace(currentItem))
        {
            _filteredIngredients.Clear();
            return;
        }

        _filteredIngredients = _commonIngredients
            .Where(i => i.Contains(currentItem, StringComparison.OrdinalIgnoreCase))
            .OrderBy(i => i.StartsWith(currentItem, StringComparison.OrdinalIgnoreCase) ? 0 : 1)
            .ThenBy(i => i)
            .ToList();
    }

