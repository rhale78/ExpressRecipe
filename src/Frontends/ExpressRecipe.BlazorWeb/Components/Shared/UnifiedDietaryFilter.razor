    private async Task SetFilterTarget(FilterTarget target)
    {
        _filterTarget = target;
        _selectedFamilyMemberIds.Clear();
        await RecalculateFilters();
    }

    private async Task ToggleFamilyMember(Guid memberId)
    {
        _filterTarget = FilterTarget.Custom;

        if (_selectedFamilyMemberIds.Contains(memberId))
        {
            _selectedFamilyMemberIds.Remove(memberId);
        }
        else
        {
            _selectedFamilyMemberIds.Add(memberId);
        }

        await RecalculateFilters();
    }

    private async Task RecalculateFilters()
    {
        _activeFilters.Clear();

        if (_userProfile == null) return;

        switch (_filterTarget)
        {
            case FilterTarget.Me:
                // Add user's allergens and dietary restrictions
                if (_userProfile.Allergens != null)
                    _activeFilters.AddRange(_userProfile.Allergens);
                if (_userProfile.DietaryRestrictions != null)
                    _activeFilters.AddRange(_userProfile.DietaryRestrictions);
                if (_userProfile.IngredientsToAvoid != null)
                    _activeFilters.AddRange(_userProfile.IngredientsToAvoid);
                break;

            case FilterTarget.Everyone:
                // Add all family members' restrictions
                if (_userProfile.Allergens != null)
                    _activeFilters.AddRange(_userProfile.Allergens);
                if (_userProfile.DietaryRestrictions != null)
                    _activeFilters.AddRange(_userProfile.DietaryRestrictions);
                if (_userProfile.IngredientsToAvoid != null)
                    _activeFilters.AddRange(_userProfile.IngredientsToAvoid);

                foreach (var member in _familyMembers)
                {
                    if (member.Allergens != null)
                        _activeFilters.AddRange(member.Allergens);
                    if (member.DietaryRestrictions != null)
                        _activeFilters.AddRange(member.DietaryRestrictions);
                    if (member.IngredientsToAvoid != null)
                        _activeFilters.AddRange(member.IngredientsToAvoid);
                }
                break;

            case FilterTarget.Custom:
                // Add selected family members' restrictions
                foreach (var memberId in _selectedFamilyMemberIds)
                {
                    var member = _familyMembers.FirstOrDefault(m => m.Id == memberId);
                    if (member != null)
                    {
                        if (member.Allergens != null)
                            _activeFilters.AddRange(member.Allergens);
                        if (member.DietaryRestrictions != null)
                            _activeFilters.AddRange(member.DietaryRestrictions);
                        if (member.IngredientsToAvoid != null)
                            _activeFilters.AddRange(member.IngredientsToAvoid);
                    }
                }
                break;
        }

        // Remove duplicates
        _activeFilters = _activeFilters.Distinct().ToList();

        await NotifyChange();
    }

    private async Task ToggleFilter(string filterName)
    {
        if (_activeFilters.Contains(filterName))
        {
            // Remove the filter
            _activeFilters.Remove(filterName);

            // Also remove any mapped ingredients if this was a dietary/religious restriction
            if (_restrictionMapping.ContainsKey(filterName))
            {
                var mappedIngredients = _restrictionMapping[filterName];
                foreach (var ingredient in mappedIngredients)
                {
                    _activeFilters.Remove(ingredient);
                }
            }
        }
        else
        {
            // Add the filter
            _activeFilters.Add(filterName);

            // If this is a dietary/religious restriction, also add all mapped ingredients
            if (_restrictionMapping.ContainsKey(filterName))
            {
                var mappedIngredients = _restrictionMapping[filterName];
                foreach (var ingredient in mappedIngredients)
                {
                    if (!_activeFilters.Contains(ingredient))
                    {
                        _activeFilters.Add(ingredient);
                    }
                }
            }
        }

        await NotifyChange();
    }

    private async Task RemoveFilter(string filterName)
    {
        _activeFilters.Remove(filterName);
        await NotifyChange();
    }

