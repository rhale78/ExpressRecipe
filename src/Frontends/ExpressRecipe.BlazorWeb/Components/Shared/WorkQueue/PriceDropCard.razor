@using ExpressRecipe.Client.Shared.Services

@* Price-drop action card — lets the user add the item to the shopping list or dismiss. *@

<div class="price-drop-card">
    <div class="action-buttons">
        <button class="btn btn-primary"   @onclick='() => TakeAction("AddedToList")' disabled="@_working">🛒 Add to Shopping List</button>
        <button class="btn btn-secondary" @onclick='() => TakeAction("Noted")'      disabled="@_working">👍 Noted</button>
    </div>
</div>

@code {
    [Parameter] public WorkQueueItemDto Item    { get; set; } = default!;
    [Parameter] public EventCallback<(Guid, string)> OnActioned { get; set; }

    private bool _working;

    private async Task TakeAction(string action)
    {
        _working = true;
        await OnActioned.InvokeAsync((Item.Id, action));
        _working = false;
    }
}
