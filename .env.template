# ExpressRecipe Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit the actual .env file to git!

# ===========================================
# JWT Authentication Configuration
# ===========================================
# SECURITY: Use a strong, random 64+ character string for production
# Generate with: openssl rand -base64 64
JWT_SECRET_KEY=REPLACE-WITH-STRONG-SECRET-MIN-64-CHARS-USE-OPENSSL-RAND-BASE64-64

# JWT Token Settings
JWT_ISSUER=ExpressRecipe.AuthService
JWT_AUDIENCE=ExpressRecipe.API
JWT_EXPIRATION_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7

# ===========================================
# Database Configuration
# ===========================================
# SQL Server Connection (used by Aspire for container)
SQL_SERVER_PASSWORD=REPLACE-WITH-STRONG-PASSWORD

# Individual Database Connections (if not using Aspire)
# AUTH_DB_CONNECTION_STRING=Server=localhost;Database=ExpressRecipe.Auth;User Id=sa;Password=YourPassword;TrustServerCertificate=True
# USER_DB_CONNECTION_STRING=Server=localhost;Database=ExpressRecipe.Users;User Id=sa;Password=YourPassword;TrustServerCertificate=True
# PRODUCT_DB_CONNECTION_STRING=Server=localhost;Database=ExpressRecipe.Products;User Id=sa;Password=YourPassword;TrustServerCertificate=True
# RECIPE_DB_CONNECTION_STRING=Server=localhost;Database=ExpressRecipe.Recipes;User Id=sa;Password=YourPassword;TrustServerCertificate=True
# INVENTORY_DB_CONNECTION_STRING=Server=localhost;Database=ExpressRecipe.Inventory;User Id=sa;Password=YourPassword;TrustServerCertificate=True
# SHOPPING_DB_CONNECTION_STRING=Server=localhost;Database=ExpressRecipe.Shopping;User Id=sa;Password=YourPassword;TrustServerCertificate=True
# MEALPLAN_DB_CONNECTION_STRING=Server=localhost;Database=ExpressRecipe.MealPlanning;User Id=sa;Password=YourPassword;TrustServerCertificate=True
# NOTIFICATION_DB_CONNECTION_STRING=Server=localhost;Database=ExpressRecipe.Notifications;User Id=sa;Password=YourPassword;TrustServerCertificate=True
# COMMUNITY_DB_CONNECTION_STRING=Server=localhost;Database=ExpressRecipe.Community;User Id=sa;Password=YourPassword;TrustServerCertificate=True
# SYNC_DB_CONNECTION_STRING=Server=localhost;Database=ExpressRecipe.Sync;User Id=sa;Password=YourPassword;TrustServerCertificate=True
# SCAN_DB_CONNECTION_STRING=Server=localhost;Database=ExpressRecipe.Scans;User Id=sa;Password=YourPassword;TrustServerCertificate=True
# PRICE_DB_CONNECTION_STRING=Server=localhost;Database=ExpressRecipe.Pricing;User Id=sa;Password=YourPassword;TrustServerCertificate=True
# RECALL_DB_CONNECTION_STRING=Server=localhost;Database=ExpressRecipe.Recalls;User Id=sa;Password=YourPassword;TrustServerCertificate=True
# SEARCH_DB_CONNECTION_STRING=Server=localhost;Database=ExpressRecipe.Search;User Id=sa;Password=YourPassword;TrustServerCertificate=True
# ANALYTICS_DB_CONNECTION_STRING=Server=localhost;Database=ExpressRecipe.Analytics;User Id=sa;Password=YourPassword;TrustServerCertificate=True

# ===========================================
# Redis Configuration
# ===========================================
REDIS_CONNECTION_STRING=localhost:6379
# REDIS_PASSWORD=

# ===========================================
# RabbitMQ Configuration
# ===========================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# ===========================================
# External API Keys
# ===========================================
# OpenFoodFacts (no key required - but rate limited)
# OPENFOODFACTS_USER_AGENT=ExpressRecipe/1.0

# USDA FoodData Central API
# Get key from: https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=REPLACE-WITH-YOUR-USDA-API-KEY

# OpenAI API (for AI features)
# OPENAI_API_KEY=REPLACE-WITH-YOUR-OPENAI-API-KEY

# Azure OpenAI (alternative to OpenAI)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=REPLACE-WITH-YOUR-AZURE-OPENAI-KEY
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4

# Barcode Lookup APIs (for scanner service)
# BARCODE_LOOKUP_API_KEY=REPLACE-WITH-YOUR-BARCODE-API-KEY

# ===========================================
# Service URLs (for non-Aspire deployments)
# ===========================================
# AUTH_SERVICE_URL=http://localhost:5000
# USER_SERVICE_URL=http://localhost:5001
# PRODUCT_SERVICE_URL=http://localhost:5002
# RECIPE_SERVICE_URL=http://localhost:5003
# INVENTORY_SERVICE_URL=http://localhost:5004
# SHOPPING_SERVICE_URL=http://localhost:5005
# MEALPLANNING_SERVICE_URL=http://localhost:5006
# NOTIFICATION_SERVICE_URL=http://localhost:5007
# SCANNER_SERVICE_URL=http://localhost:5008
# SEARCH_SERVICE_URL=http://localhost:5009
# COMMUNITY_SERVICE_URL=http://localhost:5010
# SYNC_SERVICE_URL=http://localhost:5011
# PRICE_SERVICE_URL=http://localhost:5012
# RECALL_SERVICE_URL=http://localhost:5013
# ANALYTICS_SERVICE_URL=http://localhost:5014
# AI_SERVICE_URL=http://localhost:5015

# ===========================================
# CORS Configuration
# ===========================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://localhost:7000

# ===========================================
# Email/SMS Configuration (for notifications)
# ===========================================
# SENDGRID_API_KEY=REPLACE-WITH-YOUR-SENDGRID-KEY
# TWILIO_ACCOUNT_SID=REPLACE-WITH-YOUR-TWILIO-SID
# TWILIO_AUTH_TOKEN=REPLACE-WITH-YOUR-TWILIO-TOKEN
# TWILIO_PHONE_NUMBER=+1234567890

# ===========================================
# Application Settings
# ===========================================
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=Information
# SERILOG_MINIMUM_LEVEL=Information
# APPLICATION_INSIGHTS_KEY=
